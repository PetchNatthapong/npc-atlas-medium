<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neurology — Board Review | Internal Medicine Subspecialty Series</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-blue: #1F4E79;
            --light-blue: #E7F0F7;
            --dark-gray: #333;
            --light-gray: #f5f5f5;
            --accent-orange: #FF8C42;
            --accent-amber: #FFF3E0;
            --success-green: #4CAF50;
            --warning-red: #d32f2f;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: var(--dark-gray);
            background-color: #fff;
        }

        body.dark-mode {
            background-color: #1a1a1a;
            color: #e0e0e0;
        }

        /* Header */
        header {
            background-color: var(--primary-blue);
            color: white;
            padding: 20px;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header-title {
            font-size: 28px;
            font-weight: bold;
        }

        .header-controls {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .search-bar {
            padding: 8px 12px;
            border: none;
            border-radius: 4px;
            width: 250px;
            font-size: 14px;
        }

        .search-bar.dark-mode {
            background-color: #333;
            color: #e0e0e0;
            border: 1px solid #555;
        }

        .dark-mode-toggle {
            background-color: rgba(255,255,255,0.2);
            border: 1px solid white;
            color: white;
            padding: 8px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }

        .dark-mode-toggle:hover {
            background-color: rgba(255,255,255,0.3);
        }

        /* Main Layout */
        .container {
            display: flex;
            min-height: calc(100vh - 80px);
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 250px;
            background-color: var(--light-gray);
            padding: 20px;
            position: sticky;
            top: 80px;
            max-height: calc(100vh - 80px);
            overflow-y: auto;
            border-right: 1px solid #ddd;
        }

        body.dark-mode .sidebar {
            background-color: #2a2a2a;
            border-right-color: #444;
        }

        .sidebar h3 {
            font-size: 14px;
            color: var(--primary-blue);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-link {
            display: block;
            padding: 10px 12px;
            margin-bottom: 5px;
            background-color: white;
            border-left: 3px solid transparent;
            cursor: pointer;
            border-radius: 2px;
            transition: all 0.2s;
            font-size: 14px;
        }

        body.dark-mode .nav-link {
            background-color: #333;
            color: #e0e0e0;
        }

        .nav-link:hover {
            background-color: var(--light-blue);
            border-left-color: var(--primary-blue);
        }

        .nav-link.active {
            background-color: var(--primary-blue);
            color: white;
            border-left-color: var(--accent-orange);
        }

        .progress-tracker {
            background-color: white;
            padding: 15px;
            border-radius: 4px;
            margin-top: 20px;
            font-size: 12px;
        }

        body.dark-mode .progress-tracker {
            background-color: #333;
        }

        .progress-bar {
            background-color: #e0e0e0;
            height: 20px;
            border-radius: 10px;
            overflow: hidden;
            margin: 10px 0;
        }

        .progress-fill {
            background-color: var(--success-green);
            height: 100%;
            width: 0%;
            transition: width 0.3s;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            padding: 40px;
            max-width: 1000px;
            margin: 0 auto;
            width: 100%;
        }

        .section {
            margin-bottom: 40px;
            display: none;
        }

        .section.active {
            display: block;
        }

        .section-title {
            font-size: 32px;
            color: var(--primary-blue);
            margin-bottom: 20px;
            border-bottom: 3px solid var(--primary-blue);
            padding-bottom: 10px;
        }

        body.dark-mode .section-title {
            color: #64b5f6;
        }

        .subsection {
            margin: 25px 0;
        }

        .subsection-title {
            font-size: 20px;
            color: var(--primary-blue);
            cursor: pointer;
            padding: 10px 0;
            display: flex;
            align-items: center;
            user-select: none;
            transition: color 0.2s;
        }

        .subsection-title:hover {
            color: var(--accent-orange);
        }

        .toggle-icon {
            margin-right: 10px;
            font-size: 18px;
            transition: transform 0.2s;
        }

        .subsection-content {
            max-height: 2000px;
            overflow: hidden;
            transition: max-height 0.3s ease;
            padding-left: 20px;
        }

        .subsection-content.collapsed {
            max-height: 0;
        }

        /* Clinical Pearl Box */
        .clinical-pearl {
            border-left: 4px solid var(--accent-orange);
            background-color: var(--accent-amber);
            padding: 15px;
            margin: 15px 0;
            border-radius: 2px;
        }

        body.dark-mode .clinical-pearl {
            background-color: #4d3a1a;
            border-left-color: #ffb74d;
        }

        .clinical-pearl strong {
            color: var(--accent-orange);
        }

        /* High-Yield Box */
        .high-yield {
            border-top: 4px solid var(--primary-blue);
            border-left: 4px solid var(--primary-blue);
            background-color: var(--light-blue);
            padding: 15px;
            margin: 15px 0;
            border-radius: 2px;
        }

        body.dark-mode .high-yield {
            background-color: #1a3a5a;
            border-top-color: #64b5f6;
            border-left-color: #64b5f6;
        }

        .high-yield-title {
            font-weight: bold;
            color: var(--primary-blue);
            margin-bottom: 8px;
        }

        body.dark-mode .high-yield-title {
            color: #64b5f6;
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
            font-size: 14px;
        }

        th {
            background-color: var(--primary-blue);
            color: white;
            padding: 12px;
            text-align: left;
            font-weight: 600;
        }

        td {
            padding: 10px 12px;
            border: 1px solid #ddd;
        }

        body.dark-mode td {
            border-color: #444;
        }

        tr:nth-child(even) {
            background-color: var(--light-gray);
        }

        body.dark-mode tr:nth-child(even) {
            background-color: #333;
        }

        /* Practice Questions */
        .practice-questions {
            margin-top: 40px;
            padding-top: 30px;
            border-top: 2px solid #ddd;
        }

        .question {
            background-color: var(--light-gray);
            padding: 20px;
            margin: 15px 0;
            border-radius: 4px;
            border-left: 4px solid var(--primary-blue);
        }

        body.dark-mode .question {
            background-color: #333;
            border-left-color: #64b5f6;
        }

        .question-text {
            font-weight: 600;
            margin-bottom: 15px;
            font-size: 15px;
        }

        .question-option {
            padding: 8px 0;
            margin: 5px 0;
            padding-left: 20px;
        }

        .question-option input[type="radio"] {
            margin-right: 8px;
        }

        .show-answer-btn {
            background-color: var(--primary-blue);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            margin-top: 15px;
            font-size: 14px;
            font-weight: 600;
        }

        .show-answer-btn:hover {
            background-color: #163a57;
        }

        .answer-content {
            background-color: var(--success-green);
            color: white;
            padding: 15px;
            margin-top: 10px;
            border-radius: 4px;
            display: none;
        }

        .answer-content.show {
            display: block;
        }

        .correct-answer {
            font-weight: bold;
            margin-bottom: 10px;
        }

        .explanation {
            margin-top: 10px;
            line-height: 1.6;
        }

        /* Search Highlight */
        .highlight {
            background-color: yellow;
            padding: 2px 4px;
            border-radius: 2px;
        }

        body.dark-mode .highlight {
            background-color: #ff9800;
            color: #000;
        }

        /* Print Styles */
        @media print {
            .sidebar, header, .header-controls, .progress-tracker {
                display: none;
            }

            .container {
                flex-direction: column;
            }

            .main-content {
                padding: 20px;
                max-width: 100%;
            }

            .section {
                display: block !important;
                page-break-inside: avoid;
                margin-bottom: 30px;
            }

            .subsection-content {
                max-height: none !important;
            }

            .subsection-content.collapsed {
                max-height: none !important;
            }

            body {
                color: black;
                background-color: white;
            }

            table {
                font-size: 12px;
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            .container {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                max-height: 300px;
                position: relative;
                top: auto;
                border-right: none;
                border-bottom: 1px solid #ddd;
            }

            .search-bar {
                width: 150px;
            }

            .header-title {
                font-size: 20px;
            }

            .main-content {
                padding: 20px;
            }

            .section-title {
                font-size: 24px;
            }

            .subsection-title {
                font-size: 16px;
            }
        }

        .list-item {
            margin-left: 20px;
            margin-bottom: 8px;
            list-style-type: disc;
        }

        strong {
            color: var(--primary-blue);
        }

        body.dark-mode strong {
            color: #64b5f6;
        }

        em {
            font-style: italic;
            color: var(--accent-orange);
        }

        /* Reference Box */
        .reference-box {
            border-left: 4px solid #2E7D32;
            background: #F1F8E9;
            padding: 16px 20px;
            margin: 20px 0;
            border-radius: 4px;
        }

        body.dark-mode .reference-box {
            background: #1B5E20;
            border-left-color: #81C784;
        }

        .reference-box h4 {
            color: #1B5E20;
            margin-top: 0;
            margin-bottom: 12px;
            font-size: 16px;
        }

        body.dark-mode .reference-box h4 {
            color: #C8E6C9;
        }

        .reference-box ul {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }

        .reference-box li {
            margin-bottom: 8px;
            font-size: 13px;
            line-height: 1.5;
        }

        .ref-guideline {
            color: #1B5E20;
            font-weight: bold;
        }

        body.dark-mode .ref-guideline {
            color: #81C784;
        }

        .ref-trial {
            color: #0D47A1;
            font-weight: bold;
        }

        body.dark-mode .ref-trial {
            color: #42A5F5;
        }

        .ref-trial strong {
            font-weight: bold;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <div class="header-title">🧠 Neurology — Board Review</div>
        <div class="header-controls">
            <input type="text" id="searchInput" class="search-bar" placeholder="Search content...">
            <button id="darkModeToggle" class="dark-mode-toggle">🌙 Dark Mode</button>
        </div>
    </header>

    <!-- Main Container -->
    <div class="container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <h3>Sections</h3>
            <div id="navLinks"></div>
            <div class="progress-tracker">
                <div style="font-weight: bold; margin-bottom: 10px;">Progress</div>
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <div id="progressText">0 of 12 sections read</div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">

            <!-- Section 1: Cerebrovascular Disease -->
            <section id="section-1" class="section active">
                <h1 class="section-title">1. Cerebrovascular Disease</h1>
                <p style="margin-bottom: 20px;">Cerebrovascular disease encompasses acute ischemic stroke (AIS), intracerebral hemorrhage (ICH), cerebral venous sinus thrombosis (CVT), and subarachnoid hemorrhage (SAH). This section integrates the 2026 AHA/ASA Guidelines and landmark trial evidence through 2025.</p>

                <h2 style="margin-top: 30px; color: #1565C0; border-bottom: 2px solid #1565C0; padding-bottom: 8px; font-size: 24px;">1.1 Acute Ischemic Stroke (AIS)</h2>


                <h2 style="margin-top: 30px; color: #1565C0; border-bottom: 2px solid #1565C0; padding-bottom: 8px; font-size: 24px;">1.2 Intracerebral Hemorrhage (ICH)</h2>


                <h2 style="margin-top: 30px; color: #1565C0; border-bottom: 2px solid #1565C0; padding-bottom: 8px; font-size: 24px;">1.3 Cerebral Venous Sinus Thrombosis (CVT)</h2>


                <h2 style="margin-top: 30px; color: #1565C0; border-bottom: 2px solid #1565C0; padding-bottom: 8px; font-size: 24px;">1.4 Subarachnoid Hemorrhage (SAH)</h2>


            </section>
            <section id="section-2" class="section">
                <h1 class="section-title">2. Epilepsy and Seizure Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>ILAE 2017 Classification of Seizures</span>
                    </div>
                    <div class="subsection-content">
                        <p>The ILAE 2017 classification divides seizures by onset location (focal vs generalized vs unknown) and consciousness level:</p>
                        <table>
                            <tr>
                                <th>Seizure Type</th>
                                <th>Onset</th>
                                <th>Consciousness</th>
                                <th>Features</th>
                            </tr>
                            <tr>
                                <td><strong>Focal Seizure</strong></td>
                                <td>Localized brain region</td>
                                <td>Aware or impaired</td>
                                <td>Motor, sensory, or autonomic symptoms; may progress to focal-to-bilateral tonic-clonic (FBTC)</td>
                            </tr>
                            <tr>
                                <td><strong>Generalized Tonic-Clonic</strong></td>
                                <td>Bilateral from onset</td>
                                <td>Impaired</td>
                                <td>Tonic phase (stiffening), clonic phase (jerking), post-ictal confusion</td>
                            </tr>
                            <tr>
                                <td><strong>Generalized Absence</strong></td>
                                <td>Bilateral</td>
                                <td>Impaired (brief cessation of awareness)</td>
                                <td>Staring spells, no motor activity, 3 Hz spike-and-wave EEG; onset typically 4-8 years</td>
                            </tr>
                            <tr>
                                <td><strong>Generalized Myoclonic</strong></td>
                                <td>Bilateral</td>
                                <td>Usually aware</td>
                                <td>Brief jerks of limbs, neck, face; common on awakening in JME</td>
                            </tr>
                            <tr>
                                <td><strong>Generalized Atonic (Drop)</strong></td>
                                <td>Bilateral</td>
                                <td>Impaired</td>
                                <td>Sudden loss of muscle tone; head drop or complete collapse; risk of injury</td>
                            </tr>
                            <tr>
                                <td><strong>Generalized Tonic</strong></td>
                                <td>Bilateral</td>
                                <td>Impaired</td>
                                <td>Sustained muscle stiffening without clonic phase; often during sleep (Lennox-Gastaut)</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The 2017 classification emphasized "focal onset with impaired awareness" (replacing older "complex partial") and "focal to bilateral tonic-clonic" (replacing "secondarily generalized"). This better reflects pathophysiology and helps guide treatment.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Epilepsy Syndromes in Children and Adolescents</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Syndrome</th>
                                <th>Age of Onset</th>
                                <th>Seizure Types</th>
                                <th>EEG Hallmark</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Childhood Absence Epilepsy (CAE)</strong></td>
                                <td>4-8 years (peak 5-7)</td>
                                <td>Absence (main), GTCS in 30-40%, myoclonic rare</td>
                                <td>3 Hz spike-and-wave (bilateral, synchronous, symmetric)</td>
                                <td>Good; 70-80% remission by adulthood. Ethosuximide or valproate first-line. Lamotrigine alternative.</td>
                            </tr>
                            <tr>
                                <td><strong>Juvenile Myoclonic Epilepsy (JME)</strong></td>
                                <td>8-20 years (peak 12-18)</td>
                                <td>Myoclonic (especially AM), absence (30-40%), GTCS</td>
                                <td>4-6 Hz polyspike-and-wave, background slowing</td>
                                <td>Excellent with medication (lifelong therapy required to prevent recurrence). Valproate first-line; levetiracetam or lamotrigine alternative. Avoid carbamazepine (may exacerbate myoclonic seizures).</td>
                            </tr>
                            <tr>
                                <td><strong>Temporal Lobe Epilepsy (TLE)</strong></td>
                                <td>Childhood or adult</td>
                                <td>Focal seizures with impaired awareness (aura + automatisms common)</td>
                                <td>Anterior temporal epileptiform activity, hippocampal sclerosis on MRI (unilateral or bilateral mesial TLE)</td>
                                <td>50-70% seizure-free with ASM; 40-50% candidates for surgical resection if drug-resistant (anterior temporal lobectomy success >70%)</td>
                            </tr>
                            <tr>
                                <td><strong>Lennox-Gastaut Syndrome (LGS)</strong></td>
                                <td>2-6 years (peak 3-5)</td>
                                <td>Multiple types: tonic, atonic (drop attacks), absence, GTCS, focal</td>
                                <td>1.5-2.5 Hz slow spike-and-wave (diffuse), slow background, hypsarrhythmia may be present</td>
                                <td>Poor; 10-15% seizure-free. Refractory in majority. Polypharmacy common (valproate + lamotrigine + levetiracetam). Canabidiol or lamotrigine novel options.</td>
                            </tr>
                            <tr>
                                <td><strong>West Syndrome (Infantile Spasms)</strong></td>
                                <td>4-8 months (peak 5-7 months)</td>
                                <td>Infantile spasms (brief flexor or extensor jerks in clusters), developmental regression</td>
                                <td>Hypsarrhythmia (chaotic, high-amplitude background with multifocal spikes)</td>
                                <td>Depends on etiology. ACTH or vigabatrin first-line. 30-50% seizure-free. Developmental outcome highly variable; underlying cause determines prognosis.</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Temporal Lobe Epilepsy (TLE) Deep Dive</div>
                            <p><strong>Classic Presentation:</strong> Focal seizure with impaired awareness starting in early adulthood or childhood (often after febrile seizure). Aura common (fear, autonomic symptoms, olfactory/gustatory hallucinations). Automatisms during seizure: lip smacking, picking, undressing. Post-ictal confusion 30 seconds to minutes.</p>
                            <p><strong>EEG Patterns:</strong> Anterior temporal epileptiform discharges (spikes/sharp waves), often unilateral. Sleep enhances EEG abnormalities.</p>
                            <p><strong>MRI findings:</strong> Mesial temporal sclerosis (hippocampal atrophy, T2 hyperintensity), unilateral or bilateral. Correlates with seizure localization.</p>
                            <p><strong>Treatment:</strong> First-line ASM: levetiracetam, lamotrigine, valproate, carbamazepine, oxcarbazepine. 50-70% achieve seizure freedom with monotherapy. If drug-resistant (≥2 ASM failures), consider surgical evaluation (anterior temporal lobectomy, >70% seizure-free post-op).</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Antiseizure Medications (ASM): Mechanisms, Dosing, Side Effects</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>ASM</th>
                                <th>Mechanism</th>
                                <th>Common Dosing</th>
                                <th>Key Side Effects / Considerations</th>
                            </tr>
                            <tr>
                                <td><strong>Levetiracetam (Keppra)</strong></td>
                                <td>SV2A protein binding; exact mechanism unclear</td>
                                <td>Initial 500 mg BID; titrate 500 mg weekly to 1500-3000 mg/day divided BID</td>
                                <td>Behavioral changes (irritability, mood lability, psychosis in 1-3%), somnolence, asthenia. No drug interactions; renal clearance.</td>
                            </tr>
                            <tr>
                                <td><strong>Lamotrigine (Lamictal)</strong></td>
                                <td>Na+ channel blockade, glutamate release inhibition</td>
                                <td>Initial 25 mg daily (halve if on valproate); titrate slowly Q1-2wks; maintenance 100-500 mg/day divided BID</td>
                                <td><strong>SEVERE RASH (SJS/TEN) in 0.3% (higher with rapid titration, HLA-B*1502 allele)</strong>. Diplopia, ataxia, tremor. Excellent for absence and myoclonic seizures; effective for partial seizures. Monitor LFTs.</td>
                            </tr>
                            <tr>
                                <td><strong>Valproic Acid (Depakote)</strong></td>
                                <td>GABA enhancement, Na+ channel blockade</td>
                                <td>Initial 500-750 mg daily divided; titrate 250-500 mg/day; maintenance 1000-2000 mg/day divided TID</td>
                                <td><strong>TERATOGEN (neural tube defects, developmental delay in 30% if exposed in utero)</strong>. Hepatotoxicity (monitor LFTs, risk higher <2 yrs), pancreatitis, tremor, weight gain, alopecia, thrombocytopenia. Excellent for absence, myoclonic, generalized tonic-clonic. Avoid in women of childbearing age unless no alternatives.</td>
                            </tr>
                            <tr>
                                <td><strong>Carbamazepine (Tegretol)</strong></td>
                                <td>Na+ channel blockade, polysnaptic synaptic transmission inhibition</td>
                                <td>Initial 100-200 mg BID; titrate 100-200 mg Q1-2wks; maintenance 800-1200 mg/day divided BID-QID</td>
                                <td>Diplopia, ataxia, rash (3-8%, SJS/TEN in 0.1%; HLA-B*1502 risk), hyponatremia (SIADH), hepatotoxicity. Autoinduction (increases own metabolism over 3-4 wks). First-line for focal and GTCS. AVOID in JME (exacerbates myoclonic seizures).</td>
                            </tr>
                            <tr>
                                <td><strong>Oxcarbazepine (Trileptal)</strong></td>
                                <td>Na+ channel blockade (similar to CBZ but faster metabolism)</td>
                                <td>Initial 300-600 mg BID; titrate 600 mg/day Q3-7days; maintenance 900-1800 mg/day divided BID</td>
                                <td>Hyponatremia (more frequent than CBZ), rash (milder than CBZ), diplopia, ataxia. No autoinduction. Better tolerated than CBZ; lower interaction potential. First-line for focal seizures.</td>
                            </tr>
                            <tr>
                                <td><strong>Lacosamide (Vimpat)</strong></td>
                                <td>Na+ channel enhancement (inactivation stabilization)</td>
                                <td>Initial 50 mg BID; increase 50 mg BID Q1wk; maintenance 100-200 mg BID (max 400 mg/day)</td>
                                <td>Diplopia, ataxia, dizziness, PR prolongation on ECG (monitor especially if on beta blockers). IV form useful for acute seizure loading. Focal seizure adjunctive therapy.</td>
                            </tr>
                            <tr>
                                <td><strong>Phenytoin (Dilantin)</strong></td>
                                <td>Na+ channel blockade</td>
                                <td>IV load 15-20 mg/kg; oral maintenance 300-400 mg/day divided BID-QID</td>
                                <td><strong>MANY side effects and interactions.</strong> Gingival hyperplasia, hirsutism, coarse facial features, peripheral neuropathy, hepatotoxicity, SJS/TEN, folate/B12 deficiency, osteoporosis, lupus-like syndrome. Nonlinear kinetics (small dose increases cause large [level] changes). Mostly used for acute loading (IV form) or as backup; avoid as monotherapy if possible.</td>
                            </tr>
                            <tr>
                                <td><strong>Ethosuximide (Zarontin)</strong></td>
                                <td>T-type Ca2+ channel blockade</td>
                                <td>Initial 250 mg daily; titrate 250 mg Q3-7days; maintenance 500-1500 mg/day divided BID-TID</td>
                                <td>Gastrointestinal upset (nausea), abdominal pain, somnolence, rash, SJS/TEN risk, mood changes. <strong>SPECIFIC for absence seizures</strong>; ineffective for tonic-clonic or other generalized seizures. First-line for absence.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> When choosing ASMs, always consider syndrome-specific efficacy. Carbamazepine exacerbates myoclonic seizures in JME, while valproate is ideal. Lamotrigine is excellent for absence but requires slow titration. Levetiracetam has fewer drug interactions but behavioral side effects require monitoring.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Status Epilepticus: Diagnosis & Management Algorithm</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Definition:</strong> Seizures lasting >5 minutes or ≥2 seizures without recovery of consciousness between them. Includes both generalized convulsive SE (GCSE) and non-convulsive SE (NCSE).</p>

                        <table>
                            <tr>
                                <th>Stage</th>
                                <th>Timing</th>
                                <th>Treatment</th>
                                <th>Details</th>
                            </tr>
                            <tr>
                                <td><strong>Stage 1: Early SE (0-5 min)</strong></td>
                                <td>Ongoing seizure at evaluation</td>
                                <td>Lorazepam 0.1 mg/kg IV (max 4 mg) OR midazolam 0.2 mg/kg IM (max 10 mg, preferred out-of-hospital)</td>
                                <td>Establish IV access if possible. IM midazolam has faster onset and duration than IV lorazepam in some studies. Repeat after 5-10 min if seizure continues.</td>
                            </tr>
                            <tr>
                                <td><strong>Stage 2: Early SE (5-20 min)</strong></td>
                                <td>Seizure ongoing despite benzodiazepine</td>
                                <td><strong>Second-line agent</strong> (choose one):<br/>• IV Fosphenytoin 15-20 mg PE/kg<br/>• IV Valproate 20-40 mg/kg<br/>• IV Levetiracetam 30-60 mg/kg (ESETT trial shows equal efficacy to phenytoin)<br/>• IV Lacosamide 200-400 mg</td>
                                <td>ESETT trial (2019) showed levetiracetam, fosphenytoin, and valproate had similar efficacy (~50-60% seizure cessation). Levetiracetam becoming preferred due to fewer interactions and side effects. Phenytoin largely replaced by fosphenytoin (better tolerated, faster infusion).</td>
                            </tr>
                            <tr>
                                <td><strong>Stage 3: Refractory SE (20-40 min)</strong></td>
                                <td>Seizure refractory to Stage 2 agent</td>
                                <td><strong>Anesthesia required</strong>: Intubate, then continuous infusion:<br/>• Propofol 1-3 mg/kg bolus, then 5-10 mcg/kg/min infusion<br/>• Midazolam 0.1-0.2 mg/kg bolus, then 0.5-2 mcg/kg/min infusion<br/>• Pentobarbital 5-15 mg/kg bolus, then 0.5-5 mg/kg/hr<br/>• Ketamine (increasingly used): 1-2 mg/kg IV</td>
                                <td>Goal: achieve burst suppression on EEG. Requires ICU admission, continuous EEG monitoring, vasopressor support often needed. High mortality (30-50% if RSE). Intubation mandatory for airway protection.</td>
                            </tr>
                            <tr>
                                <td><strong>Stage 4: Super-Refractory SE (>60-90 min)</strong></td>
                                <td>Seizures continue despite anesthetic agents</td>
                                <td>Consider: Multiple anesthetic agents, high-dose continuous infusions, hypothermia, extracorporeal rewarming, ECMO (select cases)</td>
                                <td>Involves multi-disciplinary ICU team, neurology consultation essential. Prognosis poor; explore underlying causes aggressively (infection, stroke, autoimmune encephalitis).</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Non-Convulsive Status Epilepticus (NCSE)</div>
                            <p>Suspect in patients with unexplained altered consciousness, confusion, or behavioral changes with minimal or absent convulsive movements. May occur post-ictal, or as subtle myoclonic jerks only visible on EEG. <strong>ALWAYS obtain EEG if clinical suspicion high.</strong> Treatment is same as GCSE (Stage 1-4 algorithm). High mortality if unrecognized and untreated.</p>
                        </div>

                        <p><strong>Epilepsy in Pregnancy:</strong> Seizure frequency increases in 20-30% of women due to decreased drug levels. Counsel preconception: benefits of seizure control outweigh fetal risk from most ASMs. Levetiracetam and lamotrigine have lower teratogenic risk (Category B). Valproate and phenytoin highest risk (avoid). Continue ASM throughout pregnancy. Monitor levels Q3-4 wks (some agents require dosing increases during pregnancy). Vitamin K supplementation (phytomenadione 10 mg daily) in last 4 weeks to reduce neonatal bleeding risk if on enzyme-inducing ASMs.</p>
                    </div>
                </div>

                <!-- Practice Question 2 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q2: A 16-year-old female presents with morning myoclonic jerks of the arms and legs for 1 month, progressing to 2 generalized tonic-clonic seizures in the past 2 weeks. EEG shows 4-6 Hz polyspike-and-wave discharges. Which ASM is contraindicated in this patient?</div>
                        <div class="question-option">
                            <input type="radio" name="q2" value="a"> A) Levetiracetam
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q2" value="b"> B) Carbamazepine
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q2" value="c"> C) Valproate
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q2" value="d"> D) Lamotrigine
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q2')">Show Answer</button>
                        <div id="q2-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical and EEG findings are classic for Juvenile Myoclonic Epilepsy (JME): age 12-20, morning myoclonic jerks, generalized tonic-clonic seizures, and 4-6 Hz polyspike-and-wave on EEG. Carbamazepine is specifically contraindicated in JME because it exacerbates myoclonic seizures. Valproate is the gold standard first-line (though teratogenic concerns in young women), and levetiracetam and lamotrigine are excellent alternatives. Understanding syndrome-specific drug selection is critical to avoid worsening seizures.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> ILAE 2017 Classification of Seizure Types and Epilepsies. Fisher RS et al. <em>Epilepsia</em>. 2017;58:512-521 & Scheffer IE et al. <em>Epilepsia</em>. 2017;58:531-542.</li>
                        <li><span class="ref-guideline">[G2]</span> AAN/AES Guideline: Treatment of New-Onset Epilepsy. Kanner AM et al. <em>Neurology</em>. 2018;91:74-81.</li>
                        <li><span class="ref-guideline">[G3]</span> AES/NCS Guideline: Status Epilepticus Management. Brophy GM et al. <em>Neurocrit Care</em>. 2012;17:3-23.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ESETT:</strong> Kapur J et al. <em>NEJM</em> 2019;381:2103-13. Fosphenytoin vs levetiracetam vs valproate for BZD-refractory SE. All three equally effective (~45%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>RAMPART:</strong> Silbergleit R et al. <em>NEJM</em> 2012;366:591-600. IM midazolam non-inferior to IV lorazepam for prehospital SE.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SANAD I:</strong> Marson AG et al. <em>Lancet</em> 2007;369:1000-15. Valproate best for generalized; lamotrigine for focal epilepsy.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SANAD II:</strong> Marson AG et al. <em>Lancet</em> 2021;397:1363-74. Levetiracetam inferior to valproate (generalized) and lamotrigine (focal).</li>
                        <li><span class="ref-trial">[T]</span> <strong>MESS:</strong> Marson A et al. <em>Lancet</em> 2005;365:2007-13. Early vs deferred ASM after first seizure.</li>
                        <li><span class="ref-trial">[T]</span> <strong>FIRST:</strong> Musicco M et al. <em>Neurology</em> 1997;49:991-8. Treating first seizure does not alter ultimate prognosis.</li>
                        <li>[R] Tomson T et al. <strong>EURAP:</strong> Antiepileptic drug exposure in pregnancy. <em>Lancet Neurol</em>. 2018;17:530-38. Valproate highest malformation rate (10.3%); lamotrigine/levetiracetam lowest (2.8-2.9%).</li>
                        <li>[R] Engel J Jr et al. Practice parameter: Temporal lobe resections for epilepsy. <em>Neurology</em>. 2003;60:538-47. Class I evidence for surgery.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 6: Movement Disorders -->
            <section id="section-6" class="section">
                <h1 class="section-title">6. Movement Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Parkinson's Disease: Diagnosis & Cardinal Features</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Diagnostic Criteria (UK Parkinson's Disease Society):</strong> Bradykinesia PLUS at least one of: resting tremor OR rigidity. Supportive features include asymmetric onset, excellent response to levodopa, presence of dyskinesias from levodopa.</p>

                        <table>
                            <tr>
                                <th>Cardinal Feature</th>
                                <th>Characteristics</th>
                                <th>Assessment</th>
                            </tr>
                            <tr>
                                <td><strong>Bradykinesia</strong></td>
                                <td>Slow, effortful movement. Loss of normal arm swing, micrographia, hypophonia</td>
                                <td>Tap index/thumb fingers, pronation/supination, timed 10-meter walk</td>
                            </tr>
                            <tr>
                                <td><strong>Resting Tremor</strong></td>
                                <td>4-6 Hz, "pill-rolling" tremor at rest, disappears with action</td>
                                <td>Observe at rest; ask patient to perform mental arithmetic to distract (brings out tremor)</td>
                            </tr>
                            <tr>
                                <td><strong>Rigidity</strong></td>
                                <td>Increased tone throughout range of motion. "Lead pipe" (uniform) or "cogwheel" (ratchety, from superimposed tremor)</td>
                                <td>Passive range of motion testing; ask patient to relax; move joints slowly</td>
                            </tr>
                            <tr>
                                <td><strong>Postural Instability</strong></td>
                                <td>Impaired righting reflexes; falls risk; stooped posture with forward-flexed trunk</td>
                                <td>Pull test (positive if falls back without catching themselves or 1 step back = abnormal)</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Non-Motor Symptoms of PD</div>
                            <p>Often precede motor symptoms by years. Include: depression, anxiety, REM sleep behavior disorder, constipation, hyposmia, cognitive decline, orthostatic hypotension, urinary frequency, sexual dysfunction, pain syndromes. MoCA or MMSE useful for tracking cognitive decline.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>PD Pharmacotherapy</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Drug Class</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy/Uses</th>
                                <th>Side Effects</th>
                            </tr>
                            <tr>
                                <td><strong>Levodopa</strong></td>
                                <td>Carbidopa-levodopa (Sinemet), benserazide-levodopa</td>
                                <td>Precursor to dopamine; crosses BBB (with decarboxylase inhibitor)</td>
                                <td>Most effective agent for motor symptoms; carbidopa blocks peripheral conversion. Start low, titrate slowly. Typical 300-600 mg/day divided TID-QID</td>
                                <td>Motor complications (dyskinesia, wearing-off, on-off phenomena) increase with dose/duration. GI upset, orthostatic hypotension</td>
                            </tr>
                            <tr>
                                <td><strong>Dopamine Agonists</strong></td>
                                <td>Pramipexole, ropinirole, rotigotine patch</td>
                                <td>Direct dopamine D2/D3 receptor agonists</td>
                                <td>Slower progression of dyskinesia vs levodopa monotherapy (LEAP study). Often used in younger patients; less effective than levodopa</td>
                                <td>Hallucinations (esp. in older/cognitively impaired), impulse control disorders (gambling, hypersexuality), somnolence, orthostatic hypotension, leg edema</td>
                            </tr>
                            <tr>
                                <td><strong>MAO-B Inhibitors</strong></td>
                                <td>Selegiline, rasagiline</td>
                                <td>Block monoamine oxidase-B (dopamine catabolism)</td>
                                <td>Modest symptomatic benefit (10-15% better than placebo). Rasagiline may slow progression (delayed start study). Adjunct to levodopa</td>
                                <td>Hypertension (avoid with SSRIs, tramadol due to serotonin syndrome risk), GI upset</td>
                            </tr>
                            <tr>
                                <td><strong>COMT Inhibitors</strong></td>
                                <td>Entacapone, tolcapone</td>
                                <td>Block catechol-O-methyl transferase (dopamine catabolism)</td>
                                <td>Extend levodopa duration by 25-30%; useful in wearing-off; taken with each levodopa dose</td>
                                <td>Diarrhea, orange urine discoloration, increased dyskinesia (from prolonged dopamine levels)</td>
                            </tr>
                            <tr>
                                <td><strong>Anticholinergics</strong></td>
                                <td>Benztropine, trihexyphenidyl</td>
                                <td>Block muscarinic acetylcholine receptors</td>
                                <td>Effective for tremor-dominant PD; less helpful for bradykinesia. Use avoided in older patients (cognitive risk)</td>
                                <td>Cognitive impairment, hallucinations, urinary retention, dry mouth, constipation. Mostly avoided in modern practice</td>
                            </tr>
                            <tr>
                                <td><strong>Amantadine</strong></td>
                                <td>Amantadine (symmetric adamantane)</td>
                                <td>NMDA antagonist, dopamine release enhancer, anticholinergic effects</td>
                                <td>Modest effect on bradykinesia/rigidity; useful for levodopa-induced dyskinesia (FDA approved for this). Doses 100-200 mg BID</td>
                                <td>Livedo reticularis (reversible reticulated rash), orthostatic hypotension, cognitive effects, renal clearance</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl - LEAP Trial Finding:</strong> The LEAP study showed that early dopamine agonist monotherapy delayed dyskinesia onset compared to early levodopa, but motor control was superior with levodopa. This led to individualized treatment: younger patients (especially <60 yrs) often started on dopamine agonists to delay levodopa introduction and dyskinesia onset; older patients or those needing maximal symptom control started on levodopa. <strong>Levodopa does NOT accelerate PD progression</strong> (disproven by modern studies).
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Atypical Parkinsonism: Differential Diagnosis</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Disorder</th>
                                <th>Key Distinguishing Features</th>
                                <th>Pathology</th>
                                <th>Response to Levodopa</th>
                            </tr>
                            <tr>
                                <td><strong>Multiple System Atrophy (MSA)</strong></td>
                                <td><em>MSA-P:</em> Parkinsonian (akinetic-rigid). <em>MSA-C:</em> Cerebellar (ataxia, dysarthria). Autonomic dysfunction (OH, urinary incontinence, erectile dysfunction) prominent. Early gait instability. Hypokinetic dysarthria. "Hot cross bun" sign on MRI (atrophy of pons/cerebellar peduncles)</td>
                                <td>Glial cytoplasmic inclusions (GCI); loss of striatal neurons, Purkinje cells, pontine nuclei</td>
                                <td>Poor; minimal benefit to levodopa (distinguishes from PD)</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive Supranuclear Palsy (PSP)</strong></td>
                                <td>Vertical supranuclear gaze palsy (looking down affected before up). Early falls (postural instability with backward falls). "Hummingbird sign" on MRI (midbrain atrophy). Pseudobulbar palsy. Facial dystonia. Apathy, cognitive decline</td>
                                <td>Neurofibrillary tangles (tau pathology) in midbrain, brainstem, basal ganglia</td>
                                <td>Poor; levodopa unresponsive</td>
                            </tr>
                            <tr>
                                <td><strong>Corticobasal Degeneration (CBD)</strong></td>
                                <td>Asymmetric parkinsonism and dystonia. Limb apraxia. Alien hand syndrome (involuntary movements of one limb). Cortical sensory loss. Myoclonus. "Cortical" tremor (task-specific). Speech apraxia</td>
                                <td>Tau pathology with Pick bodies, astrocytic plaques, achromatic neurons in cortex and substantia nigra</td>
                                <td>Poor; minimal levodopa response</td>
                            </tr>
                            <tr>
                                <td><strong>Dementia with Lewy Bodies (DLB)</strong></td>
                                <td>Cognitive decline prominent and early (before or concurrent with motor symptoms, distinguishing from PD-dementia). Visual hallucinations (detailed, animated). REM sleep behavior disorder. Sensitivity to antipsychotics (can precipitate severe parkinsonism, NMS)</td>
                                <td>Lewy bodies (alpha-synuclein); loss of cholinergic neurons and dopaminergic neurons</td>
                                <td>Variable; levodopa benefit less consistent than PD. Hallucinations often persist</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The presence of <strong>vertical supranuclear gaze palsy</strong> is nearly pathognomonic for PSP. <strong>Early falls</strong> (within first year) and <strong>poor levodopa response</strong> suggest atypical parkinsonism rather than PD. <strong>Autonomic dysfunction as leading feature</strong> suggests MSA.
                        </div>

                        <p><strong>DLB Antipsychotic Warning:</strong> Patients with DLB have severe sensitivity to dopamine-blocking agents. Typical antipsychotics (haloperidol, chlorpromazine) and even some atypical agents (risperidone, olanzapine) can precipitate fulminant parkinsonism, neuroleptic malignant syndrome-like picture, and death. If antipsychotic absolutely necessary, quetiapine or pimavanserin preferred; use lowest dose.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Other Movement Disorders: Essential Tremor, Chorea, Dystonia</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Essential Tremor (ET):</strong> Most common movement disorder. Kinetic (action) tremor 4-12 Hz, affects hands (asymmetric common), head, voice. Worsened by anxiety, caffeine, fatigue; improved by alcohol. Treatment: propranolol (first-line, 20-160 mg/day), primidone, topiramate. Botulinum toxin for head/voice tremor. Deep brain stimulation for severe, refractory cases.</p>

                        <p><strong>Huntington's Disease (Chorea):</strong> CAG trinucleotide repeat expansion. Involuntary jerking, writhing movements (choreiform). Cognitive decline, behavioral changes (irritability, apathy, depression), executive dysfunction. Onset typically 40-50 years (juvenile form if <20 yrs, progresses faster). No cure; tetrabenazine or deutetrabenazine (VMAT2 inhibitors) reduce chorea. Antipsychotics (haloperidol, quetiapine) as adjuncts. Genetic counseling and predictive testing available for at-risk relatives.</p>

                        <p><strong>Sydenham's Chorea:</strong> Post-rheumatic fever complication (weeks after group A strep pharyngitis). Self-limited (resolves in 3-6 months typically). Causes involuntary movements, emotional lability, weakness. Treat with NSAIDs, corticosteroids if severe, penicillin for any residual strep infection.</p>

                        <p><strong>Tardive Dyskinesia (TD):</strong> Complication of prolonged antipsychotic use (typical agents higher risk, but atypical also cause). Involuntary orofacial, limb, truncal movements; may persist even after drug discontinuation. Prevention: use lowest antipsychotic dose, atypicals preferred. Treatment: switch to aripiprazole (dopamine partial agonist—paradoxically helps TD), valbenazine or deutetrabenazine (VMAT2 inhibitors), tetrabenazine.</p>

                        <p><strong>Dystonia:</strong> Involuntary sustained muscle contractions causing abnormal postures/repetitive movements. Can be generalized (affects multiple body regions) or focal (one region: blepharospasm, cervical dystonia, writer's cramp). Causes include genetic (DYT1, etc.), secondary (stroke, trauma, drugs, Wilson's disease), idiopathic. Botulinum toxin injections effective for focal dystonia. Oral agents (anticholinergics, benzodiazepines) have variable effect. Deep brain stimulation for generalized, severe cases.</p>
                    </div>
                </div>

                <!-- Practice Question 3 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q3: A 72-year-old male presents with a 2-year history of progressive parkinsonism. Noted for early falls (backward) in the first year despite treatment, vertical gaze restriction particularly downward, and midbrain atrophy on MRI ("hummingbird sign"). He has had minimal response to maximum-tolerated doses of levodopa. Which diagnosis is most consistent?</div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="a"> A) Parkinson's disease with early postural instability
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="b"> B) Progressive Supranuclear Palsy (PSP)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="c"> C) Multiple System Atrophy, Parkinsonian subtype (MSA-P)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="d"> D) Corticobasal degeneration with asymmetric presentation
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q3')">Show Answer</button>
                        <div id="q3-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical triad strongly favors PSP: (1) vertical supranuclear gaze palsy (restricted downward gaze), (2) early falls (hallmark of PSP, distinguishes from typical PD), and (3) midbrain atrophy ("hummingbird sign" is nearly pathognomonic). The poor levodopa response further distinguishes atypical parkinsonism from PD. MSA-P presents with autonomic dysfunction as a leading feature and shows "hot cross bun" sign, not hummingbird. CBD typically has asymmetric cortical features (apraxia, alien hand) rather than symmetric gaze palsy.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> MDS Clinical Diagnostic Criteria for Parkinson Disease. Postuma RB et al. <em>Mov Disord</em>. 2015;30:1591-1601.</li>
                        <li><span class="ref-guideline">[G2]</span> MDS Criteria for the Diagnosis of PSP. Hoglinger GU et al. <em>Mov Disord</em>. 2017;32:853-864.</li>
                        <li><span class="ref-guideline">[G3]</span> Consensus Criteria for MSA. Gilman S et al. <em>Neurology</em>. 2008;71:670-676. Updated: Wenning GK et al. <em>Mov Disord</em>. 2022.</li>
                        <li><span class="ref-guideline">[G4]</span> Consensus Criteria for CBD. Armstrong MJ et al. <em>Neurology</em>. 2013;80:496-503.</li>
                        <li><span class="ref-guideline">[G5]</span> DLB Fourth Consensus Report. McKeith IG et al. <em>Neurology</em>. 2017;89:88-100.</li>
                        <li><span class="ref-trial">[T]</span> <strong>LEAP:</strong> Verschuur CVM et al. <em>NEJM</em> 2019;380:315-24. Levodopa does NOT accelerate PD. Safe to start when clinically needed.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ELLDOPA:</strong> Fahn S et al. <em>NEJM</em> 2004;351:2498-2508. Higher levodopa doses = better symptom control. No accelerated progression.</li>
                        <li><span class="ref-trial">[T]</span> <strong>EARLYSTIM:</strong> Schuepbach WMM et al. <em>NEJM</em> 2013;368:610-22. DBS (STN) superior to best medical therapy in early motor complications.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ADAGIO:</strong> Olanow CW et al. <em>NEJM</em> 2009;361:1268-78. Rasagiline possible disease-modifying effect (1 mg only).</li>
                        <li>[R] Postuma RB et al. Risk and predictors in idiopathic RBD. <em>Brain</em>. 2019;142:744-759. Phenoconversion >80% at 10-15 years.</li>
                        <li>[R] McColgan P, Tabrizi SJ. Huntington Disease. <em>NEJM</em> 2020;382:1753-64.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 7: Headache Disorders -->
            <section id="section-7" class="section">
                <h1 class="section-title">7. Headache Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Red Flags for Secondary Headache (SNOOP10)</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>SNOOP10 mnemonic for red flags suggesting secondary headache:</strong></p>
                        <ul class="list-item">
                            <li><strong>S</strong> - Systemic illness (fever, weight loss, malaise)</li>
                            <li><strong>N</strong> - Neurologic symptoms or signs (focal deficits, papilledema, altered consciousness)</li>
                            <li><strong>O</strong> - Onset sudden (thunderclap headache suggests SAH, reversible cerebral vasoconstriction, etc.)</li>
                            <li><strong>O</strong> - Older age (>50 years); new-onset headache in this group warrants investigation</li>
                            <li><strong>P</strong> - Papilledema, focal neurologic signs, or progressive worsening</li>
                            <li><strong>1</strong> - Pattern change (headache that has changed character, frequency, severity from baseline)</li>
                            <li><strong>0</strong> - Immunocompromised (HIV, chemotherapy, post-transplant) or on anticoagulation/recent head trauma</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Management Approach</div>
                            <p>Presence of ANY red flag warrants neuroimaging (MRI brain with/without contrast, or stat CT if acute), LP if imaging negative, and specialist evaluation. Primary headache diagnosis (migraine, tension, cluster) requires absence of red flags AND meeting clinical criteria.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine: Diagnostic Criteria (ICHD-3) & Acute Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>ICHD-3 Criteria for Migraine without Aura:</strong> At least 5 attacks with: (1) headache 4-72 hours, (2) at least 2 of: unilateral, pulsating quality, moderate-severe pain, aggravated by physical activity, AND (3) at least 1 of: nausea/vomiting OR photophobia/phonophobia.</p>

                        <p><strong>Migraine with Aura:</strong> Similar criteria but preceded by 5-60 minute aura (visual: scotoma, flashing lights; sensory: paresthesias; speech/language disturbance), fully reversible.</p>

                        <table>
                            <tr>
                                <th>Acute Treatment Class</th>
                                <th>Agent & Dosing</th>
                                <th>Efficacy Notes</th>
                            </tr>
                            <tr>
                                <td><strong>NSAIDs</strong></td>
                                <td>Ibuprofen 400-800 mg, naproxen 500 mg, aspirin 1000 mg PO</td>
                                <td>Effective for mild-moderate migraine. Risk with frequent use (>10-15 days/month): medication overuse headache</td>
                            </tr>
                            <tr>
                                <td><strong>Triptans</strong></td>
                                <td>Sumatriptan 50 mg PO / 20 mg nasal / 6 mg SC (most common). Alternatives: rizatriptan, naratriptan, zolmitriptan, almotriptan</td>
                                <td>Gold standard for moderate-severe migraine. 50-60% 2-hour pain-free rate. Contraindicated in uncontrolled HTN, CAD, prior MI/stroke, Raynaud's. Avoid frequent use (>10 days/month—rebound headache risk).</td>
                            </tr>
                            <tr>
                                <td><strong>Calcitonin Gene-Related Peptide (CGRP) Antagonists (Gepants)</strong></td>
                                <td>Ubrogepant 50-100 mg PO, rimegepant 75 mg PO (can be used preventively Q2 days), lasmiditan (5-HT1F agonist, structurally distinct)</td>
                                <td>Novel class; comparable efficacy to triptans (50-60% 2-hour pain-free). Advantages: no vasoconstrictive effects, safe in CAD/uncontrolled HTN. Drawback: cost. Good option if triptan contraindicated or failed.</td>
                            </tr>
                            <tr>
                                <td><strong>Ditans</strong></td>
                                <td>Lasmiditan 50-200 mg PO (5-HT1F agonist, distinct serotonin pathway)</td>
                                <td>Efficacy similar to triptans. Advantage: no vasoconstriction, safe in coronary disease. Caution: CNS effects (dizziness); avoid driving 8 hrs post-dose. Emerging class.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiemetics</strong></td>
                                <td>Metoclopramide 10 mg IV/IM, prochlorperazine 10 mg IV/IM, ondansetron 8 mg IV</td>
                                <td>Essential adjunct, especially for moderate-severe migraines with nausea. Can be monotherapy for mild cases. Metoclopramide enhances triptan absorption when given with oral triptan.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> <strong>Timing is critical.</strong> Acute migraine treatment is most effective when given early in migraine course (within 1-2 hours of onset). Repeated dosing after 2 hours if pain returns is less effective than initial dose. Triptan + NSAID combination often more effective than monotherapy.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine Prevention: Pharmacologic & Non-Pharmacologic</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Agent Class</th>
                                <th>Specific Drugs & Dosing</th>
                                <th>Efficacy & Notes</th>
                            </tr>
                            <tr>
                                <td><strong>Beta-Blockers</strong></td>
                                <td>Propranolol 40-240 mg/day divided TID, timolol, metoprolol</td>
                                <td>First-line. Reduce migraine frequency by 40-60%. Particularly effective for migraine with aura, migraine with palpitations, or concurrent hypertension. SE: fatigue, erectile dysfunction.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiepileptics</strong></td>
                                <td>Topiramate (Topamax) 50-200 mg/day; valproate 500-1500 mg/day; lamotrigine 100-200 mg/day</td>
                                <td>Topiramate most evidence. 40-50% reduction in migraine frequency. SE: cognitive effects, weight loss (topiramate, valproate), teratogenicity (valproate). Valproate rarely used now due to teratogenic risk.</td>
                            </tr>
                            <tr>
                                <td><strong>Tricyclic Antidepressants</strong></td>
                                <td>Amitriptyline 10-100 mg nightly; nortriptyline alternative</td>
                                <td>Effective, especially if concurrent depression/anxiety. 40-50% frequency reduction. SE: dry mouth, weight gain, sedation, anticholinergic effects. Often combined with other preventives.</td>
                            </tr>
                            <tr>
                                <td><strong>CGRP Monoclonal Antibodies (mAbs)</strong></td>
                                <td>Erenumab (Aimovig) 70-140 mg SC monthly, fremanezumab (Ajovy) 225 mg SC monthly or 675 mg quarterly, galcanezumab (Emgality) 240 mg SC loading, then 120 mg monthly, eptinezumab (Vyepti) IV quarterly</td>
                                <td>Highly effective; 40-50% migraine day reduction. Safe, well-tolerated. No serious black-box warnings. Monthly or quarterly dosing improves compliance. Cost/insurance barriers remain. Indication: ≥4 migraine days/month.</td>
                            </tr>
                            <tr>
                                <td><strong>Botulinum Toxin (Botox)</strong></td>
                                <td>Injections 155 units total (across forehead, temples, occiput, neck) Q12 weeks</td>
                                <td>FDA-approved for chronic migraine (≥15 days/month). ~45% responders with ≥50% reduction. Mechanism unclear but effective. Requires repeat injections every 12 weeks.</td>
                            </tr>
                            <tr>
                                <td><strong>Neuromodulation</strong></td>
                                <td>Occipital nerve stimulation (ONS), supraorbital nerve stimulation (SONS), vagus nerve stimulation (VNS)</td>
                                <td>Emerging options for refractory chronic migraine. Implantable devices; mixed evidence but growing support. Consider after drug failures.</td>
                            </tr>
                        </table>

                        <p><strong>Non-Pharmacologic Prevention:</strong> Sleep hygiene (consistent sleep schedule), stress management, biofeedback, regular aerobic exercise (30 mins 3-5x/week), trigger avoidance (food triggers: aged cheeses, processed meats, nitrites; hormone fluctuation in women; environmental triggers). Riboflavin 400 mg daily and magnesium 400-500 mg daily have modest evidence.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Medication Overuse Headache & Cluster Headache</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Medication Overuse Headache (MOH):</strong> Defined as headache occurring ≥15 days/month resulting from regular overuse of acute medication for ≥3 months. Risk drugs: triptans/ergots (≥10 days/month), analgesics/NSAIDs/acetaminophen (≥15 days/month), opioids/combination meds (≥10 days/month). Paradoxically, medication meant to relieve headache perpetuates chronic daily headache. Management: abrupt (or gradual) discontinuation of overused agent + migraine prevention. Withdrawal headaches expected first 1-2 weeks; reassurance and bridge therapy (NSAIDs, triptans prescribed sparingly) helps. Success rate 50-70% after medication cessation.</p>

                        <p><strong>Cluster Headache:</strong> Male-predominant (3-4:1), unilateral orbital/periorbital pain, severe (9-10/10), 15-180 minute duration, multiple attacks per day. Autonomic features: ipsilateral lacrimation, nasal congestion, conjunctival injection, ptosis/miosis (Horner's). Periods of remission and clusters (hence "cluster"). <em>Acute Treatment:</em> 100% oxygen 12-15 L/min for 15 minutes (rapid relief) + sumatriptan 6 mg SC (first-line). <em>Preventive:</em> Verapamil 240-480 mg/day (first-line, though evidence limited), topiramate, lithium (for chronic cluster), melatonin, occipital nerve blockade.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Secondary Headaches: Giant Cell Arteritis, Idiopathic Intracranial Hypertension, Others</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Condition</th>
                                <th>Clinical Features</th>
                                <th>Diagnosis</th>
                                <th>Urgent Management</th>
                            </tr>
                            <tr>
                                <td><strong>Giant Cell Arteritis (GCA)</strong></td>
                                <td>Age >50, new-onset temporal/occipital headache, scalp tenderness, jaw claudication, vision loss risk (arteritic anterior ischemic optic neuropathy—AAION), elevated ESR/CRP</td>
                                <td>Temporal artery biopsy (gold standard); elevated inflammatory markers</td>
                                <td>URGENT: High-dose corticosteroids (prednisone 1 mg/kg/day or IV methylprednisolone if vision loss) to prevent irreversible blindness. Do NOT wait for biopsy to start treatment if high suspicion.</td>
                            </tr>
                            <tr>
                                <td><strong>Idiopathic Intracranial Hypertension (IIH)</strong></td>
                                <td>Young women (18-45 yrs), obesity, progressive headache, visual obscurations, papilledema, sixth CN palsy possible</td>
                                <td>MRI brain (normal) + lumbar puncture (elevated ICP, normal CSF analysis)</td>
                                <td>Acetazolamide 500 mg BID-QID (carbonic anhydrase inhibitor reduces CSF production); weight loss critical. Topiramate alternative. Vision-threatening papilledema: consider optic nerve sheath fenestration or lumboperitoneal shunt.</td>
                            </tr>
                            <tr>
                                <td><strong>Spontaneous Intracranial Hypotension (SIH)</strong></td>
                                <td>Positional headache (worsens upright, improves supine), neck stiffness, auditory symptoms (tinnitus), visual disturbance. History of spinal procedures or Ehlers-Danlos syndrome</td>
                                <td>MRI brain shows sagging brainstem, subdural hematoma possible; MR myelography shows CSF leak site</td>
                                <td>Bed rest, hydration, caffeine (increases CSF production), epidural blood patch (gold standard treatment, 50-90% response), abdominal binder</td>
                            </tr>
                            <tr>
                                <td><strong>Reversible Cerebral Vasoconstriction Syndrome (RCVS)</strong></td>
                                <td>Thunderclap headaches (recurrent, 1-3 weeks), preceded by eclampsia, use of vasoactive drugs (decongestants, stimulants, cocaine), or spontaneous. Risk of stroke from vasospasm</td>
                                <td>MR/CT angiography shows segmental vasoconstriction pattern; dramatic improvement over 1-3 months</td>
                                <td>Calcium channel blockers (verapamil, nimodipine) for vasospasm prevention. Avoid vasoconstrictors. Usually self-limited but ischemic/hemorrhagic complications possible.</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Practice Question 4 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q4: A 32-year-old woman with obesity presents with subacute progressive morning headache, visual obscurations, and mild blurred vision. Fundoscopy shows bilateral papilledema. MRI brain is normal. Lumbar puncture shows opening pressure of 32 cm H2O (normal <25), with normal glucose, protein, and cell counts. What is the next step in management?</div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="a"> A) Immediate IV mannitol and ICU admission for intracranial hypertension crisis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="b"> B) Start acetazolamide 500 mg BID, recommend weight loss, repeat imaging in 4 weeks
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="c"> C) MR venography to exclude cerebral venous sinus thrombosis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="d"> D) High-dose corticosteroids and temporal artery biopsy
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q4')">Show Answer</button>
                        <div id="q4-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation, demographics (young woman with obesity), imaging (normal MRI), and LP findings (elevated ICP, normal CSF analysis) are diagnostic for Idiopathic Intracranial Hypertension (IIH). This is not an acute neurosurgical emergency requiring ICU care unless there is vision-threatening papilledema with visual field loss. First-line management: acetazolamide to reduce CSF production, weight loss (most important modifiable factor), and monitoring for visual complications. Option A (mannitol) is reserved for acute elevated ICP with neurologic deterioration. Option C is unnecessary given normal MRI. Option D is incorrect (GCA criteria not met: wrong age, no systemic symptoms).</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> ICHD-3. <em>Cephalalgia</em>. 2018;38:1-211. Headache Classification Committee of IHS.</li>
                        <li><span class="ref-guideline">[G2]</span> AHS Consensus Statement: Integrating New Migraine Treatments. <em>Headache</em>. 2021;61:1021-1039.</li>
                        <li><span class="ref-guideline">[G3]</span> EHF Guideline: CGRP mAbs for Migraine Prevention. <em>J Headache Pain</em>. 2022;23:67.</li>
                        <li><span class="ref-trial">[T]</span> <strong>IIHTT:</strong> Wall M et al. <em>JAMA</em> 2014;311:1641-51. Acetazolamide + weight management in IIH.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PROMISE-1 (Erenumab):</strong> Goadsby PJ et al. <em>NEJM</em> 2017;377:2123-32. Erenumab reduced migraine days by 3.2-3.7.</li>
                        <li><span class="ref-trial">[T]</span> <strong>STRIVE (Erenumab):</strong> Dodick DW et al. <em>NEJM</em> 2018;378:2346-56. 50% responder rate 43-50%.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREEMPT 1&2 (OnabotulinumtoxinA):</strong> Aurora SK et al. <em>Headache</em> 2010;50:921-36. For chronic migraine.</li>
                        <li><span class="ref-trial">[T]</span> <strong>GiACTA (Tocilizumab for GCA):</strong> Stone JH et al. <em>NEJM</em> 2017;377:317-28. 56% sustained remission.</li>
                        <li>[R] Silberstein SD et al. Guideline: pharmacologic treatment for episodic migraine prevention. <em>Neurology</em>. 2012;78:1337-45.</li>
                        <li>[R] May A et al. Cluster headache. <em>Nat Rev Dis Primers</em>. 2018;4:18006.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 8: CNS Infections -->
            <section id="section-8" class="section">
                <h1 class="section-title">8. CNS Infections</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Bacterial Meningitis: Etiology by Age & Empiric Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Age Group</th>
                                <th>Most Common Organisms</th>
                                <th>Empiric Antibiotics</th>
                            </tr>
                            <tr>
                                <td><strong>Neonates (0-30 days)</strong></td>
                                <td>Group B Strep, E. coli K1, Listeria monocytogenes</td>
                                <td>Ampicillin 2g Q4H + ceftazidime 2g Q8H (or gentamicin)</td>
                            </tr>
                            <tr>
                                <td><strong>Infants/Children (1 mo-18 yrs)</strong></td>
                                <td>Streptococcus pneumoniae, Neisseria meningitidis, H. influenzae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Adults (18-50 yrs)</strong></td>
                                <td>N. meningitidis, S. pneumoniae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Older Adults (>50 yrs)</strong></td>
                                <td>S. pneumoniae, Listeria, Gram-negative rods</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin + ampicillin 2g Q4H</td>
                            </tr>
                            <tr>
                                <td><strong>Immunocompromised</strong></td>
                                <td>Listeria, Gram-negative rods, Cryptococcus, Mycobacterium</td>
                                <td>Add ampicillin to coverage; consider TMP-SMX for Listeria alternative</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Critical Management: Dexamethasone Timing</div>
                            <p>Dexamethasone 10 mg IV must be given <strong>BEFORE OR WITH first antibiotic dose</strong> to reduce neurologic complications (especially in pneumococcal meningitis). Give Q6H x 4 days. If given after antibiotics, efficacy diminished. Improves outcomes in ~30% of cases.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>CSF Analysis: Bacterial vs Viral vs TB vs Fungal</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Parameter</th>
                                <th>Bacterial</th>
                                <th>Viral</th>
                                <th>TB</th>
                                <th>Fungal</th>
                            </tr>
                            <tr>
                                <td><strong>Appearance</strong></td>
                                <td>Turbid/purulent</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                            </tr>
                            <tr>
                                <td><strong>Pressure</strong></td>
                                <td>Usually elevated (>400 mm H2O)</td>
                                <td>Normal-mildly elevated</td>
                                <td>Mildly-moderately elevated</td>
                                <td>Often elevated (100-500+)</td>
                            </tr>
                            <tr>
                                <td><strong>WBC (cells/µL)</strong></td>
                                <td>500-20,000+ (PMN predominant)</td>
                                <td>10-500 (lymph predominant early, then lymph)</td>
                                <td>100-500 (lymph predominant)</td>
                                <td>50-500 (lymph predominant)</td>
                            </tr>
                            <tr>
                                <td><strong>Protein</strong></td>
                                <td>>100 mg/dL (often 200-500)</td>
                                <td>Normal-mildly elevated (50-100)</td>
                                <td>100-500+ (often high)</td>
                                <td>100-500+ (often high)</td>
                            </tr>
                            <tr>
                                <td><strong>Glucose (CSF:serum ratio)</strong></td>
                                <td><40 mg/dL or <40% of serum</td>
                                <td>Normal (50-80% of serum)</td>
                                <td><40 mg/dL or <40% (low ratio key)</td>
                                <td>Low-normal (variable)</td>
                            </tr>
                            <tr>
                                <td><strong>Gram Stain</strong></td>
                                <td>Positive 60-90%</td>
                                <td>Negative</td>
                                <td>Negative (AFB for TB)</td>
                                <td>Negative (India ink for Cryptococcus)</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The combination of <strong>low CSF glucose + high protein + lymphocytic predominance</strong> is classic for TB meningitis. Delayed diagnosis is common; maintain high suspicion in at-risk patients (immunocompromised, endemic areas). Start anti-TB therapy empirically if TB meningitis suspected, even before confirmatory test results.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>HSV Encephalitis & Autoimmune Encephalitis</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Herpes Simplex Virus (HSV) Encephalitis:</strong> Most common cause of sporadic viral encephalitis. Presents with fever, altered consciousness, behavioral changes, seizures, focal neurologic signs (temporal lobe involvement common). CSF: lymphocytic pleocytosis, elevated protein, normal glucose (variable). <em>MRI:</em> T2/FLAIR hyperintensity in temporal lobes, orbitofrontal, insular regions. <em>EEG:</em> Periodic sharp wave complexes in temporal regions (PLEDS—periodic lateralizing epileptiform discharges). <em>Treatment:</em> <strong>Start acyclovir 10-15 mg/kg IV Q8H immediately upon suspicion (do NOT wait for LP or EEG)</strong>. Continue 10-14 days. PCR of CSF for HSV is gold standard (90%+ sensitivity), but treatment must start empirically. Early treatment crucial for prognosis; delays lead to permanent sequelae (cognitive impairment, seizures, personality change).</p>

                        <p><strong>Autoimmune Encephalitis (NMDAR-IgG, AMPAR-IgG, GABA-B-IgG, etc.):</strong> Increasingly recognized, especially in young patients with behavioral changes, psychosis, seizures, movement disorders. CSF shows lymphocytic pleocytosis, elevated protein. Brain MRI often normal or shows nonspecific changes. <em>Diagnosis:</em> CSF/serum antibody testing (NMDAR most common; can be seronegative 10-20%). <em>Treatment:</em> Immunotherapy is cornerstone: IVIG 2 g/kg over 3-5 days, plasma exchange, or both. Corticosteroids (methylprednisolone 1g daily x 3-5 days, then taper). Second-line: rituximab, cyclophosphamide for severe/refractory cases. Screen for underlying malignancy (ovarian teratomas in NMDAR encephalitis, lung cancer in others).</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>TB Meningitis & Cryptococcal Meningitis in HIV</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>TB Meningitis:</strong> Diagnosis: acid-fast bacilli (AFB) stain of CSF (low sensitivity ~10%), TB culture (gold standard but takes 2-6 weeks), TB PCR/GeneXpert MTB/RIF (higher sensitivity, faster). CSF shows low glucose + high protein. <em>Treatment:</em> 12-month regimen: (1) Intensive phase (2 months): isoniazid, rifampin, pyrazinamide, ethambutol, plus streptomycin. (2) Continuation phase (10 months): isoniazid + rifampin. <strong>Corticosteroids essential:</strong> Dexamethasone 0.3-0.4 mg/kg Q6H x 3 weeks, then taper. Dramatically improves outcomes. Adjunctive vitamin B6 (pyridoxine) for isoniazid neuropathy prevention.</p>

                        <p><strong>Cryptococcal Meningitis (CrAg-positive HIV/AIDS):</strong> <em>Diagnosis:</em> Serum/CSF CrAg antigen testing (>95% sensitive in CSF), India ink stain (40-50% sensitive), fungal culture. <em>Treatment (dual phases):</em></p>
                        <ul class="list-item">
                            <li><strong>Induction phase (2 weeks):</strong> Amphotericin B 0.7-1 mg/kg IV daily + flucytosine 25 mg/kg Q6H (if available/tolerated)</li>
                            <li><strong>Consolidation phase (8 weeks):</strong> Fluconazole 400 mg daily</li>
                            <li><strong>Maintenance phase:</strong> Fluconazole 200 mg daily indefinitely (until CD4 >100-200 for ≥3 months on ART)</li>
                        </ul>
                        <p><em>Adjunctive management:</em> CSF drainage/shunt if severe elevated ICP or symptomatic hydrocephalus. Avoid excessive fluid resuscitation (increases ICP). Corticosteroids controversial; may be considered if severe inflammation.</p>
                    </div>
                </div>

                <!-- Practice Question 5 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q5: A 24-year-old woman with AIDS (CD4 28 cells/µL) presents with subacute headache, fever, and neck stiffness. LP shows CSF: 80 WBC (predominantly lymphocytes), protein 110 mg/dL, glucose 42 mg/dL (serum 92). Serum CrAg is positive. CSF India ink stain is negative. What is the most important initial management step?</div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="a"> A) Start fluconazole 400 mg PO daily pending cultures; recheck LP in 1 week
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="b"> B) Start IV amphotericin B 0.7-1 mg/kg daily + flucytosine 25 mg/kg Q6H for induction therapy; manage ICP with CSF drainage if needed
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="c"> C) Start ceftriaxone + vancomycin empirically; obtain repeat cultures to confirm organism
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="d"> D) Initiate TB treatment immediately; TB meningitis most likely given low CSF glucose
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q5')">Show Answer</button>
                        <div id="q5-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The positive serum CrAg in an AIDS patient with meningitis is diagnostic for cryptococcal meningitis. Although CSF India ink is negative, the CrAg and clinical presentation confirm the diagnosis. Induction therapy with IV amphotericin B + flucytosine is the standard of care and offers superior outcomes compared to fluconazole monotherapy. ICP management is critical in cryptococcal meningitis due to high opening pressures; CSF drainage via LP or EVD may be necessary. Option A (fluconazole monotherapy) is suboptimal for induction. Options C and D are incorrect diagnoses given the positive CrAg.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> IDSA Practice Guidelines for Bacterial Meningitis. Tunkel AR et al. <em>Clin Infect Dis</em>. 2004;39:1267-84. Updated 2017.</li>
                        <li><span class="ref-guideline">[G2]</span> IDSA Guidelines for Cryptococcal Disease. Perfect JR et al. <em>Clin Infect Dis</em>. 2010;50:291-322.</li>
                        <li><span class="ref-guideline">[G3]</span> WHO Guidelines: Cryptococcal Disease in HIV-infected Adults. 2018.</li>
                        <li><span class="ref-trial">[T]</span> <strong>de Gans Trial:</strong> de Gans J, van de Beek D. <em>NEJM</em> 2002;347:1549-56. Dexamethasone reduced mortality in <em>S. pneumoniae</em> meningitis (7% vs 15%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>Thwaites Trial:</strong> Thwaites GE et al. <em>NEJM</em> 2004;351:1741-51. Dexamethasone in TBM reduced mortality (32% vs 41%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>AMBITION:</strong> Jarvis JN et al. <em>NEJM</em> 2022;386:1109-20. Single high-dose liposomal amphotericin B simplified cryptococcal treatment.</li>
                        <li>[R] van de Beek D et al. Community-acquired bacterial meningitis. <em>Nat Rev Dis Primers</em>. 2016;2:16074.</li>
                        <li>[R] Dalmau J et al. Anti-NMDA-receptor encephalitis. <em>Lancet Neurol</em>. 2008;7:1091-98.</li>
                        <li>[R] Thwaites GE et al. Tuberculous meningitis. <em>Nat Rev Neurol</em>. 2013;9:33-43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 9: Demyelinating Diseases -->
            <section id="section-9" class="section">
                <h1 class="section-title">9. Demyelinating Diseases</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Multiple Sclerosis: Subtypes & Diagnostic Criteria</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>MS Subtype</th>
                                <th>Course & Features</th>
                                <th>Frequency at Onset</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Relapsing-Remitting (RRMS)</strong></td>
                                <td>Distinct relapses with periods of remission/recovery. New or enlarging lesions on MRI between clinical events.</td>
                                <td>85% of MS presentations</td>
                                <td>~50% convert to SPMS by 10 years; highly variable</td>
                            </tr>
                            <tr>
                                <td><strong>Secondary Progressive (SPMS)</strong></td>
                                <td>Initial RRMS course followed by progressive worsening with or without superimposed relapses; declining remission quality</td>
                                <td>N/A (develops from RRMS)</td>
                                <td>Progressive disability; early/frequent relapses predict earlier conversion to SP</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive (PPMS)</strong></td>
                                <td>Progressive disability from onset without distinct relapses; slow, relentless accumulation of impairment</td>
                                <td>10-15% at onset</td>
                                <td>Worse prognosis; fewer effective DMT options historically; newer agents showing benefit</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive-Relapsing (PRMS)</strong></td>
                                <td>Progressive from onset with superimposed relapses and inter-relapse progression</td>
                                <td>5% at onset</td>
                                <td>Aggressive course; rare in modern series with early DMT initiation</td>
                            </tr>
                        </table>

                        <p><strong>McDonald 2017 Criteria for MS Diagnosis:</strong> Requires dissemination in space (DIS) and time (DIT).</p>
                        <ul class="list-item">
                            <li><strong>DIS:</strong> ≥1 lesion in ≥2 CNS regions (periventricular, juxtacortical, infratentorial, spinal cord) on MRI</li>
                            <li><strong>DIT:</strong> Simultaneous presence of gadolinium-enhancing and non-enhancing lesions on brain MRI, OR new lesions on follow-up MRI (≥30 days from initial scan), OR CSF-specific oligoclonal bands + abnormal VEP</li>
                            <li><strong>Clinical events required:</strong> Can satisfy DIT with single clinical event if above imaging criteria met; two relapses + objective evidence suffices for diagnosis</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ MS Presentations: Common Clinical Syndromes</div>
                            <ul class="list-item">
                                <li><strong>Optic Neuritis (ON):</strong> Unilateral vision loss, pain with eye movement, relative afferent pupillary defect (RAPD), normal appearing disc acutely or swollen. MRI shows T2 hyperintensity in optic nerve; brain MRI identifies clinically silent lesions (predicts future MS risk).</li>
                                <li><strong>Transverse Myelitis (TM):</strong> Bilateral motor/sensory deficits and sphincter dysfunction with clear spinal cord level. MRI shows T2 hyperintensity in cord; affects multiple segments (>2-3 vertebral levels).</li>
                                <li><strong>Internuclear Ophthalmoplegia (INO):</strong> Impaired adduction ipsilateral to lesion (medial longitudinal fasciculus—MLF), with preserved convergence. Bilateral INO in young patients is highly suggestive of MS.</li>
                                <li><strong>Lhermitte sign:</strong> Electric shock-like sensation down spine with neck flexion; indicates cervical demyelination.</li>
                                <li><strong>Uhthoff phenomenon:</strong> Transient worsening of symptoms with heat/exercise; due to impaired conduction in demyelinated axons.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Disease-Modifying Therapies (DMTs) for MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>DMT Category</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy & Use</th>
                                <th>Key Monitoring/SE</th>
                            </tr>
                            <tr>
                                <td><strong>Injectable (First-Line)</strong></td>
                                <td>Interferon-beta (IFN-β-1a, IFN-β-1b), glatiramer acetate</td>
                                <td>Immune modulation; unclear exact mechanism</td>
                                <td>Moderate efficacy; reduce relapses ~30%. Well-tolerated, established safety. First-line option especially in early/mild RRMS.</td>
                                <td>IFN: flu-like symptoms, depression risk (screen). GA: local injection reactions. Monthly monitoring labs initially.</td>
                            </tr>
                            <tr>
                                <td><strong>Oral Moderate (1st-2nd Line)</strong></td>
                                <td>Fingolimod, teriflunomide, dimethyl fumarate</td>
                                <td>S1P modulators, DHFR inhibitors, NRF2 activators</td>
                                <td>Moderate-high efficacy (20-50% relapse reduction vs placebo). Convenient oral dosing. Used in RRMS, early aggressive disease.</td>
                                <td>Fingolimod: heart rate monitoring (first dose), opportunistic infection risk (VZV, CMV, PML rare). Teriflunomide: hepatotoxicity, teratogen. DMF: flushing, GI upset, PML risk (rare, esp. if immunosuppressed).</td>
                            </tr>
                            <tr>
                                <td><strong>Oral High-Efficacy</strong></td>
                                <td>Cladribine (Mavenclad), siponimod</td>
                                <td>Lymphocyte depletion, S1P modulation</td>
                                <td>High efficacy (~60% relapse reduction). Used in aggressive RRMS, early conversion-risk disease. Siponimod effective in SPMS.</td>
                                <td>Cladribine: teratogenic, myelosuppression, infection risk, requires monitoring. Siponimod: similar to fingolimod (first-dose monitoring, infection risk).</td>
                            </tr>
                            <tr>
                                <td><strong>IV Infusion (High-Efficacy)</strong></td>
                                <td>Natalizumab (Tysabri), ocrelizumab (Ocrevus), alemtuzumab (Lemtrada)</td>
                                <td>VLA-4 antagonist, anti-CD20 B-cell depletion, anti-CD52 T-cell depletion</td>
                                <td><strong>Natalizumab:</strong> ~90% relapse reduction; used for aggressive RRMS or after DMT failure. <strong>Ocrelizumab:</strong> ~50-60% reduction, also effective in PPMS (unique). <strong>Alemtuzumab:</strong> ~70% reduction; intense induction, long remission potential.</td>
                                <td>Natalizumab: PML risk (especially JC virus+, on therapy >2 yrs; ~4 per 1000 JCV+). Ocrelizumab: infection risk, infusion reactions. Alemtuzumab: severe autoimmunity risk (thyroid, ITP, AIHA), requires monitoring Q3mo.</td>
                            </tr>
                            <tr>
                                <td><strong>Immune Reconstitution (Hematopoietic Stem Cell Transplantation—HSCT)</strong></td>
                                <td>Autologous HSCT</td>
                                <td>Myeloablation + stem cell rescue; resets immune system</td>
                                <td>Dramatic effect in highly aggressive RRMS/early SPMS; sustained remission in ~40-60%. High risk/high reward; reserved for aggressive disease.</td>
                                <td>Treatment toxicity (infections, secondary malignancy risk), mortality 1-3%. Requires extensive workup, intense supportive care.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> Modern MS treatment paradigm emphasizes early, aggressive therapy ("hit early, hit hard") in RRMS to prevent disability accumulation. High-efficacy agents increasingly used upfront in aggressive disease, shifting away from step-wise approach. Monitoring for DMT-specific complications (especially PML with natalizumab, autoimmunity with alemtuzumab) is essential.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Neuromyelitis Optica Spectrum Disorder (NMOSD) vs MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>MS</th>
                                <th>NMOSD</th>
                            </tr>
                            <tr>
                                <td><strong>Demographics</strong></td>
                                <td>Caucasian, age 20-40</td>
                                <td>Female-predominant, non-Caucasian (African, Asian), older age at onset</td>
                            </tr>
                            <tr>
                                <td><strong>Clinical Attacks</strong></td>
                                <td>Varied locations (ON, spinal, brainstem, multifocal)</td>
                                <td>Bilateral optic neuritis (ON) and longitudinally extensive transverse myelitis (LETM) are hallmark; area postrema syndrome (hiccups, vomiting) characteristic</td>
                            </tr>
                            <tr>
                                <td><strong>MRI Spine</strong></td>
                                <td>Short lesions (≤2 vertebral segments)</td>
                                <td>Longitudinally extensive lesions (≥3 vertebral segments, often spanning entire cord)</td>
                            </tr>
                            <tr>
                                <td><strong>Brain MRI</strong></td>
                                <td>Multiple white matter lesions, often periventricular</td>
                                <td>Often normal or minimal; brainstem/diencephalic lesions if present</td>
                            </tr>
                            <tr>
                                <td><strong>CSF</strong></td>
                                <td>Oligoclonal bands (OCBs) common</td>
                                <td>OCBs rare; pleocytosis may be higher (>50 WBC common in attacks)</td>
                            </tr>
                            <tr>
                                <td><strong>Aquaporin-4 (AQP4-IgG)</strong></td>
                                <td>Negative</td>
                                <td>Positive in ~80% (AQP4-IgG seropositive NMOSD); seronegative NMOSD exists (~20%, usually MOG-antibody associated)</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>DMTs (IFN, fingolimod, natalizumab, etc.)</td>
                                <td>Avoid IFN (may worsen); immunosuppression key (azathioprine, mycophenolate, rituximab, complement inhibitor eculizumab for AQP4-IgG+). Acute attacks: high-dose IV corticosteroids + PLEX.</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis</strong></td>
                                <td>Variable; slow disability accumulation</td>
                                <td>Generally worse; permanent visual loss, paraparesis common after attacks; however, newer targeted therapies improving outcomes</td>
                            </tr>
                        </table>

                        <p><strong>Area Postrema Syndrome (APS) in NMOSD:</strong> Intractable hiccups, nausea, vomiting from lesions in brainstem area postrema. Highly specific for NMOSD (rarely seen in MS). Often precedes more widespread neurologic symptoms by days/weeks. Warrant urgent neuroimaging and AQP4-IgG testing.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ NMOSD Diagnostic Criteria (2015 Revised)</div>
                            <p>Presence of AQP4-IgG (seropositive form) + at least 1 core clinical characteristic (ON, LETM, area postrema syndrome, acute brainstem syndrome, symptomatic narcolepsy, symptomatic acute diencephalic/optic pathway syndrome). OR seronegative: ≥2 core characteristics in different attacks + brain MRI normal + spinal cord MRI with ≥3 contiguous segments of T2 signal abnormality + CSF pleocytosis (recommended).</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 6 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q6: A 28-year-old woman presents with acute bilateral vision loss and MRI shows bilateral optic nerve T2 hyperintensity. Spine MRI reveals an 8-cm longitudinally extensive T2 signal abnormality spanning C1-T5 with central canal involvement. Serum and CSF AQP4-IgG testing is positive. What is the most important management distinction from MS?</div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="a"> A) Start interferon-beta as first-line DMT, as it is highly effective in NMOSD
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="b"> B) AVOID interferon-beta; use intensive immunosuppression (mycophenolate, azathioprine) or complement inhibitor (eculizumab) for long-term prevention. For acute attack: high-dose IV corticosteroids + plasma exchange.
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="c"> C) Prognosis is identical to MS; start standard MS DMT and monitor closely
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="d"> D) No treatment needed; bilateral ON and LETM are self-limited complications
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q6')">Show Answer</button>
                        <div id="q6-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation (bilateral ON + LETM) combined with positive AQP4-IgG is diagnostic for NMOSD. A critical distinction from MS is that interferon-beta and some other MS DMTs are contraindicated and may worsen NMOSD. Instead, intensive immunosuppression or complement inhibition is the cornerstone of therapy. Acute attacks require aggressive treatment (high-dose IV steroids, plasma exchange) to minimize permanent disability. The longitudinally extensive spinal cord lesion (8 cm, >3 segments) is characteristic of NMOSD, not typical MS. Prognosis requires different management to prevent vision loss and paralysis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> 2017 McDonald Criteria for MS. Thompson AJ et al. <em>Lancet Neurol</em>. 2018;17:162-173.</li>
                        <li><span class="ref-guideline">[G2]</span> International Consensus Criteria for NMOSD. Wingerchuk DM et al. <em>Neurology</em>. 2015;85:177-189.</li>
                        <li><span class="ref-guideline">[G3]</span> AAN DMT Guidelines for MS. Rae-Grant A et al. <em>Neurology</em>. 2018;90:777-788.</li>
                        <li><span class="ref-trial">[T]</span> <strong>OPERA I & II (Ocrelizumab):</strong> Hauser SL et al. <em>NEJM</em> 2017;376:221-34. Anti-CD20 vs IFN-beta-1a in RRMS: 46-47% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ORATORIO (Ocrelizumab PPMS):</strong> Montalban X et al. <em>NEJM</em> 2017;376:209-20. Only approved DMT for PPMS.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ASCLEPIOS (Ofatumumab):</strong> Hauser SL et al. <em>NEJM</em> 2020;383:546-57. SC anti-CD20 vs teriflunomide: 51-59% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREVENT (Eculizumab NMOSD):</strong> Pittock SJ et al. <em>NEJM</em> 2019;381:614-25. 94% relapse reduction in AQP4+ NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>N-MOmentum (Inebilizumab):</strong> Cree BAC et al. <em>Lancet</em> 2019;394:1352-63. 73% ARR reduction in NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SAkuraStar (Satralizumab):</strong> Traboulsee A et al. <em>Lancet Neurol</em> 2020;19:402-12. Anti-IL6R in NMOSD.</li>
                        <li>[R] Filippi M et al. Multiple sclerosis. <em>Nat Rev Dis Primers</em>. 2018;4:43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 10: Neuromuscular Disorders -->
            <section id="section-3" class="section">
                <h1 class="section-title">3. Movement Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Parkinson's Disease: Diagnosis & Cardinal Features</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Diagnostic Criteria (UK Parkinson's Disease Society):</strong> Bradykinesia PLUS at least one of: resting tremor OR rigidity. Supportive features include asymmetric onset, excellent response to levodopa, presence of dyskinesias from levodopa.</p>

                        <table>
                            <tr>
                                <th>Cardinal Feature</th>
                                <th>Characteristics</th>
                                <th>Assessment</th>
                            </tr>
                            <tr>
                                <td><strong>Bradykinesia</strong></td>
                                <td>Slow, effortful movement. Loss of normal arm swing, micrographia, hypophonia</td>
                                <td>Tap index/thumb fingers, pronation/supination, timed 10-meter walk</td>
                            </tr>
                            <tr>
                                <td><strong>Resting Tremor</strong></td>
                                <td>4-6 Hz, "pill-rolling" tremor at rest, disappears with action</td>
                                <td>Observe at rest; ask patient to perform mental arithmetic to distract (brings out tremor)</td>
                            </tr>
                            <tr>
                                <td><strong>Rigidity</strong></td>
                                <td>Increased tone throughout range of motion. "Lead pipe" (uniform) or "cogwheel" (ratchety, from superimposed tremor)</td>
                                <td>Passive range of motion testing; ask patient to relax; move joints slowly</td>
                            </tr>
                            <tr>
                                <td><strong>Postural Instability</strong></td>
                                <td>Impaired righting reflexes; falls risk; stooped posture with forward-flexed trunk</td>
                                <td>Pull test (positive if falls back without catching themselves or 1 step back = abnormal)</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Non-Motor Symptoms of PD</div>
                            <p>Often precede motor symptoms by years. Include: depression, anxiety, REM sleep behavior disorder, constipation, hyposmia, cognitive decline, orthostatic hypotension, urinary frequency, sexual dysfunction, pain syndromes. MoCA or MMSE useful for tracking cognitive decline.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>PD Pharmacotherapy</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Drug Class</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy/Uses</th>
                                <th>Side Effects</th>
                            </tr>
                            <tr>
                                <td><strong>Levodopa</strong></td>
                                <td>Carbidopa-levodopa (Sinemet), benserazide-levodopa</td>
                                <td>Precursor to dopamine; crosses BBB (with decarboxylase inhibitor)</td>
                                <td>Most effective agent for motor symptoms; carbidopa blocks peripheral conversion. Start low, titrate slowly. Typical 300-600 mg/day divided TID-QID</td>
                                <td>Motor complications (dyskinesia, wearing-off, on-off phenomena) increase with dose/duration. GI upset, orthostatic hypotension</td>
                            </tr>
                            <tr>
                                <td><strong>Dopamine Agonists</strong></td>
                                <td>Pramipexole, ropinirole, rotigotine patch</td>
                                <td>Direct dopamine D2/D3 receptor agonists</td>
                                <td>Slower progression of dyskinesia vs levodopa monotherapy (LEAP study). Often used in younger patients; less effective than levodopa</td>
                                <td>Hallucinations (esp. in older/cognitively impaired), impulse control disorders (gambling, hypersexuality), somnolence, orthostatic hypotension, leg edema</td>
                            </tr>
                            <tr>
                                <td><strong>MAO-B Inhibitors</strong></td>
                                <td>Selegiline, rasagiline</td>
                                <td>Block monoamine oxidase-B (dopamine catabolism)</td>
                                <td>Modest symptomatic benefit (10-15% better than placebo). Rasagiline may slow progression (delayed start study). Adjunct to levodopa</td>
                                <td>Hypertension (avoid with SSRIs, tramadol due to serotonin syndrome risk), GI upset</td>
                            </tr>
                            <tr>
                                <td><strong>COMT Inhibitors</strong></td>
                                <td>Entacapone, tolcapone</td>
                                <td>Block catechol-O-methyl transferase (dopamine catabolism)</td>
                                <td>Extend levodopa duration by 25-30%; useful in wearing-off; taken with each levodopa dose</td>
                                <td>Diarrhea, orange urine discoloration, increased dyskinesia (from prolonged dopamine levels)</td>
                            </tr>
                            <tr>
                                <td><strong>Anticholinergics</strong></td>
                                <td>Benztropine, trihexyphenidyl</td>
                                <td>Block muscarinic acetylcholine receptors</td>
                                <td>Effective for tremor-dominant PD; less helpful for bradykinesia. Use avoided in older patients (cognitive risk)</td>
                                <td>Cognitive impairment, hallucinations, urinary retention, dry mouth, constipation. Mostly avoided in modern practice</td>
                            </tr>
                            <tr>
                                <td><strong>Amantadine</strong></td>
                                <td>Amantadine (symmetric adamantane)</td>
                                <td>NMDA antagonist, dopamine release enhancer, anticholinergic effects</td>
                                <td>Modest effect on bradykinesia/rigidity; useful for levodopa-induced dyskinesia (FDA approved for this). Doses 100-200 mg BID</td>
                                <td>Livedo reticularis (reversible reticulated rash), orthostatic hypotension, cognitive effects, renal clearance</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl - LEAP Trial Finding:</strong> The LEAP study showed that early dopamine agonist monotherapy delayed dyskinesia onset compared to early levodopa, but motor control was superior with levodopa. This led to individualized treatment: younger patients (especially <60 yrs) often started on dopamine agonists to delay levodopa introduction and dyskinesia onset; older patients or those needing maximal symptom control started on levodopa. <strong>Levodopa does NOT accelerate PD progression</strong> (disproven by modern studies).
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Atypical Parkinsonism: Differential Diagnosis</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Disorder</th>
                                <th>Key Distinguishing Features</th>
                                <th>Pathology</th>
                                <th>Response to Levodopa</th>
                            </tr>
                            <tr>
                                <td><strong>Multiple System Atrophy (MSA)</strong></td>
                                <td><em>MSA-P:</em> Parkinsonian (akinetic-rigid). <em>MSA-C:</em> Cerebellar (ataxia, dysarthria). Autonomic dysfunction (OH, urinary incontinence, erectile dysfunction) prominent. Early gait instability. Hypokinetic dysarthria. "Hot cross bun" sign on MRI (atrophy of pons/cerebellar peduncles)</td>
                                <td>Glial cytoplasmic inclusions (GCI); loss of striatal neurons, Purkinje cells, pontine nuclei</td>
                                <td>Poor; minimal benefit to levodopa (distinguishes from PD)</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive Supranuclear Palsy (PSP)</strong></td>
                                <td>Vertical supranuclear gaze palsy (looking down affected before up). Early falls (postural instability with backward falls). "Hummingbird sign" on MRI (midbrain atrophy). Pseudobulbar palsy. Facial dystonia. Apathy, cognitive decline</td>
                                <td>Neurofibrillary tangles (tau pathology) in midbrain, brainstem, basal ganglia</td>
                                <td>Poor; levodopa unresponsive</td>
                            </tr>
                            <tr>
                                <td><strong>Corticobasal Degeneration (CBD)</strong></td>
                                <td>Asymmetric parkinsonism and dystonia. Limb apraxia. Alien hand syndrome (involuntary movements of one limb). Cortical sensory loss. Myoclonus. "Cortical" tremor (task-specific). Speech apraxia</td>
                                <td>Tau pathology with Pick bodies, astrocytic plaques, achromatic neurons in cortex and substantia nigra</td>
                                <td>Poor; minimal levodopa response</td>
                            </tr>
                            <tr>
                                <td><strong>Dementia with Lewy Bodies (DLB)</strong></td>
                                <td>Cognitive decline prominent and early (before or concurrent with motor symptoms, distinguishing from PD-dementia). Visual hallucinations (detailed, animated). REM sleep behavior disorder. Sensitivity to antipsychotics (can precipitate severe parkinsonism, NMS)</td>
                                <td>Lewy bodies (alpha-synuclein); loss of cholinergic neurons and dopaminergic neurons</td>
                                <td>Variable; levodopa benefit less consistent than PD. Hallucinations often persist</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The presence of <strong>vertical supranuclear gaze palsy</strong> is nearly pathognomonic for PSP. <strong>Early falls</strong> (within first year) and <strong>poor levodopa response</strong> suggest atypical parkinsonism rather than PD. <strong>Autonomic dysfunction as leading feature</strong> suggests MSA.
                        </div>

                        <p><strong>DLB Antipsychotic Warning:</strong> Patients with DLB have severe sensitivity to dopamine-blocking agents. Typical antipsychotics (haloperidol, chlorpromazine) and even some atypical agents (risperidone, olanzapine) can precipitate fulminant parkinsonism, neuroleptic malignant syndrome-like picture, and death. If antipsychotic absolutely necessary, quetiapine or pimavanserin preferred; use lowest dose.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Other Movement Disorders: Essential Tremor, Chorea, Dystonia</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Essential Tremor (ET):</strong> Most common movement disorder. Kinetic (action) tremor 4-12 Hz, affects hands (asymmetric common), head, voice. Worsened by anxiety, caffeine, fatigue; improved by alcohol. Treatment: propranolol (first-line, 20-160 mg/day), primidone, topiramate. Botulinum toxin for head/voice tremor. Deep brain stimulation for severe, refractory cases.</p>

                        <p><strong>Huntington's Disease (Chorea):</strong> CAG trinucleotide repeat expansion. Involuntary jerking, writhing movements (choreiform). Cognitive decline, behavioral changes (irritability, apathy, depression), executive dysfunction. Onset typically 40-50 years (juvenile form if <20 yrs, progresses faster). No cure; tetrabenazine or deutetrabenazine (VMAT2 inhibitors) reduce chorea. Antipsychotics (haloperidol, quetiapine) as adjuncts. Genetic counseling and predictive testing available for at-risk relatives.</p>

                        <p><strong>Sydenham's Chorea:</strong> Post-rheumatic fever complication (weeks after group A strep pharyngitis). Self-limited (resolves in 3-6 months typically). Causes involuntary movements, emotional lability, weakness. Treat with NSAIDs, corticosteroids if severe, penicillin for any residual strep infection.</p>

                        <p><strong>Tardive Dyskinesia (TD):</strong> Complication of prolonged antipsychotic use (typical agents higher risk, but atypical also cause). Involuntary orofacial, limb, truncal movements; may persist even after drug discontinuation. Prevention: use lowest antipsychotic dose, atypicals preferred. Treatment: switch to aripiprazole (dopamine partial agonist—paradoxically helps TD), valbenazine or deutetrabenazine (VMAT2 inhibitors), tetrabenazine.</p>

                        <p><strong>Dystonia:</strong> Involuntary sustained muscle contractions causing abnormal postures/repetitive movements. Can be generalized (affects multiple body regions) or focal (one region: blepharospasm, cervical dystonia, writer's cramp). Causes include genetic (DYT1, etc.), secondary (stroke, trauma, drugs, Wilson's disease), idiopathic. Botulinum toxin injections effective for focal dystonia. Oral agents (anticholinergics, benzodiazepines) have variable effect. Deep brain stimulation for generalized, severe cases.</p>
                    </div>
                </div>

                <!-- Practice Question 3 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q3: A 72-year-old male presents with a 2-year history of progressive parkinsonism. Noted for early falls (backward) in the first year despite treatment, vertical gaze restriction particularly downward, and midbrain atrophy on MRI ("hummingbird sign"). He has had minimal response to maximum-tolerated doses of levodopa. Which diagnosis is most consistent?</div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="a"> A) Parkinson's disease with early postural instability
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="b"> B) Progressive Supranuclear Palsy (PSP)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="c"> C) Multiple System Atrophy, Parkinsonian subtype (MSA-P)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q3" value="d"> D) Corticobasal degeneration with asymmetric presentation
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q3')">Show Answer</button>
                        <div id="q3-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical triad strongly favors PSP: (1) vertical supranuclear gaze palsy (restricted downward gaze), (2) early falls (hallmark of PSP, distinguishes from typical PD), and (3) midbrain atrophy ("hummingbird sign" is nearly pathognomonic). The poor levodopa response further distinguishes atypical parkinsonism from PD. MSA-P presents with autonomic dysfunction as a leading feature and shows "hot cross bun" sign, not hummingbird. CBD typically has asymmetric cortical features (apraxia, alien hand) rather than symmetric gaze palsy.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> MDS Clinical Diagnostic Criteria for Parkinson Disease. Postuma RB et al. <em>Mov Disord</em>. 2015;30:1591-1601.</li>
                        <li><span class="ref-guideline">[G2]</span> MDS Criteria for the Diagnosis of PSP. Hoglinger GU et al. <em>Mov Disord</em>. 2017;32:853-864.</li>
                        <li><span class="ref-guideline">[G3]</span> Consensus Criteria for MSA. Gilman S et al. <em>Neurology</em>. 2008;71:670-676. Updated: Wenning GK et al. <em>Mov Disord</em>. 2022.</li>
                        <li><span class="ref-guideline">[G4]</span> Consensus Criteria for CBD. Armstrong MJ et al. <em>Neurology</em>. 2013;80:496-503.</li>
                        <li><span class="ref-guideline">[G5]</span> DLB Fourth Consensus Report. McKeith IG et al. <em>Neurology</em>. 2017;89:88-100.</li>
                        <li><span class="ref-trial">[T]</span> <strong>LEAP:</strong> Verschuur CVM et al. <em>NEJM</em> 2019;380:315-24. Levodopa does NOT accelerate PD. Safe to start when clinically needed.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ELLDOPA:</strong> Fahn S et al. <em>NEJM</em> 2004;351:2498-2508. Higher levodopa doses = better symptom control. No accelerated progression.</li>
                        <li><span class="ref-trial">[T]</span> <strong>EARLYSTIM:</strong> Schuepbach WMM et al. <em>NEJM</em> 2013;368:610-22. DBS (STN) superior to best medical therapy in early motor complications.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ADAGIO:</strong> Olanow CW et al. <em>NEJM</em> 2009;361:1268-78. Rasagiline possible disease-modifying effect (1 mg only).</li>
                        <li>[R] Postuma RB et al. Risk and predictors in idiopathic RBD. <em>Brain</em>. 2019;142:744-759. Phenoconversion >80% at 10-15 years.</li>
                        <li>[R] McColgan P, Tabrizi SJ. Huntington Disease. <em>NEJM</em> 2020;382:1753-64.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 7: Headache Disorders -->
            <section id="section-7" class="section">
                <h1 class="section-title">7. Headache Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Red Flags for Secondary Headache (SNOOP10)</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>SNOOP10 mnemonic for red flags suggesting secondary headache:</strong></p>
                        <ul class="list-item">
                            <li><strong>S</strong> - Systemic illness (fever, weight loss, malaise)</li>
                            <li><strong>N</strong> - Neurologic symptoms or signs (focal deficits, papilledema, altered consciousness)</li>
                            <li><strong>O</strong> - Onset sudden (thunderclap headache suggests SAH, reversible cerebral vasoconstriction, etc.)</li>
                            <li><strong>O</strong> - Older age (>50 years); new-onset headache in this group warrants investigation</li>
                            <li><strong>P</strong> - Papilledema, focal neurologic signs, or progressive worsening</li>
                            <li><strong>1</strong> - Pattern change (headache that has changed character, frequency, severity from baseline)</li>
                            <li><strong>0</strong> - Immunocompromised (HIV, chemotherapy, post-transplant) or on anticoagulation/recent head trauma</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Management Approach</div>
                            <p>Presence of ANY red flag warrants neuroimaging (MRI brain with/without contrast, or stat CT if acute), LP if imaging negative, and specialist evaluation. Primary headache diagnosis (migraine, tension, cluster) requires absence of red flags AND meeting clinical criteria.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine: Diagnostic Criteria (ICHD-3) & Acute Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>ICHD-3 Criteria for Migraine without Aura:</strong> At least 5 attacks with: (1) headache 4-72 hours, (2) at least 2 of: unilateral, pulsating quality, moderate-severe pain, aggravated by physical activity, AND (3) at least 1 of: nausea/vomiting OR photophobia/phonophobia.</p>

                        <p><strong>Migraine with Aura:</strong> Similar criteria but preceded by 5-60 minute aura (visual: scotoma, flashing lights; sensory: paresthesias; speech/language disturbance), fully reversible.</p>

                        <table>
                            <tr>
                                <th>Acute Treatment Class</th>
                                <th>Agent & Dosing</th>
                                <th>Efficacy Notes</th>
                            </tr>
                            <tr>
                                <td><strong>NSAIDs</strong></td>
                                <td>Ibuprofen 400-800 mg, naproxen 500 mg, aspirin 1000 mg PO</td>
                                <td>Effective for mild-moderate migraine. Risk with frequent use (>10-15 days/month): medication overuse headache</td>
                            </tr>
                            <tr>
                                <td><strong>Triptans</strong></td>
                                <td>Sumatriptan 50 mg PO / 20 mg nasal / 6 mg SC (most common). Alternatives: rizatriptan, naratriptan, zolmitriptan, almotriptan</td>
                                <td>Gold standard for moderate-severe migraine. 50-60% 2-hour pain-free rate. Contraindicated in uncontrolled HTN, CAD, prior MI/stroke, Raynaud's. Avoid frequent use (>10 days/month—rebound headache risk).</td>
                            </tr>
                            <tr>
                                <td><strong>Calcitonin Gene-Related Peptide (CGRP) Antagonists (Gepants)</strong></td>
                                <td>Ubrogepant 50-100 mg PO, rimegepant 75 mg PO (can be used preventively Q2 days), lasmiditan (5-HT1F agonist, structurally distinct)</td>
                                <td>Novel class; comparable efficacy to triptans (50-60% 2-hour pain-free). Advantages: no vasoconstrictive effects, safe in CAD/uncontrolled HTN. Drawback: cost. Good option if triptan contraindicated or failed.</td>
                            </tr>
                            <tr>
                                <td><strong>Ditans</strong></td>
                                <td>Lasmiditan 50-200 mg PO (5-HT1F agonist, distinct serotonin pathway)</td>
                                <td>Efficacy similar to triptans. Advantage: no vasoconstriction, safe in coronary disease. Caution: CNS effects (dizziness); avoid driving 8 hrs post-dose. Emerging class.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiemetics</strong></td>
                                <td>Metoclopramide 10 mg IV/IM, prochlorperazine 10 mg IV/IM, ondansetron 8 mg IV</td>
                                <td>Essential adjunct, especially for moderate-severe migraines with nausea. Can be monotherapy for mild cases. Metoclopramide enhances triptan absorption when given with oral triptan.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> <strong>Timing is critical.</strong> Acute migraine treatment is most effective when given early in migraine course (within 1-2 hours of onset). Repeated dosing after 2 hours if pain returns is less effective than initial dose. Triptan + NSAID combination often more effective than monotherapy.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine Prevention: Pharmacologic & Non-Pharmacologic</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Agent Class</th>
                                <th>Specific Drugs & Dosing</th>
                                <th>Efficacy & Notes</th>
                            </tr>
                            <tr>
                                <td><strong>Beta-Blockers</strong></td>
                                <td>Propranolol 40-240 mg/day divided TID, timolol, metoprolol</td>
                                <td>First-line. Reduce migraine frequency by 40-60%. Particularly effective for migraine with aura, migraine with palpitations, or concurrent hypertension. SE: fatigue, erectile dysfunction.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiepileptics</strong></td>
                                <td>Topiramate (Topamax) 50-200 mg/day; valproate 500-1500 mg/day; lamotrigine 100-200 mg/day</td>
                                <td>Topiramate most evidence. 40-50% reduction in migraine frequency. SE: cognitive effects, weight loss (topiramate, valproate), teratogenicity (valproate). Valproate rarely used now due to teratogenic risk.</td>
                            </tr>
                            <tr>
                                <td><strong>Tricyclic Antidepressants</strong></td>
                                <td>Amitriptyline 10-100 mg nightly; nortriptyline alternative</td>
                                <td>Effective, especially if concurrent depression/anxiety. 40-50% frequency reduction. SE: dry mouth, weight gain, sedation, anticholinergic effects. Often combined with other preventives.</td>
                            </tr>
                            <tr>
                                <td><strong>CGRP Monoclonal Antibodies (mAbs)</strong></td>
                                <td>Erenumab (Aimovig) 70-140 mg SC monthly, fremanezumab (Ajovy) 225 mg SC monthly or 675 mg quarterly, galcanezumab (Emgality) 240 mg SC loading, then 120 mg monthly, eptinezumab (Vyepti) IV quarterly</td>
                                <td>Highly effective; 40-50% migraine day reduction. Safe, well-tolerated. No serious black-box warnings. Monthly or quarterly dosing improves compliance. Cost/insurance barriers remain. Indication: ≥4 migraine days/month.</td>
                            </tr>
                            <tr>
                                <td><strong>Botulinum Toxin (Botox)</strong></td>
                                <td>Injections 155 units total (across forehead, temples, occiput, neck) Q12 weeks</td>
                                <td>FDA-approved for chronic migraine (≥15 days/month). ~45% responders with ≥50% reduction. Mechanism unclear but effective. Requires repeat injections every 12 weeks.</td>
                            </tr>
                            <tr>
                                <td><strong>Neuromodulation</strong></td>
                                <td>Occipital nerve stimulation (ONS), supraorbital nerve stimulation (SONS), vagus nerve stimulation (VNS)</td>
                                <td>Emerging options for refractory chronic migraine. Implantable devices; mixed evidence but growing support. Consider after drug failures.</td>
                            </tr>
                        </table>

                        <p><strong>Non-Pharmacologic Prevention:</strong> Sleep hygiene (consistent sleep schedule), stress management, biofeedback, regular aerobic exercise (30 mins 3-5x/week), trigger avoidance (food triggers: aged cheeses, processed meats, nitrites; hormone fluctuation in women; environmental triggers). Riboflavin 400 mg daily and magnesium 400-500 mg daily have modest evidence.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Medication Overuse Headache & Cluster Headache</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Medication Overuse Headache (MOH):</strong> Defined as headache occurring ≥15 days/month resulting from regular overuse of acute medication for ≥3 months. Risk drugs: triptans/ergots (≥10 days/month), analgesics/NSAIDs/acetaminophen (≥15 days/month), opioids/combination meds (≥10 days/month). Paradoxically, medication meant to relieve headache perpetuates chronic daily headache. Management: abrupt (or gradual) discontinuation of overused agent + migraine prevention. Withdrawal headaches expected first 1-2 weeks; reassurance and bridge therapy (NSAIDs, triptans prescribed sparingly) helps. Success rate 50-70% after medication cessation.</p>

                        <p><strong>Cluster Headache:</strong> Male-predominant (3-4:1), unilateral orbital/periorbital pain, severe (9-10/10), 15-180 minute duration, multiple attacks per day. Autonomic features: ipsilateral lacrimation, nasal congestion, conjunctival injection, ptosis/miosis (Horner's). Periods of remission and clusters (hence "cluster"). <em>Acute Treatment:</em> 100% oxygen 12-15 L/min for 15 minutes (rapid relief) + sumatriptan 6 mg SC (first-line). <em>Preventive:</em> Verapamil 240-480 mg/day (first-line, though evidence limited), topiramate, lithium (for chronic cluster), melatonin, occipital nerve blockade.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Secondary Headaches: Giant Cell Arteritis, Idiopathic Intracranial Hypertension, Others</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Condition</th>
                                <th>Clinical Features</th>
                                <th>Diagnosis</th>
                                <th>Urgent Management</th>
                            </tr>
                            <tr>
                                <td><strong>Giant Cell Arteritis (GCA)</strong></td>
                                <td>Age >50, new-onset temporal/occipital headache, scalp tenderness, jaw claudication, vision loss risk (arteritic anterior ischemic optic neuropathy—AAION), elevated ESR/CRP</td>
                                <td>Temporal artery biopsy (gold standard); elevated inflammatory markers</td>
                                <td>URGENT: High-dose corticosteroids (prednisone 1 mg/kg/day or IV methylprednisolone if vision loss) to prevent irreversible blindness. Do NOT wait for biopsy to start treatment if high suspicion.</td>
                            </tr>
                            <tr>
                                <td><strong>Idiopathic Intracranial Hypertension (IIH)</strong></td>
                                <td>Young women (18-45 yrs), obesity, progressive headache, visual obscurations, papilledema, sixth CN palsy possible</td>
                                <td>MRI brain (normal) + lumbar puncture (elevated ICP, normal CSF analysis)</td>
                                <td>Acetazolamide 500 mg BID-QID (carbonic anhydrase inhibitor reduces CSF production); weight loss critical. Topiramate alternative. Vision-threatening papilledema: consider optic nerve sheath fenestration or lumboperitoneal shunt.</td>
                            </tr>
                            <tr>
                                <td><strong>Spontaneous Intracranial Hypotension (SIH)</strong></td>
                                <td>Positional headache (worsens upright, improves supine), neck stiffness, auditory symptoms (tinnitus), visual disturbance. History of spinal procedures or Ehlers-Danlos syndrome</td>
                                <td>MRI brain shows sagging brainstem, subdural hematoma possible; MR myelography shows CSF leak site</td>
                                <td>Bed rest, hydration, caffeine (increases CSF production), epidural blood patch (gold standard treatment, 50-90% response), abdominal binder</td>
                            </tr>
                            <tr>
                                <td><strong>Reversible Cerebral Vasoconstriction Syndrome (RCVS)</strong></td>
                                <td>Thunderclap headaches (recurrent, 1-3 weeks), preceded by eclampsia, use of vasoactive drugs (decongestants, stimulants, cocaine), or spontaneous. Risk of stroke from vasospasm</td>
                                <td>MR/CT angiography shows segmental vasoconstriction pattern; dramatic improvement over 1-3 months</td>
                                <td>Calcium channel blockers (verapamil, nimodipine) for vasospasm prevention. Avoid vasoconstrictors. Usually self-limited but ischemic/hemorrhagic complications possible.</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Practice Question 4 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q4: A 32-year-old woman with obesity presents with subacute progressive morning headache, visual obscurations, and mild blurred vision. Fundoscopy shows bilateral papilledema. MRI brain is normal. Lumbar puncture shows opening pressure of 32 cm H2O (normal <25), with normal glucose, protein, and cell counts. What is the next step in management?</div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="a"> A) Immediate IV mannitol and ICU admission for intracranial hypertension crisis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="b"> B) Start acetazolamide 500 mg BID, recommend weight loss, repeat imaging in 4 weeks
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="c"> C) MR venography to exclude cerebral venous sinus thrombosis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="d"> D) High-dose corticosteroids and temporal artery biopsy
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q4')">Show Answer</button>
                        <div id="q4-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation, demographics (young woman with obesity), imaging (normal MRI), and LP findings (elevated ICP, normal CSF analysis) are diagnostic for Idiopathic Intracranial Hypertension (IIH). This is not an acute neurosurgical emergency requiring ICU care unless there is vision-threatening papilledema with visual field loss. First-line management: acetazolamide to reduce CSF production, weight loss (most important modifiable factor), and monitoring for visual complications. Option A (mannitol) is reserved for acute elevated ICP with neurologic deterioration. Option C is unnecessary given normal MRI. Option D is incorrect (GCA criteria not met: wrong age, no systemic symptoms).</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> ICHD-3. <em>Cephalalgia</em>. 2018;38:1-211. Headache Classification Committee of IHS.</li>
                        <li><span class="ref-guideline">[G2]</span> AHS Consensus Statement: Integrating New Migraine Treatments. <em>Headache</em>. 2021;61:1021-1039.</li>
                        <li><span class="ref-guideline">[G3]</span> EHF Guideline: CGRP mAbs for Migraine Prevention. <em>J Headache Pain</em>. 2022;23:67.</li>
                        <li><span class="ref-trial">[T]</span> <strong>IIHTT:</strong> Wall M et al. <em>JAMA</em> 2014;311:1641-51. Acetazolamide + weight management in IIH.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PROMISE-1 (Erenumab):</strong> Goadsby PJ et al. <em>NEJM</em> 2017;377:2123-32. Erenumab reduced migraine days by 3.2-3.7.</li>
                        <li><span class="ref-trial">[T]</span> <strong>STRIVE (Erenumab):</strong> Dodick DW et al. <em>NEJM</em> 2018;378:2346-56. 50% responder rate 43-50%.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREEMPT 1&2 (OnabotulinumtoxinA):</strong> Aurora SK et al. <em>Headache</em> 2010;50:921-36. For chronic migraine.</li>
                        <li><span class="ref-trial">[T]</span> <strong>GiACTA (Tocilizumab for GCA):</strong> Stone JH et al. <em>NEJM</em> 2017;377:317-28. 56% sustained remission.</li>
                        <li>[R] Silberstein SD et al. Guideline: pharmacologic treatment for episodic migraine prevention. <em>Neurology</em>. 2012;78:1337-45.</li>
                        <li>[R] May A et al. Cluster headache. <em>Nat Rev Dis Primers</em>. 2018;4:18006.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 8: CNS Infections -->
            <section id="section-8" class="section">
                <h1 class="section-title">8. CNS Infections</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Bacterial Meningitis: Etiology by Age & Empiric Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Age Group</th>
                                <th>Most Common Organisms</th>
                                <th>Empiric Antibiotics</th>
                            </tr>
                            <tr>
                                <td><strong>Neonates (0-30 days)</strong></td>
                                <td>Group B Strep, E. coli K1, Listeria monocytogenes</td>
                                <td>Ampicillin 2g Q4H + ceftazidime 2g Q8H (or gentamicin)</td>
                            </tr>
                            <tr>
                                <td><strong>Infants/Children (1 mo-18 yrs)</strong></td>
                                <td>Streptococcus pneumoniae, Neisseria meningitidis, H. influenzae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Adults (18-50 yrs)</strong></td>
                                <td>N. meningitidis, S. pneumoniae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Older Adults (>50 yrs)</strong></td>
                                <td>S. pneumoniae, Listeria, Gram-negative rods</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin + ampicillin 2g Q4H</td>
                            </tr>
                            <tr>
                                <td><strong>Immunocompromised</strong></td>
                                <td>Listeria, Gram-negative rods, Cryptococcus, Mycobacterium</td>
                                <td>Add ampicillin to coverage; consider TMP-SMX for Listeria alternative</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Critical Management: Dexamethasone Timing</div>
                            <p>Dexamethasone 10 mg IV must be given <strong>BEFORE OR WITH first antibiotic dose</strong> to reduce neurologic complications (especially in pneumococcal meningitis). Give Q6H x 4 days. If given after antibiotics, efficacy diminished. Improves outcomes in ~30% of cases.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>CSF Analysis: Bacterial vs Viral vs TB vs Fungal</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Parameter</th>
                                <th>Bacterial</th>
                                <th>Viral</th>
                                <th>TB</th>
                                <th>Fungal</th>
                            </tr>
                            <tr>
                                <td><strong>Appearance</strong></td>
                                <td>Turbid/purulent</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                            </tr>
                            <tr>
                                <td><strong>Pressure</strong></td>
                                <td>Usually elevated (>400 mm H2O)</td>
                                <td>Normal-mildly elevated</td>
                                <td>Mildly-moderately elevated</td>
                                <td>Often elevated (100-500+)</td>
                            </tr>
                            <tr>
                                <td><strong>WBC (cells/µL)</strong></td>
                                <td>500-20,000+ (PMN predominant)</td>
                                <td>10-500 (lymph predominant early, then lymph)</td>
                                <td>100-500 (lymph predominant)</td>
                                <td>50-500 (lymph predominant)</td>
                            </tr>
                            <tr>
                                <td><strong>Protein</strong></td>
                                <td>>100 mg/dL (often 200-500)</td>
                                <td>Normal-mildly elevated (50-100)</td>
                                <td>100-500+ (often high)</td>
                                <td>100-500+ (often high)</td>
                            </tr>
                            <tr>
                                <td><strong>Glucose (CSF:serum ratio)</strong></td>
                                <td><40 mg/dL or <40% of serum</td>
                                <td>Normal (50-80% of serum)</td>
                                <td><40 mg/dL or <40% (low ratio key)</td>
                                <td>Low-normal (variable)</td>
                            </tr>
                            <tr>
                                <td><strong>Gram Stain</strong></td>
                                <td>Positive 60-90%</td>
                                <td>Negative</td>
                                <td>Negative (AFB for TB)</td>
                                <td>Negative (India ink for Cryptococcus)</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The combination of <strong>low CSF glucose + high protein + lymphocytic predominance</strong> is classic for TB meningitis. Delayed diagnosis is common; maintain high suspicion in at-risk patients (immunocompromised, endemic areas). Start anti-TB therapy empirically if TB meningitis suspected, even before confirmatory test results.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>HSV Encephalitis & Autoimmune Encephalitis</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Herpes Simplex Virus (HSV) Encephalitis:</strong> Most common cause of sporadic viral encephalitis. Presents with fever, altered consciousness, behavioral changes, seizures, focal neurologic signs (temporal lobe involvement common). CSF: lymphocytic pleocytosis, elevated protein, normal glucose (variable). <em>MRI:</em> T2/FLAIR hyperintensity in temporal lobes, orbitofrontal, insular regions. <em>EEG:</em> Periodic sharp wave complexes in temporal regions (PLEDS—periodic lateralizing epileptiform discharges). <em>Treatment:</em> <strong>Start acyclovir 10-15 mg/kg IV Q8H immediately upon suspicion (do NOT wait for LP or EEG)</strong>. Continue 10-14 days. PCR of CSF for HSV is gold standard (90%+ sensitivity), but treatment must start empirically. Early treatment crucial for prognosis; delays lead to permanent sequelae (cognitive impairment, seizures, personality change).</p>

                        <p><strong>Autoimmune Encephalitis (NMDAR-IgG, AMPAR-IgG, GABA-B-IgG, etc.):</strong> Increasingly recognized, especially in young patients with behavioral changes, psychosis, seizures, movement disorders. CSF shows lymphocytic pleocytosis, elevated protein. Brain MRI often normal or shows nonspecific changes. <em>Diagnosis:</em> CSF/serum antibody testing (NMDAR most common; can be seronegative 10-20%). <em>Treatment:</em> Immunotherapy is cornerstone: IVIG 2 g/kg over 3-5 days, plasma exchange, or both. Corticosteroids (methylprednisolone 1g daily x 3-5 days, then taper). Second-line: rituximab, cyclophosphamide for severe/refractory cases. Screen for underlying malignancy (ovarian teratomas in NMDAR encephalitis, lung cancer in others).</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>TB Meningitis & Cryptococcal Meningitis in HIV</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>TB Meningitis:</strong> Diagnosis: acid-fast bacilli (AFB) stain of CSF (low sensitivity ~10%), TB culture (gold standard but takes 2-6 weeks), TB PCR/GeneXpert MTB/RIF (higher sensitivity, faster). CSF shows low glucose + high protein. <em>Treatment:</em> 12-month regimen: (1) Intensive phase (2 months): isoniazid, rifampin, pyrazinamide, ethambutol, plus streptomycin. (2) Continuation phase (10 months): isoniazid + rifampin. <strong>Corticosteroids essential:</strong> Dexamethasone 0.3-0.4 mg/kg Q6H x 3 weeks, then taper. Dramatically improves outcomes. Adjunctive vitamin B6 (pyridoxine) for isoniazid neuropathy prevention.</p>

                        <p><strong>Cryptococcal Meningitis (CrAg-positive HIV/AIDS):</strong> <em>Diagnosis:</em> Serum/CSF CrAg antigen testing (>95% sensitive in CSF), India ink stain (40-50% sensitive), fungal culture. <em>Treatment (dual phases):</em></p>
                        <ul class="list-item">
                            <li><strong>Induction phase (2 weeks):</strong> Amphotericin B 0.7-1 mg/kg IV daily + flucytosine 25 mg/kg Q6H (if available/tolerated)</li>
                            <li><strong>Consolidation phase (8 weeks):</strong> Fluconazole 400 mg daily</li>
                            <li><strong>Maintenance phase:</strong> Fluconazole 200 mg daily indefinitely (until CD4 >100-200 for ≥3 months on ART)</li>
                        </ul>
                        <p><em>Adjunctive management:</em> CSF drainage/shunt if severe elevated ICP or symptomatic hydrocephalus. Avoid excessive fluid resuscitation (increases ICP). Corticosteroids controversial; may be considered if severe inflammation.</p>
                    </div>
                </div>

                <!-- Practice Question 5 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q5: A 24-year-old woman with AIDS (CD4 28 cells/µL) presents with subacute headache, fever, and neck stiffness. LP shows CSF: 80 WBC (predominantly lymphocytes), protein 110 mg/dL, glucose 42 mg/dL (serum 92). Serum CrAg is positive. CSF India ink stain is negative. What is the most important initial management step?</div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="a"> A) Start fluconazole 400 mg PO daily pending cultures; recheck LP in 1 week
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="b"> B) Start IV amphotericin B 0.7-1 mg/kg daily + flucytosine 25 mg/kg Q6H for induction therapy; manage ICP with CSF drainage if needed
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="c"> C) Start ceftriaxone + vancomycin empirically; obtain repeat cultures to confirm organism
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="d"> D) Initiate TB treatment immediately; TB meningitis most likely given low CSF glucose
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q5')">Show Answer</button>
                        <div id="q5-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The positive serum CrAg in an AIDS patient with meningitis is diagnostic for cryptococcal meningitis. Although CSF India ink is negative, the CrAg and clinical presentation confirm the diagnosis. Induction therapy with IV amphotericin B + flucytosine is the standard of care and offers superior outcomes compared to fluconazole monotherapy. ICP management is critical in cryptococcal meningitis due to high opening pressures; CSF drainage via LP or EVD may be necessary. Option A (fluconazole monotherapy) is suboptimal for induction. Options C and D are incorrect diagnoses given the positive CrAg.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> IDSA Practice Guidelines for Bacterial Meningitis. Tunkel AR et al. <em>Clin Infect Dis</em>. 2004;39:1267-84. Updated 2017.</li>
                        <li><span class="ref-guideline">[G2]</span> IDSA Guidelines for Cryptococcal Disease. Perfect JR et al. <em>Clin Infect Dis</em>. 2010;50:291-322.</li>
                        <li><span class="ref-guideline">[G3]</span> WHO Guidelines: Cryptococcal Disease in HIV-infected Adults. 2018.</li>
                        <li><span class="ref-trial">[T]</span> <strong>de Gans Trial:</strong> de Gans J, van de Beek D. <em>NEJM</em> 2002;347:1549-56. Dexamethasone reduced mortality in <em>S. pneumoniae</em> meningitis (7% vs 15%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>Thwaites Trial:</strong> Thwaites GE et al. <em>NEJM</em> 2004;351:1741-51. Dexamethasone in TBM reduced mortality (32% vs 41%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>AMBITION:</strong> Jarvis JN et al. <em>NEJM</em> 2022;386:1109-20. Single high-dose liposomal amphotericin B simplified cryptococcal treatment.</li>
                        <li>[R] van de Beek D et al. Community-acquired bacterial meningitis. <em>Nat Rev Dis Primers</em>. 2016;2:16074.</li>
                        <li>[R] Dalmau J et al. Anti-NMDA-receptor encephalitis. <em>Lancet Neurol</em>. 2008;7:1091-98.</li>
                        <li>[R] Thwaites GE et al. Tuberculous meningitis. <em>Nat Rev Neurol</em>. 2013;9:33-43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 9: Demyelinating Diseases -->
            <section id="section-9" class="section">
                <h1 class="section-title">9. Demyelinating Diseases</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Multiple Sclerosis: Subtypes & Diagnostic Criteria</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>MS Subtype</th>
                                <th>Course & Features</th>
                                <th>Frequency at Onset</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Relapsing-Remitting (RRMS)</strong></td>
                                <td>Distinct relapses with periods of remission/recovery. New or enlarging lesions on MRI between clinical events.</td>
                                <td>85% of MS presentations</td>
                                <td>~50% convert to SPMS by 10 years; highly variable</td>
                            </tr>
                            <tr>
                                <td><strong>Secondary Progressive (SPMS)</strong></td>
                                <td>Initial RRMS course followed by progressive worsening with or without superimposed relapses; declining remission quality</td>
                                <td>N/A (develops from RRMS)</td>
                                <td>Progressive disability; early/frequent relapses predict earlier conversion to SP</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive (PPMS)</strong></td>
                                <td>Progressive disability from onset without distinct relapses; slow, relentless accumulation of impairment</td>
                                <td>10-15% at onset</td>
                                <td>Worse prognosis; fewer effective DMT options historically; newer agents showing benefit</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive-Relapsing (PRMS)</strong></td>
                                <td>Progressive from onset with superimposed relapses and inter-relapse progression</td>
                                <td>5% at onset</td>
                                <td>Aggressive course; rare in modern series with early DMT initiation</td>
                            </tr>
                        </table>

                        <p><strong>McDonald 2017 Criteria for MS Diagnosis:</strong> Requires dissemination in space (DIS) and time (DIT).</p>
                        <ul class="list-item">
                            <li><strong>DIS:</strong> ≥1 lesion in ≥2 CNS regions (periventricular, juxtacortical, infratentorial, spinal cord) on MRI</li>
                            <li><strong>DIT:</strong> Simultaneous presence of gadolinium-enhancing and non-enhancing lesions on brain MRI, OR new lesions on follow-up MRI (≥30 days from initial scan), OR CSF-specific oligoclonal bands + abnormal VEP</li>
                            <li><strong>Clinical events required:</strong> Can satisfy DIT with single clinical event if above imaging criteria met; two relapses + objective evidence suffices for diagnosis</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ MS Presentations: Common Clinical Syndromes</div>
                            <ul class="list-item">
                                <li><strong>Optic Neuritis (ON):</strong> Unilateral vision loss, pain with eye movement, relative afferent pupillary defect (RAPD), normal appearing disc acutely or swollen. MRI shows T2 hyperintensity in optic nerve; brain MRI identifies clinically silent lesions (predicts future MS risk).</li>
                                <li><strong>Transverse Myelitis (TM):</strong> Bilateral motor/sensory deficits and sphincter dysfunction with clear spinal cord level. MRI shows T2 hyperintensity in cord; affects multiple segments (>2-3 vertebral levels).</li>
                                <li><strong>Internuclear Ophthalmoplegia (INO):</strong> Impaired adduction ipsilateral to lesion (medial longitudinal fasciculus—MLF), with preserved convergence. Bilateral INO in young patients is highly suggestive of MS.</li>
                                <li><strong>Lhermitte sign:</strong> Electric shock-like sensation down spine with neck flexion; indicates cervical demyelination.</li>
                                <li><strong>Uhthoff phenomenon:</strong> Transient worsening of symptoms with heat/exercise; due to impaired conduction in demyelinated axons.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Disease-Modifying Therapies (DMTs) for MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>DMT Category</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy & Use</th>
                                <th>Key Monitoring/SE</th>
                            </tr>
                            <tr>
                                <td><strong>Injectable (First-Line)</strong></td>
                                <td>Interferon-beta (IFN-β-1a, IFN-β-1b), glatiramer acetate</td>
                                <td>Immune modulation; unclear exact mechanism</td>
                                <td>Moderate efficacy; reduce relapses ~30%. Well-tolerated, established safety. First-line option especially in early/mild RRMS.</td>
                                <td>IFN: flu-like symptoms, depression risk (screen). GA: local injection reactions. Monthly monitoring labs initially.</td>
                            </tr>
                            <tr>
                                <td><strong>Oral Moderate (1st-2nd Line)</strong></td>
                                <td>Fingolimod, teriflunomide, dimethyl fumarate</td>
                                <td>S1P modulators, DHFR inhibitors, NRF2 activators</td>
                                <td>Moderate-high efficacy (20-50% relapse reduction vs placebo). Convenient oral dosing. Used in RRMS, early aggressive disease.</td>
                                <td>Fingolimod: heart rate monitoring (first dose), opportunistic infection risk (VZV, CMV, PML rare). Teriflunomide: hepatotoxicity, teratogen. DMF: flushing, GI upset, PML risk (rare, esp. if immunosuppressed).</td>
                            </tr>
                            <tr>
                                <td><strong>Oral High-Efficacy</strong></td>
                                <td>Cladribine (Mavenclad), siponimod</td>
                                <td>Lymphocyte depletion, S1P modulation</td>
                                <td>High efficacy (~60% relapse reduction). Used in aggressive RRMS, early conversion-risk disease. Siponimod effective in SPMS.</td>
                                <td>Cladribine: teratogenic, myelosuppression, infection risk, requires monitoring. Siponimod: similar to fingolimod (first-dose monitoring, infection risk).</td>
                            </tr>
                            <tr>
                                <td><strong>IV Infusion (High-Efficacy)</strong></td>
                                <td>Natalizumab (Tysabri), ocrelizumab (Ocrevus), alemtuzumab (Lemtrada)</td>
                                <td>VLA-4 antagonist, anti-CD20 B-cell depletion, anti-CD52 T-cell depletion</td>
                                <td><strong>Natalizumab:</strong> ~90% relapse reduction; used for aggressive RRMS or after DMT failure. <strong>Ocrelizumab:</strong> ~50-60% reduction, also effective in PPMS (unique). <strong>Alemtuzumab:</strong> ~70% reduction; intense induction, long remission potential.</td>
                                <td>Natalizumab: PML risk (especially JC virus+, on therapy >2 yrs; ~4 per 1000 JCV+). Ocrelizumab: infection risk, infusion reactions. Alemtuzumab: severe autoimmunity risk (thyroid, ITP, AIHA), requires monitoring Q3mo.</td>
                            </tr>
                            <tr>
                                <td><strong>Immune Reconstitution (Hematopoietic Stem Cell Transplantation—HSCT)</strong></td>
                                <td>Autologous HSCT</td>
                                <td>Myeloablation + stem cell rescue; resets immune system</td>
                                <td>Dramatic effect in highly aggressive RRMS/early SPMS; sustained remission in ~40-60%. High risk/high reward; reserved for aggressive disease.</td>
                                <td>Treatment toxicity (infections, secondary malignancy risk), mortality 1-3%. Requires extensive workup, intense supportive care.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> Modern MS treatment paradigm emphasizes early, aggressive therapy ("hit early, hit hard") in RRMS to prevent disability accumulation. High-efficacy agents increasingly used upfront in aggressive disease, shifting away from step-wise approach. Monitoring for DMT-specific complications (especially PML with natalizumab, autoimmunity with alemtuzumab) is essential.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Neuromyelitis Optica Spectrum Disorder (NMOSD) vs MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>MS</th>
                                <th>NMOSD</th>
                            </tr>
                            <tr>
                                <td><strong>Demographics</strong></td>
                                <td>Caucasian, age 20-40</td>
                                <td>Female-predominant, non-Caucasian (African, Asian), older age at onset</td>
                            </tr>
                            <tr>
                                <td><strong>Clinical Attacks</strong></td>
                                <td>Varied locations (ON, spinal, brainstem, multifocal)</td>
                                <td>Bilateral optic neuritis (ON) and longitudinally extensive transverse myelitis (LETM) are hallmark; area postrema syndrome (hiccups, vomiting) characteristic</td>
                            </tr>
                            <tr>
                                <td><strong>MRI Spine</strong></td>
                                <td>Short lesions (≤2 vertebral segments)</td>
                                <td>Longitudinally extensive lesions (≥3 vertebral segments, often spanning entire cord)</td>
                            </tr>
                            <tr>
                                <td><strong>Brain MRI</strong></td>
                                <td>Multiple white matter lesions, often periventricular</td>
                                <td>Often normal or minimal; brainstem/diencephalic lesions if present</td>
                            </tr>
                            <tr>
                                <td><strong>CSF</strong></td>
                                <td>Oligoclonal bands (OCBs) common</td>
                                <td>OCBs rare; pleocytosis may be higher (>50 WBC common in attacks)</td>
                            </tr>
                            <tr>
                                <td><strong>Aquaporin-4 (AQP4-IgG)</strong></td>
                                <td>Negative</td>
                                <td>Positive in ~80% (AQP4-IgG seropositive NMOSD); seronegative NMOSD exists (~20%, usually MOG-antibody associated)</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>DMTs (IFN, fingolimod, natalizumab, etc.)</td>
                                <td>Avoid IFN (may worsen); immunosuppression key (azathioprine, mycophenolate, rituximab, complement inhibitor eculizumab for AQP4-IgG+). Acute attacks: high-dose IV corticosteroids + PLEX.</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis</strong></td>
                                <td>Variable; slow disability accumulation</td>
                                <td>Generally worse; permanent visual loss, paraparesis common after attacks; however, newer targeted therapies improving outcomes</td>
                            </tr>
                        </table>

                        <p><strong>Area Postrema Syndrome (APS) in NMOSD:</strong> Intractable hiccups, nausea, vomiting from lesions in brainstem area postrema. Highly specific for NMOSD (rarely seen in MS). Often precedes more widespread neurologic symptoms by days/weeks. Warrant urgent neuroimaging and AQP4-IgG testing.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ NMOSD Diagnostic Criteria (2015 Revised)</div>
                            <p>Presence of AQP4-IgG (seropositive form) + at least 1 core clinical characteristic (ON, LETM, area postrema syndrome, acute brainstem syndrome, symptomatic narcolepsy, symptomatic acute diencephalic/optic pathway syndrome). OR seronegative: ≥2 core characteristics in different attacks + brain MRI normal + spinal cord MRI with ≥3 contiguous segments of T2 signal abnormality + CSF pleocytosis (recommended).</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 6 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q6: A 28-year-old woman presents with acute bilateral vision loss and MRI shows bilateral optic nerve T2 hyperintensity. Spine MRI reveals an 8-cm longitudinally extensive T2 signal abnormality spanning C1-T5 with central canal involvement. Serum and CSF AQP4-IgG testing is positive. What is the most important management distinction from MS?</div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="a"> A) Start interferon-beta as first-line DMT, as it is highly effective in NMOSD
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="b"> B) AVOID interferon-beta; use intensive immunosuppression (mycophenolate, azathioprine) or complement inhibitor (eculizumab) for long-term prevention. For acute attack: high-dose IV corticosteroids + plasma exchange.
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="c"> C) Prognosis is identical to MS; start standard MS DMT and monitor closely
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="d"> D) No treatment needed; bilateral ON and LETM are self-limited complications
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q6')">Show Answer</button>
                        <div id="q6-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation (bilateral ON + LETM) combined with positive AQP4-IgG is diagnostic for NMOSD. A critical distinction from MS is that interferon-beta and some other MS DMTs are contraindicated and may worsen NMOSD. Instead, intensive immunosuppression or complement inhibition is the cornerstone of therapy. Acute attacks require aggressive treatment (high-dose IV steroids, plasma exchange) to minimize permanent disability. The longitudinally extensive spinal cord lesion (8 cm, >3 segments) is characteristic of NMOSD, not typical MS. Prognosis requires different management to prevent vision loss and paralysis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> 2017 McDonald Criteria for MS. Thompson AJ et al. <em>Lancet Neurol</em>. 2018;17:162-173.</li>
                        <li><span class="ref-guideline">[G2]</span> International Consensus Criteria for NMOSD. Wingerchuk DM et al. <em>Neurology</em>. 2015;85:177-189.</li>
                        <li><span class="ref-guideline">[G3]</span> AAN DMT Guidelines for MS. Rae-Grant A et al. <em>Neurology</em>. 2018;90:777-788.</li>
                        <li><span class="ref-trial">[T]</span> <strong>OPERA I & II (Ocrelizumab):</strong> Hauser SL et al. <em>NEJM</em> 2017;376:221-34. Anti-CD20 vs IFN-beta-1a in RRMS: 46-47% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ORATORIO (Ocrelizumab PPMS):</strong> Montalban X et al. <em>NEJM</em> 2017;376:209-20. Only approved DMT for PPMS.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ASCLEPIOS (Ofatumumab):</strong> Hauser SL et al. <em>NEJM</em> 2020;383:546-57. SC anti-CD20 vs teriflunomide: 51-59% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREVENT (Eculizumab NMOSD):</strong> Pittock SJ et al. <em>NEJM</em> 2019;381:614-25. 94% relapse reduction in AQP4+ NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>N-MOmentum (Inebilizumab):</strong> Cree BAC et al. <em>Lancet</em> 2019;394:1352-63. 73% ARR reduction in NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SAkuraStar (Satralizumab):</strong> Traboulsee A et al. <em>Lancet Neurol</em> 2020;19:402-12. Anti-IL6R in NMOSD.</li>
                        <li>[R] Filippi M et al. Multiple sclerosis. <em>Nat Rev Dis Primers</em>. 2018;4:43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 10: Neuromuscular Disorders -->
            <section id="section-4" class="section">
                <h1 class="section-title">4. Headache Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Red Flags for Secondary Headache (SNOOP10)</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>SNOOP10 mnemonic for red flags suggesting secondary headache:</strong></p>
                        <ul class="list-item">
                            <li><strong>S</strong> - Systemic illness (fever, weight loss, malaise)</li>
                            <li><strong>N</strong> - Neurologic symptoms or signs (focal deficits, papilledema, altered consciousness)</li>
                            <li><strong>O</strong> - Onset sudden (thunderclap headache suggests SAH, reversible cerebral vasoconstriction, etc.)</li>
                            <li><strong>O</strong> - Older age (>50 years); new-onset headache in this group warrants investigation</li>
                            <li><strong>P</strong> - Papilledema, focal neurologic signs, or progressive worsening</li>
                            <li><strong>1</strong> - Pattern change (headache that has changed character, frequency, severity from baseline)</li>
                            <li><strong>0</strong> - Immunocompromised (HIV, chemotherapy, post-transplant) or on anticoagulation/recent head trauma</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Management Approach</div>
                            <p>Presence of ANY red flag warrants neuroimaging (MRI brain with/without contrast, or stat CT if acute), LP if imaging negative, and specialist evaluation. Primary headache diagnosis (migraine, tension, cluster) requires absence of red flags AND meeting clinical criteria.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine: Diagnostic Criteria (ICHD-3) & Acute Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>ICHD-3 Criteria for Migraine without Aura:</strong> At least 5 attacks with: (1) headache 4-72 hours, (2) at least 2 of: unilateral, pulsating quality, moderate-severe pain, aggravated by physical activity, AND (3) at least 1 of: nausea/vomiting OR photophobia/phonophobia.</p>

                        <p><strong>Migraine with Aura:</strong> Similar criteria but preceded by 5-60 minute aura (visual: scotoma, flashing lights; sensory: paresthesias; speech/language disturbance), fully reversible.</p>

                        <table>
                            <tr>
                                <th>Acute Treatment Class</th>
                                <th>Agent & Dosing</th>
                                <th>Efficacy Notes</th>
                            </tr>
                            <tr>
                                <td><strong>NSAIDs</strong></td>
                                <td>Ibuprofen 400-800 mg, naproxen 500 mg, aspirin 1000 mg PO</td>
                                <td>Effective for mild-moderate migraine. Risk with frequent use (>10-15 days/month): medication overuse headache</td>
                            </tr>
                            <tr>
                                <td><strong>Triptans</strong></td>
                                <td>Sumatriptan 50 mg PO / 20 mg nasal / 6 mg SC (most common). Alternatives: rizatriptan, naratriptan, zolmitriptan, almotriptan</td>
                                <td>Gold standard for moderate-severe migraine. 50-60% 2-hour pain-free rate. Contraindicated in uncontrolled HTN, CAD, prior MI/stroke, Raynaud's. Avoid frequent use (>10 days/month—rebound headache risk).</td>
                            </tr>
                            <tr>
                                <td><strong>Calcitonin Gene-Related Peptide (CGRP) Antagonists (Gepants)</strong></td>
                                <td>Ubrogepant 50-100 mg PO, rimegepant 75 mg PO (can be used preventively Q2 days), lasmiditan (5-HT1F agonist, structurally distinct)</td>
                                <td>Novel class; comparable efficacy to triptans (50-60% 2-hour pain-free). Advantages: no vasoconstrictive effects, safe in CAD/uncontrolled HTN. Drawback: cost. Good option if triptan contraindicated or failed.</td>
                            </tr>
                            <tr>
                                <td><strong>Ditans</strong></td>
                                <td>Lasmiditan 50-200 mg PO (5-HT1F agonist, distinct serotonin pathway)</td>
                                <td>Efficacy similar to triptans. Advantage: no vasoconstriction, safe in coronary disease. Caution: CNS effects (dizziness); avoid driving 8 hrs post-dose. Emerging class.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiemetics</strong></td>
                                <td>Metoclopramide 10 mg IV/IM, prochlorperazine 10 mg IV/IM, ondansetron 8 mg IV</td>
                                <td>Essential adjunct, especially for moderate-severe migraines with nausea. Can be monotherapy for mild cases. Metoclopramide enhances triptan absorption when given with oral triptan.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> <strong>Timing is critical.</strong> Acute migraine treatment is most effective when given early in migraine course (within 1-2 hours of onset). Repeated dosing after 2 hours if pain returns is less effective than initial dose. Triptan + NSAID combination often more effective than monotherapy.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Migraine Prevention: Pharmacologic & Non-Pharmacologic</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Agent Class</th>
                                <th>Specific Drugs & Dosing</th>
                                <th>Efficacy & Notes</th>
                            </tr>
                            <tr>
                                <td><strong>Beta-Blockers</strong></td>
                                <td>Propranolol 40-240 mg/day divided TID, timolol, metoprolol</td>
                                <td>First-line. Reduce migraine frequency by 40-60%. Particularly effective for migraine with aura, migraine with palpitations, or concurrent hypertension. SE: fatigue, erectile dysfunction.</td>
                            </tr>
                            <tr>
                                <td><strong>Antiepileptics</strong></td>
                                <td>Topiramate (Topamax) 50-200 mg/day; valproate 500-1500 mg/day; lamotrigine 100-200 mg/day</td>
                                <td>Topiramate most evidence. 40-50% reduction in migraine frequency. SE: cognitive effects, weight loss (topiramate, valproate), teratogenicity (valproate). Valproate rarely used now due to teratogenic risk.</td>
                            </tr>
                            <tr>
                                <td><strong>Tricyclic Antidepressants</strong></td>
                                <td>Amitriptyline 10-100 mg nightly; nortriptyline alternative</td>
                                <td>Effective, especially if concurrent depression/anxiety. 40-50% frequency reduction. SE: dry mouth, weight gain, sedation, anticholinergic effects. Often combined with other preventives.</td>
                            </tr>
                            <tr>
                                <td><strong>CGRP Monoclonal Antibodies (mAbs)</strong></td>
                                <td>Erenumab (Aimovig) 70-140 mg SC monthly, fremanezumab (Ajovy) 225 mg SC monthly or 675 mg quarterly, galcanezumab (Emgality) 240 mg SC loading, then 120 mg monthly, eptinezumab (Vyepti) IV quarterly</td>
                                <td>Highly effective; 40-50% migraine day reduction. Safe, well-tolerated. No serious black-box warnings. Monthly or quarterly dosing improves compliance. Cost/insurance barriers remain. Indication: ≥4 migraine days/month.</td>
                            </tr>
                            <tr>
                                <td><strong>Botulinum Toxin (Botox)</strong></td>
                                <td>Injections 155 units total (across forehead, temples, occiput, neck) Q12 weeks</td>
                                <td>FDA-approved for chronic migraine (≥15 days/month). ~45% responders with ≥50% reduction. Mechanism unclear but effective. Requires repeat injections every 12 weeks.</td>
                            </tr>
                            <tr>
                                <td><strong>Neuromodulation</strong></td>
                                <td>Occipital nerve stimulation (ONS), supraorbital nerve stimulation (SONS), vagus nerve stimulation (VNS)</td>
                                <td>Emerging options for refractory chronic migraine. Implantable devices; mixed evidence but growing support. Consider after drug failures.</td>
                            </tr>
                        </table>

                        <p><strong>Non-Pharmacologic Prevention:</strong> Sleep hygiene (consistent sleep schedule), stress management, biofeedback, regular aerobic exercise (30 mins 3-5x/week), trigger avoidance (food triggers: aged cheeses, processed meats, nitrites; hormone fluctuation in women; environmental triggers). Riboflavin 400 mg daily and magnesium 400-500 mg daily have modest evidence.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Medication Overuse Headache & Cluster Headache</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Medication Overuse Headache (MOH):</strong> Defined as headache occurring ≥15 days/month resulting from regular overuse of acute medication for ≥3 months. Risk drugs: triptans/ergots (≥10 days/month), analgesics/NSAIDs/acetaminophen (≥15 days/month), opioids/combination meds (≥10 days/month). Paradoxically, medication meant to relieve headache perpetuates chronic daily headache. Management: abrupt (or gradual) discontinuation of overused agent + migraine prevention. Withdrawal headaches expected first 1-2 weeks; reassurance and bridge therapy (NSAIDs, triptans prescribed sparingly) helps. Success rate 50-70% after medication cessation.</p>

                        <p><strong>Cluster Headache:</strong> Male-predominant (3-4:1), unilateral orbital/periorbital pain, severe (9-10/10), 15-180 minute duration, multiple attacks per day. Autonomic features: ipsilateral lacrimation, nasal congestion, conjunctival injection, ptosis/miosis (Horner's). Periods of remission and clusters (hence "cluster"). <em>Acute Treatment:</em> 100% oxygen 12-15 L/min for 15 minutes (rapid relief) + sumatriptan 6 mg SC (first-line). <em>Preventive:</em> Verapamil 240-480 mg/day (first-line, though evidence limited), topiramate, lithium (for chronic cluster), melatonin, occipital nerve blockade.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Secondary Headaches: Giant Cell Arteritis, Idiopathic Intracranial Hypertension, Others</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Condition</th>
                                <th>Clinical Features</th>
                                <th>Diagnosis</th>
                                <th>Urgent Management</th>
                            </tr>
                            <tr>
                                <td><strong>Giant Cell Arteritis (GCA)</strong></td>
                                <td>Age >50, new-onset temporal/occipital headache, scalp tenderness, jaw claudication, vision loss risk (arteritic anterior ischemic optic neuropathy—AAION), elevated ESR/CRP</td>
                                <td>Temporal artery biopsy (gold standard); elevated inflammatory markers</td>
                                <td>URGENT: High-dose corticosteroids (prednisone 1 mg/kg/day or IV methylprednisolone if vision loss) to prevent irreversible blindness. Do NOT wait for biopsy to start treatment if high suspicion.</td>
                            </tr>
                            <tr>
                                <td><strong>Idiopathic Intracranial Hypertension (IIH)</strong></td>
                                <td>Young women (18-45 yrs), obesity, progressive headache, visual obscurations, papilledema, sixth CN palsy possible</td>
                                <td>MRI brain (normal) + lumbar puncture (elevated ICP, normal CSF analysis)</td>
                                <td>Acetazolamide 500 mg BID-QID (carbonic anhydrase inhibitor reduces CSF production); weight loss critical. Topiramate alternative. Vision-threatening papilledema: consider optic nerve sheath fenestration or lumboperitoneal shunt.</td>
                            </tr>
                            <tr>
                                <td><strong>Spontaneous Intracranial Hypotension (SIH)</strong></td>
                                <td>Positional headache (worsens upright, improves supine), neck stiffness, auditory symptoms (tinnitus), visual disturbance. History of spinal procedures or Ehlers-Danlos syndrome</td>
                                <td>MRI brain shows sagging brainstem, subdural hematoma possible; MR myelography shows CSF leak site</td>
                                <td>Bed rest, hydration, caffeine (increases CSF production), epidural blood patch (gold standard treatment, 50-90% response), abdominal binder</td>
                            </tr>
                            <tr>
                                <td><strong>Reversible Cerebral Vasoconstriction Syndrome (RCVS)</strong></td>
                                <td>Thunderclap headaches (recurrent, 1-3 weeks), preceded by eclampsia, use of vasoactive drugs (decongestants, stimulants, cocaine), or spontaneous. Risk of stroke from vasospasm</td>
                                <td>MR/CT angiography shows segmental vasoconstriction pattern; dramatic improvement over 1-3 months</td>
                                <td>Calcium channel blockers (verapamil, nimodipine) for vasospasm prevention. Avoid vasoconstrictors. Usually self-limited but ischemic/hemorrhagic complications possible.</td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Practice Question 4 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q4: A 32-year-old woman with obesity presents with subacute progressive morning headache, visual obscurations, and mild blurred vision. Fundoscopy shows bilateral papilledema. MRI brain is normal. Lumbar puncture shows opening pressure of 32 cm H2O (normal <25), with normal glucose, protein, and cell counts. What is the next step in management?</div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="a"> A) Immediate IV mannitol and ICU admission for intracranial hypertension crisis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="b"> B) Start acetazolamide 500 mg BID, recommend weight loss, repeat imaging in 4 weeks
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="c"> C) MR venography to exclude cerebral venous sinus thrombosis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q4" value="d"> D) High-dose corticosteroids and temporal artery biopsy
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q4')">Show Answer</button>
                        <div id="q4-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation, demographics (young woman with obesity), imaging (normal MRI), and LP findings (elevated ICP, normal CSF analysis) are diagnostic for Idiopathic Intracranial Hypertension (IIH). This is not an acute neurosurgical emergency requiring ICU care unless there is vision-threatening papilledema with visual field loss. First-line management: acetazolamide to reduce CSF production, weight loss (most important modifiable factor), and monitoring for visual complications. Option A (mannitol) is reserved for acute elevated ICP with neurologic deterioration. Option C is unnecessary given normal MRI. Option D is incorrect (GCA criteria not met: wrong age, no systemic symptoms).</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> ICHD-3. <em>Cephalalgia</em>. 2018;38:1-211. Headache Classification Committee of IHS.</li>
                        <li><span class="ref-guideline">[G2]</span> AHS Consensus Statement: Integrating New Migraine Treatments. <em>Headache</em>. 2021;61:1021-1039.</li>
                        <li><span class="ref-guideline">[G3]</span> EHF Guideline: CGRP mAbs for Migraine Prevention. <em>J Headache Pain</em>. 2022;23:67.</li>
                        <li><span class="ref-trial">[T]</span> <strong>IIHTT:</strong> Wall M et al. <em>JAMA</em> 2014;311:1641-51. Acetazolamide + weight management in IIH.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PROMISE-1 (Erenumab):</strong> Goadsby PJ et al. <em>NEJM</em> 2017;377:2123-32. Erenumab reduced migraine days by 3.2-3.7.</li>
                        <li><span class="ref-trial">[T]</span> <strong>STRIVE (Erenumab):</strong> Dodick DW et al. <em>NEJM</em> 2018;378:2346-56. 50% responder rate 43-50%.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREEMPT 1&2 (OnabotulinumtoxinA):</strong> Aurora SK et al. <em>Headache</em> 2010;50:921-36. For chronic migraine.</li>
                        <li><span class="ref-trial">[T]</span> <strong>GiACTA (Tocilizumab for GCA):</strong> Stone JH et al. <em>NEJM</em> 2017;377:317-28. 56% sustained remission.</li>
                        <li>[R] Silberstein SD et al. Guideline: pharmacologic treatment for episodic migraine prevention. <em>Neurology</em>. 2012;78:1337-45.</li>
                        <li>[R] May A et al. Cluster headache. <em>Nat Rev Dis Primers</em>. 2018;4:18006.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 8: CNS Infections -->
            <section id="section-8" class="section">
                <h1 class="section-title">8. CNS Infections</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Bacterial Meningitis: Etiology by Age & Empiric Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Age Group</th>
                                <th>Most Common Organisms</th>
                                <th>Empiric Antibiotics</th>
                            </tr>
                            <tr>
                                <td><strong>Neonates (0-30 days)</strong></td>
                                <td>Group B Strep, E. coli K1, Listeria monocytogenes</td>
                                <td>Ampicillin 2g Q4H + ceftazidime 2g Q8H (or gentamicin)</td>
                            </tr>
                            <tr>
                                <td><strong>Infants/Children (1 mo-18 yrs)</strong></td>
                                <td>Streptococcus pneumoniae, Neisseria meningitidis, H. influenzae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Adults (18-50 yrs)</strong></td>
                                <td>N. meningitidis, S. pneumoniae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Older Adults (>50 yrs)</strong></td>
                                <td>S. pneumoniae, Listeria, Gram-negative rods</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin + ampicillin 2g Q4H</td>
                            </tr>
                            <tr>
                                <td><strong>Immunocompromised</strong></td>
                                <td>Listeria, Gram-negative rods, Cryptococcus, Mycobacterium</td>
                                <td>Add ampicillin to coverage; consider TMP-SMX for Listeria alternative</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Critical Management: Dexamethasone Timing</div>
                            <p>Dexamethasone 10 mg IV must be given <strong>BEFORE OR WITH first antibiotic dose</strong> to reduce neurologic complications (especially in pneumococcal meningitis). Give Q6H x 4 days. If given after antibiotics, efficacy diminished. Improves outcomes in ~30% of cases.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>CSF Analysis: Bacterial vs Viral vs TB vs Fungal</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Parameter</th>
                                <th>Bacterial</th>
                                <th>Viral</th>
                                <th>TB</th>
                                <th>Fungal</th>
                            </tr>
                            <tr>
                                <td><strong>Appearance</strong></td>
                                <td>Turbid/purulent</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                            </tr>
                            <tr>
                                <td><strong>Pressure</strong></td>
                                <td>Usually elevated (>400 mm H2O)</td>
                                <td>Normal-mildly elevated</td>
                                <td>Mildly-moderately elevated</td>
                                <td>Often elevated (100-500+)</td>
                            </tr>
                            <tr>
                                <td><strong>WBC (cells/µL)</strong></td>
                                <td>500-20,000+ (PMN predominant)</td>
                                <td>10-500 (lymph predominant early, then lymph)</td>
                                <td>100-500 (lymph predominant)</td>
                                <td>50-500 (lymph predominant)</td>
                            </tr>
                            <tr>
                                <td><strong>Protein</strong></td>
                                <td>>100 mg/dL (often 200-500)</td>
                                <td>Normal-mildly elevated (50-100)</td>
                                <td>100-500+ (often high)</td>
                                <td>100-500+ (often high)</td>
                            </tr>
                            <tr>
                                <td><strong>Glucose (CSF:serum ratio)</strong></td>
                                <td><40 mg/dL or <40% of serum</td>
                                <td>Normal (50-80% of serum)</td>
                                <td><40 mg/dL or <40% (low ratio key)</td>
                                <td>Low-normal (variable)</td>
                            </tr>
                            <tr>
                                <td><strong>Gram Stain</strong></td>
                                <td>Positive 60-90%</td>
                                <td>Negative</td>
                                <td>Negative (AFB for TB)</td>
                                <td>Negative (India ink for Cryptococcus)</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The combination of <strong>low CSF glucose + high protein + lymphocytic predominance</strong> is classic for TB meningitis. Delayed diagnosis is common; maintain high suspicion in at-risk patients (immunocompromised, endemic areas). Start anti-TB therapy empirically if TB meningitis suspected, even before confirmatory test results.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>HSV Encephalitis & Autoimmune Encephalitis</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Herpes Simplex Virus (HSV) Encephalitis:</strong> Most common cause of sporadic viral encephalitis. Presents with fever, altered consciousness, behavioral changes, seizures, focal neurologic signs (temporal lobe involvement common). CSF: lymphocytic pleocytosis, elevated protein, normal glucose (variable). <em>MRI:</em> T2/FLAIR hyperintensity in temporal lobes, orbitofrontal, insular regions. <em>EEG:</em> Periodic sharp wave complexes in temporal regions (PLEDS—periodic lateralizing epileptiform discharges). <em>Treatment:</em> <strong>Start acyclovir 10-15 mg/kg IV Q8H immediately upon suspicion (do NOT wait for LP or EEG)</strong>. Continue 10-14 days. PCR of CSF for HSV is gold standard (90%+ sensitivity), but treatment must start empirically. Early treatment crucial for prognosis; delays lead to permanent sequelae (cognitive impairment, seizures, personality change).</p>

                        <p><strong>Autoimmune Encephalitis (NMDAR-IgG, AMPAR-IgG, GABA-B-IgG, etc.):</strong> Increasingly recognized, especially in young patients with behavioral changes, psychosis, seizures, movement disorders. CSF shows lymphocytic pleocytosis, elevated protein. Brain MRI often normal or shows nonspecific changes. <em>Diagnosis:</em> CSF/serum antibody testing (NMDAR most common; can be seronegative 10-20%). <em>Treatment:</em> Immunotherapy is cornerstone: IVIG 2 g/kg over 3-5 days, plasma exchange, or both. Corticosteroids (methylprednisolone 1g daily x 3-5 days, then taper). Second-line: rituximab, cyclophosphamide for severe/refractory cases. Screen for underlying malignancy (ovarian teratomas in NMDAR encephalitis, lung cancer in others).</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>TB Meningitis & Cryptococcal Meningitis in HIV</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>TB Meningitis:</strong> Diagnosis: acid-fast bacilli (AFB) stain of CSF (low sensitivity ~10%), TB culture (gold standard but takes 2-6 weeks), TB PCR/GeneXpert MTB/RIF (higher sensitivity, faster). CSF shows low glucose + high protein. <em>Treatment:</em> 12-month regimen: (1) Intensive phase (2 months): isoniazid, rifampin, pyrazinamide, ethambutol, plus streptomycin. (2) Continuation phase (10 months): isoniazid + rifampin. <strong>Corticosteroids essential:</strong> Dexamethasone 0.3-0.4 mg/kg Q6H x 3 weeks, then taper. Dramatically improves outcomes. Adjunctive vitamin B6 (pyridoxine) for isoniazid neuropathy prevention.</p>

                        <p><strong>Cryptococcal Meningitis (CrAg-positive HIV/AIDS):</strong> <em>Diagnosis:</em> Serum/CSF CrAg antigen testing (>95% sensitive in CSF), India ink stain (40-50% sensitive), fungal culture. <em>Treatment (dual phases):</em></p>
                        <ul class="list-item">
                            <li><strong>Induction phase (2 weeks):</strong> Amphotericin B 0.7-1 mg/kg IV daily + flucytosine 25 mg/kg Q6H (if available/tolerated)</li>
                            <li><strong>Consolidation phase (8 weeks):</strong> Fluconazole 400 mg daily</li>
                            <li><strong>Maintenance phase:</strong> Fluconazole 200 mg daily indefinitely (until CD4 >100-200 for ≥3 months on ART)</li>
                        </ul>
                        <p><em>Adjunctive management:</em> CSF drainage/shunt if severe elevated ICP or symptomatic hydrocephalus. Avoid excessive fluid resuscitation (increases ICP). Corticosteroids controversial; may be considered if severe inflammation.</p>
                    </div>
                </div>

                <!-- Practice Question 5 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q5: A 24-year-old woman with AIDS (CD4 28 cells/µL) presents with subacute headache, fever, and neck stiffness. LP shows CSF: 80 WBC (predominantly lymphocytes), protein 110 mg/dL, glucose 42 mg/dL (serum 92). Serum CrAg is positive. CSF India ink stain is negative. What is the most important initial management step?</div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="a"> A) Start fluconazole 400 mg PO daily pending cultures; recheck LP in 1 week
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="b"> B) Start IV amphotericin B 0.7-1 mg/kg daily + flucytosine 25 mg/kg Q6H for induction therapy; manage ICP with CSF drainage if needed
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="c"> C) Start ceftriaxone + vancomycin empirically; obtain repeat cultures to confirm organism
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="d"> D) Initiate TB treatment immediately; TB meningitis most likely given low CSF glucose
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q5')">Show Answer</button>
                        <div id="q5-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The positive serum CrAg in an AIDS patient with meningitis is diagnostic for cryptococcal meningitis. Although CSF India ink is negative, the CrAg and clinical presentation confirm the diagnosis. Induction therapy with IV amphotericin B + flucytosine is the standard of care and offers superior outcomes compared to fluconazole monotherapy. ICP management is critical in cryptococcal meningitis due to high opening pressures; CSF drainage via LP or EVD may be necessary. Option A (fluconazole monotherapy) is suboptimal for induction. Options C and D are incorrect diagnoses given the positive CrAg.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> IDSA Practice Guidelines for Bacterial Meningitis. Tunkel AR et al. <em>Clin Infect Dis</em>. 2004;39:1267-84. Updated 2017.</li>
                        <li><span class="ref-guideline">[G2]</span> IDSA Guidelines for Cryptococcal Disease. Perfect JR et al. <em>Clin Infect Dis</em>. 2010;50:291-322.</li>
                        <li><span class="ref-guideline">[G3]</span> WHO Guidelines: Cryptococcal Disease in HIV-infected Adults. 2018.</li>
                        <li><span class="ref-trial">[T]</span> <strong>de Gans Trial:</strong> de Gans J, van de Beek D. <em>NEJM</em> 2002;347:1549-56. Dexamethasone reduced mortality in <em>S. pneumoniae</em> meningitis (7% vs 15%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>Thwaites Trial:</strong> Thwaites GE et al. <em>NEJM</em> 2004;351:1741-51. Dexamethasone in TBM reduced mortality (32% vs 41%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>AMBITION:</strong> Jarvis JN et al. <em>NEJM</em> 2022;386:1109-20. Single high-dose liposomal amphotericin B simplified cryptococcal treatment.</li>
                        <li>[R] van de Beek D et al. Community-acquired bacterial meningitis. <em>Nat Rev Dis Primers</em>. 2016;2:16074.</li>
                        <li>[R] Dalmau J et al. Anti-NMDA-receptor encephalitis. <em>Lancet Neurol</em>. 2008;7:1091-98.</li>
                        <li>[R] Thwaites GE et al. Tuberculous meningitis. <em>Nat Rev Neurol</em>. 2013;9:33-43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 9: Demyelinating Diseases -->
            <section id="section-9" class="section">
                <h1 class="section-title">9. Demyelinating Diseases</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Multiple Sclerosis: Subtypes & Diagnostic Criteria</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>MS Subtype</th>
                                <th>Course & Features</th>
                                <th>Frequency at Onset</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Relapsing-Remitting (RRMS)</strong></td>
                                <td>Distinct relapses with periods of remission/recovery. New or enlarging lesions on MRI between clinical events.</td>
                                <td>85% of MS presentations</td>
                                <td>~50% convert to SPMS by 10 years; highly variable</td>
                            </tr>
                            <tr>
                                <td><strong>Secondary Progressive (SPMS)</strong></td>
                                <td>Initial RRMS course followed by progressive worsening with or without superimposed relapses; declining remission quality</td>
                                <td>N/A (develops from RRMS)</td>
                                <td>Progressive disability; early/frequent relapses predict earlier conversion to SP</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive (PPMS)</strong></td>
                                <td>Progressive disability from onset without distinct relapses; slow, relentless accumulation of impairment</td>
                                <td>10-15% at onset</td>
                                <td>Worse prognosis; fewer effective DMT options historically; newer agents showing benefit</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive-Relapsing (PRMS)</strong></td>
                                <td>Progressive from onset with superimposed relapses and inter-relapse progression</td>
                                <td>5% at onset</td>
                                <td>Aggressive course; rare in modern series with early DMT initiation</td>
                            </tr>
                        </table>

                        <p><strong>McDonald 2017 Criteria for MS Diagnosis:</strong> Requires dissemination in space (DIS) and time (DIT).</p>
                        <ul class="list-item">
                            <li><strong>DIS:</strong> ≥1 lesion in ≥2 CNS regions (periventricular, juxtacortical, infratentorial, spinal cord) on MRI</li>
                            <li><strong>DIT:</strong> Simultaneous presence of gadolinium-enhancing and non-enhancing lesions on brain MRI, OR new lesions on follow-up MRI (≥30 days from initial scan), OR CSF-specific oligoclonal bands + abnormal VEP</li>
                            <li><strong>Clinical events required:</strong> Can satisfy DIT with single clinical event if above imaging criteria met; two relapses + objective evidence suffices for diagnosis</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ MS Presentations: Common Clinical Syndromes</div>
                            <ul class="list-item">
                                <li><strong>Optic Neuritis (ON):</strong> Unilateral vision loss, pain with eye movement, relative afferent pupillary defect (RAPD), normal appearing disc acutely or swollen. MRI shows T2 hyperintensity in optic nerve; brain MRI identifies clinically silent lesions (predicts future MS risk).</li>
                                <li><strong>Transverse Myelitis (TM):</strong> Bilateral motor/sensory deficits and sphincter dysfunction with clear spinal cord level. MRI shows T2 hyperintensity in cord; affects multiple segments (>2-3 vertebral levels).</li>
                                <li><strong>Internuclear Ophthalmoplegia (INO):</strong> Impaired adduction ipsilateral to lesion (medial longitudinal fasciculus—MLF), with preserved convergence. Bilateral INO in young patients is highly suggestive of MS.</li>
                                <li><strong>Lhermitte sign:</strong> Electric shock-like sensation down spine with neck flexion; indicates cervical demyelination.</li>
                                <li><strong>Uhthoff phenomenon:</strong> Transient worsening of symptoms with heat/exercise; due to impaired conduction in demyelinated axons.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Disease-Modifying Therapies (DMTs) for MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>DMT Category</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy & Use</th>
                                <th>Key Monitoring/SE</th>
                            </tr>
                            <tr>
                                <td><strong>Injectable (First-Line)</strong></td>
                                <td>Interferon-beta (IFN-β-1a, IFN-β-1b), glatiramer acetate</td>
                                <td>Immune modulation; unclear exact mechanism</td>
                                <td>Moderate efficacy; reduce relapses ~30%. Well-tolerated, established safety. First-line option especially in early/mild RRMS.</td>
                                <td>IFN: flu-like symptoms, depression risk (screen). GA: local injection reactions. Monthly monitoring labs initially.</td>
                            </tr>
                            <tr>
                                <td><strong>Oral Moderate (1st-2nd Line)</strong></td>
                                <td>Fingolimod, teriflunomide, dimethyl fumarate</td>
                                <td>S1P modulators, DHFR inhibitors, NRF2 activators</td>
                                <td>Moderate-high efficacy (20-50% relapse reduction vs placebo). Convenient oral dosing. Used in RRMS, early aggressive disease.</td>
                                <td>Fingolimod: heart rate monitoring (first dose), opportunistic infection risk (VZV, CMV, PML rare). Teriflunomide: hepatotoxicity, teratogen. DMF: flushing, GI upset, PML risk (rare, esp. if immunosuppressed).</td>
                            </tr>
                            <tr>
                                <td><strong>Oral High-Efficacy</strong></td>
                                <td>Cladribine (Mavenclad), siponimod</td>
                                <td>Lymphocyte depletion, S1P modulation</td>
                                <td>High efficacy (~60% relapse reduction). Used in aggressive RRMS, early conversion-risk disease. Siponimod effective in SPMS.</td>
                                <td>Cladribine: teratogenic, myelosuppression, infection risk, requires monitoring. Siponimod: similar to fingolimod (first-dose monitoring, infection risk).</td>
                            </tr>
                            <tr>
                                <td><strong>IV Infusion (High-Efficacy)</strong></td>
                                <td>Natalizumab (Tysabri), ocrelizumab (Ocrevus), alemtuzumab (Lemtrada)</td>
                                <td>VLA-4 antagonist, anti-CD20 B-cell depletion, anti-CD52 T-cell depletion</td>
                                <td><strong>Natalizumab:</strong> ~90% relapse reduction; used for aggressive RRMS or after DMT failure. <strong>Ocrelizumab:</strong> ~50-60% reduction, also effective in PPMS (unique). <strong>Alemtuzumab:</strong> ~70% reduction; intense induction, long remission potential.</td>
                                <td>Natalizumab: PML risk (especially JC virus+, on therapy >2 yrs; ~4 per 1000 JCV+). Ocrelizumab: infection risk, infusion reactions. Alemtuzumab: severe autoimmunity risk (thyroid, ITP, AIHA), requires monitoring Q3mo.</td>
                            </tr>
                            <tr>
                                <td><strong>Immune Reconstitution (Hematopoietic Stem Cell Transplantation—HSCT)</strong></td>
                                <td>Autologous HSCT</td>
                                <td>Myeloablation + stem cell rescue; resets immune system</td>
                                <td>Dramatic effect in highly aggressive RRMS/early SPMS; sustained remission in ~40-60%. High risk/high reward; reserved for aggressive disease.</td>
                                <td>Treatment toxicity (infections, secondary malignancy risk), mortality 1-3%. Requires extensive workup, intense supportive care.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> Modern MS treatment paradigm emphasizes early, aggressive therapy ("hit early, hit hard") in RRMS to prevent disability accumulation. High-efficacy agents increasingly used upfront in aggressive disease, shifting away from step-wise approach. Monitoring for DMT-specific complications (especially PML with natalizumab, autoimmunity with alemtuzumab) is essential.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Neuromyelitis Optica Spectrum Disorder (NMOSD) vs MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>MS</th>
                                <th>NMOSD</th>
                            </tr>
                            <tr>
                                <td><strong>Demographics</strong></td>
                                <td>Caucasian, age 20-40</td>
                                <td>Female-predominant, non-Caucasian (African, Asian), older age at onset</td>
                            </tr>
                            <tr>
                                <td><strong>Clinical Attacks</strong></td>
                                <td>Varied locations (ON, spinal, brainstem, multifocal)</td>
                                <td>Bilateral optic neuritis (ON) and longitudinally extensive transverse myelitis (LETM) are hallmark; area postrema syndrome (hiccups, vomiting) characteristic</td>
                            </tr>
                            <tr>
                                <td><strong>MRI Spine</strong></td>
                                <td>Short lesions (≤2 vertebral segments)</td>
                                <td>Longitudinally extensive lesions (≥3 vertebral segments, often spanning entire cord)</td>
                            </tr>
                            <tr>
                                <td><strong>Brain MRI</strong></td>
                                <td>Multiple white matter lesions, often periventricular</td>
                                <td>Often normal or minimal; brainstem/diencephalic lesions if present</td>
                            </tr>
                            <tr>
                                <td><strong>CSF</strong></td>
                                <td>Oligoclonal bands (OCBs) common</td>
                                <td>OCBs rare; pleocytosis may be higher (>50 WBC common in attacks)</td>
                            </tr>
                            <tr>
                                <td><strong>Aquaporin-4 (AQP4-IgG)</strong></td>
                                <td>Negative</td>
                                <td>Positive in ~80% (AQP4-IgG seropositive NMOSD); seronegative NMOSD exists (~20%, usually MOG-antibody associated)</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>DMTs (IFN, fingolimod, natalizumab, etc.)</td>
                                <td>Avoid IFN (may worsen); immunosuppression key (azathioprine, mycophenolate, rituximab, complement inhibitor eculizumab for AQP4-IgG+). Acute attacks: high-dose IV corticosteroids + PLEX.</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis</strong></td>
                                <td>Variable; slow disability accumulation</td>
                                <td>Generally worse; permanent visual loss, paraparesis common after attacks; however, newer targeted therapies improving outcomes</td>
                            </tr>
                        </table>

                        <p><strong>Area Postrema Syndrome (APS) in NMOSD:</strong> Intractable hiccups, nausea, vomiting from lesions in brainstem area postrema. Highly specific for NMOSD (rarely seen in MS). Often precedes more widespread neurologic symptoms by days/weeks. Warrant urgent neuroimaging and AQP4-IgG testing.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ NMOSD Diagnostic Criteria (2015 Revised)</div>
                            <p>Presence of AQP4-IgG (seropositive form) + at least 1 core clinical characteristic (ON, LETM, area postrema syndrome, acute brainstem syndrome, symptomatic narcolepsy, symptomatic acute diencephalic/optic pathway syndrome). OR seronegative: ≥2 core characteristics in different attacks + brain MRI normal + spinal cord MRI with ≥3 contiguous segments of T2 signal abnormality + CSF pleocytosis (recommended).</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 6 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q6: A 28-year-old woman presents with acute bilateral vision loss and MRI shows bilateral optic nerve T2 hyperintensity. Spine MRI reveals an 8-cm longitudinally extensive T2 signal abnormality spanning C1-T5 with central canal involvement. Serum and CSF AQP4-IgG testing is positive. What is the most important management distinction from MS?</div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="a"> A) Start interferon-beta as first-line DMT, as it is highly effective in NMOSD
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="b"> B) AVOID interferon-beta; use intensive immunosuppression (mycophenolate, azathioprine) or complement inhibitor (eculizumab) for long-term prevention. For acute attack: high-dose IV corticosteroids + plasma exchange.
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="c"> C) Prognosis is identical to MS; start standard MS DMT and monitor closely
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="d"> D) No treatment needed; bilateral ON and LETM are self-limited complications
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q6')">Show Answer</button>
                        <div id="q6-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation (bilateral ON + LETM) combined with positive AQP4-IgG is diagnostic for NMOSD. A critical distinction from MS is that interferon-beta and some other MS DMTs are contraindicated and may worsen NMOSD. Instead, intensive immunosuppression or complement inhibition is the cornerstone of therapy. Acute attacks require aggressive treatment (high-dose IV steroids, plasma exchange) to minimize permanent disability. The longitudinally extensive spinal cord lesion (8 cm, >3 segments) is characteristic of NMOSD, not typical MS. Prognosis requires different management to prevent vision loss and paralysis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> 2017 McDonald Criteria for MS. Thompson AJ et al. <em>Lancet Neurol</em>. 2018;17:162-173.</li>
                        <li><span class="ref-guideline">[G2]</span> International Consensus Criteria for NMOSD. Wingerchuk DM et al. <em>Neurology</em>. 2015;85:177-189.</li>
                        <li><span class="ref-guideline">[G3]</span> AAN DMT Guidelines for MS. Rae-Grant A et al. <em>Neurology</em>. 2018;90:777-788.</li>
                        <li><span class="ref-trial">[T]</span> <strong>OPERA I & II (Ocrelizumab):</strong> Hauser SL et al. <em>NEJM</em> 2017;376:221-34. Anti-CD20 vs IFN-beta-1a in RRMS: 46-47% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ORATORIO (Ocrelizumab PPMS):</strong> Montalban X et al. <em>NEJM</em> 2017;376:209-20. Only approved DMT for PPMS.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ASCLEPIOS (Ofatumumab):</strong> Hauser SL et al. <em>NEJM</em> 2020;383:546-57. SC anti-CD20 vs teriflunomide: 51-59% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREVENT (Eculizumab NMOSD):</strong> Pittock SJ et al. <em>NEJM</em> 2019;381:614-25. 94% relapse reduction in AQP4+ NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>N-MOmentum (Inebilizumab):</strong> Cree BAC et al. <em>Lancet</em> 2019;394:1352-63. 73% ARR reduction in NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SAkuraStar (Satralizumab):</strong> Traboulsee A et al. <em>Lancet Neurol</em> 2020;19:402-12. Anti-IL6R in NMOSD.</li>
                        <li>[R] Filippi M et al. Multiple sclerosis. <em>Nat Rev Dis Primers</em>. 2018;4:43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 10: Neuromuscular Disorders -->
            <section id="section-5" class="section">
                <h1 class="section-title">5. Neuromuscular Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Myasthenia Gravis: Diagnosis & Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Clinical Features:</strong> Fluctuating weakness worsened by fatigue, worse in evening. Ptosis, diplopia common. Bulbar weakness (dysarthria, dysphagia). Respiratory weakness in severe cases. Vital capacity critical to monitor.</p>

                        <table>
                            <tr>
                                <th>Diagnostic Test</th>
                                <th>Sensitivity</th>
                                <th>Method/Findings</th>
                            </tr>
                            <tr>
                                <td><strong>Serum Anti-Acetylcholine Receptor (AChR) Antibodies</strong></td>
                                <td>~80% in generalized MG, ~50% in ocular MG</td>
                                <td>Seropositivity confirms diagnosis; high titers correlate with severity</td>
                            </tr>
                            <tr>
                                <td><strong>Anti-Muscle-Specific Kinase (MuSK) Antibodies</strong></td>
                                <td>~40-50% in seronegative MG (AChR-negative)</td>
                                <td>Seronegative myasthenia; often more severe ocular involvement</td>
                            </tr>
                            <tr>
                                <td><strong>Edrophonium Challenge Test</strong></td>
                                <td>~95%</td>
                                <td>Rarely used now; IV edrophonium (acetylcholinesterase inhibitor) causes transient strength improvement in MG (specific for NMJ disorder). Risk of cholinergic crisis; atropine at bedside required.</td>
                            </tr>
                            <tr>
                                <td><strong>Repetitive Nerve Stimulation (RNS)</strong></td>
                                <td>~60-80% in generalized MG, ~10% in ocular</td>
                                <td>Characteristic decremental response (progressive decline in compound muscle action potential with repeated stimulation)</td>
                            </tr>
                            <tr>
                                <td><strong>Single-Fiber Electromyography (SFEMG)</strong></td>
                                <td>~95% (most sensitive)</td>
                                <td>Increased "jitter" and blocking; abnormal in MG, also in Lambert-Eaton and some myopathies</td>
                            </tr>
                        </table>

                        <p><strong>Pharmacotherapy:</strong></p>
                        <ul class="list-item">
                            <li><strong>Acetylcholinesterase Inhibitors:</strong> Pyridostigmine 30-60 mg PO Q3-4H (max 600 mg/day). Symptomatic only, no disease-modifying effect. SE: cholinergic (diarrhea, cramping, fasciculations). Onset of action 30 min, duration 3-4 hrs.</li>
                            <li><strong>Immunosuppressants (Disease-modifying):</strong> Corticosteroids (prednisone starting 0.5-1 mg/kg/day, taper to lowest effective dose), azathioprine (2-3 mg/kg/day, requires thiopurine methyltransferase screening), mycophenolate (0.5-1 g BID). Effective in majority; can take weeks-months for benefit.</li>
                            <li><strong>Complement Inhibitors (Newer):</strong> Eculizumab (first approved complement inhibitor for generalized MG, particularly anti-AChR+), C5a receptor antagonist (iptacopan). Reduce exacerbations, improve strength without systemic immunosuppression risks.</li>
                            <li><strong>FcRn Inhibitors (Emerging):</strong> Efgartigimod, rozanolixizumab. Block neonatal Fc receptor, reduce IgG recycling → rapid symptom improvement, used as adjunct or in refractory cases.</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Myasthenic Crisis (MC)</div>
                            <p><strong>"20-30-40 Rule":</strong> Watch for crisis if vital capacity <2 liters (20% of predicted normal ~4-5L), oropharyngeal weakness score >4 (0-5 scale), or disease duration 4-40 years (peak risk). Crisis manifests as respiratory failure requiring intubation (positive pressure ventilation needed). <strong>Management:</strong> Intubate prophylactically if trending toward crisis (VC declining, difficulty managing secretions). Plasmapheresis (PLEX) or IVIG 2 g/kg over 3-5 days for rapid symptom improvement; both ~equal efficacy. Avoid aminoglycosides, macrolides (worsen neuromuscular transmission). IV magnesium, muscle relaxants (succinylcholine) prolonged effect in MG—use rocuronium instead if paralysis needed. Thymectomy (after stabilization) beneficial even in seronegative cases.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Guillain-Barré Syndrome: Variants & Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>GBS Variant</th>
                                <th>Features</th>
                                <th>Associated Antibodies</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Acute Inflammatory Demyelinating Polyradiculoneuropathy (AIDP)</strong></td>
                                <td>Most common (85-90%). Ascending paralysis, areflexia, respiratory involvement possible. CSF albuminocytologic dissociation (high protein, normal cells).</td>
                                <td>Anti-GQ1b, anti-GM1 occasionally</td>
                                <td>~85% achieve good recovery; mortality 3-5% (resp. failure, autonomic dysfunction)</td>
                            </tr>
                            <tr>
                                <td><strong>Acute Motor Axonal Neuropathy (AMAN)</strong></td>
                                <td>Primarily motor, minimal sensory loss. Predominantly in Asia/South America. Associated with C. jejuni infection.</td>
                                <td>Anti-GM1 (>80%), anti-GD1a</td>
                                <td>More aggressive; slower recovery (~12 months); residual deficit common</td>
                            </tr>
                            <tr>
                                <td><strong>Miller Fisher Syndrome (MFS)</strong></td>
                                <td>Classic triad: areflexia + ataxia + ophthalmoplegia (inability to move eyes). Minimal limb weakness. Variant of GBS (~5%).</td>
                                <td>Anti-GQ1b (90%+), anti-GT1a, anti-GD1b</td>
                                <td>Generally better prognosis; ~70% full recovery; treatment same as GBS</td>
                            </tr>
                        </table>

                        <p><strong>CSF Findings:</strong> Characteristic albuminocytologic dissociation—elevated protein (100-600 mg/dL) with normal-low WBC (<5 cells/µL), normal glucose. This distinguishes GBS from other causes of acute paralysis.</p>

                        <p><strong>Treatment:</strong> <strong>IVIg 2 g/kg over 3-5 days OR plasmapheresis (4-6 exchanges over 7-14 days)</strong>. Both equally effective; choice depends on availability. <strong>Combination therapy (IVIG + PLEX) not superior to either alone.</strong> Supportive care critical: respiratory monitoring (FVC/MIF), ICU admission if respiratory involvement anticipated. Autonomic instability common (hypertension, orthostatic hypotension, arrhythmias)—continuous cardiac monitoring. Avoid exacerbating factors (temp >38.5°C, hyponatremia). Prognosis generally good if recognized and treated early, though residual weakness may persist in 15-20%.</p>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> High CSF protein (>100 mg/dL) early in GBS course (first week) may predict worse prognosis. Anti-GQ1b antibodies in Miller Fisher are nearly pathognomonic; if present with appropriate clinical syndrome, diagnosis is secure.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Peripheral Neuropathy: Approach & Common Etiologies</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>Axonal Neuropathy</th>
                                <th>Demyelinating Neuropathy</th>
                            </tr>
                            <tr>
                                <td><strong>Distribution</strong></td>
                                <td>Distal, length-dependent, "stocking-glove" pattern (legs > arms)</td>
                                <td>Proximal or diffuse; can be patchy/multifocal</td>
                            </tr>
                            <tr>
                                <td><strong>NCS/EMG</strong></td>
                                <td>Normal/reduced conduction velocities; reduced amplitudes (compound muscle/sensory action potential); some slowing</td>
                                <td>Markedly slowed conduction velocities (<50% normal), prolonged F waves/distal latencies, conduction blocks</td>
                            </tr>
                            <tr>
                                <td><strong>Common Causes</strong></td>
                                <td>Diabetes (most common), alcoholism, B12 deficiency, chemotherapy, hereditary sensory-motor neuropathy</td>
                                <td>Chronic Inflammatory Demyelinating Polyradiculoneuropathy (CIDP), CMT1 (hereditary), IgM monoclonal gammopathy</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis/Treatment</strong></td>
                                <td>Often irreversible; focus on prevention/slowing progression. Symptom management (gabapentin, pregabalin, duloxetine).</td>
                                <td>Often responsive to immunotherapy. CIDP: IVIG, PLEX, or corticosteroids. Hereditary requires genetic counseling.</td>
                            </tr>
                        </table>

                        <p><strong>Diabetic Peripheral Neuropathy:</strong> Most common cause of neuropathy in developed countries. Manifests as distal, symmetrical, length-dependent sensorimotor neuropathy. Small fiber involvement common (pain, temperature loss). Large fiber involvement: weakness, ataxia, areflexia. Prevention: tight glycemic control (target HbA1c <7%), blood pressure control. Treatment: gabapentin 1800-3600 mg/day, pregabalin 300-600 mg/day, duloxetine 60 mg daily. Alpha-lipoic acid shows modest benefit. Aggressive foot care (inspection, padded shoes, regular podiatry) to prevent ulcers.</p>

                        <p><strong>B12 Deficiency Neuropathy:</strong> Combined central and peripheral involvement. Dorsal column disease (posterior column syndrome): vibration/proprioception loss, sensory ataxia, positive Romberg. Peripheral nerve involvement: distal sensory loss, areflexia. Cognitive changes (dementia, personality change) if chronic. Diagnosis: low B12 level, elevated methylmalonic acid and homocysteine. Treatment: B12 repletion (IM cyanocobalamin 1000 µg monthly, or high-dose oral if pernicious anemia treated with intrinsic factor). Neurologic damage may be irreversible if prolonged; early treatment essential.</p>

                        <p><strong>CIDP (Chronic Inflammatory Demyelinating Polyradiculoneuropathy):</strong> Acquired demyelinating disorder; progressive or relapsing course over ≥8 weeks. Proximal + distal weakness, elevated CSF protein (demyelinating pattern on NCS). Diagnosis requires: (1) clinical + NCS criteria (slowed velocities, blocks), (2) CSF elevated protein, OR (3) demyelinating features on nerve biopsy. Treatment: IVIG (2 g/kg monthly), PLEX, or oral corticosteroids. Many require long-term immunosuppression (azathioprine, mycophenolate).</p>
                    </div>
                </div>

                <!-- Practice Question 7 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q7: A 35-year-old woman with seronegative myasthenia gravis (no anti-AChR antibodies) on pyridostigmine presents with worsening ptosis and diplopia unresponsive to increasing doses. She is not yet on immunosuppression. What is the most likely underlying antibody target?</div>
                        <div class="question-option">
                            <input type="radio" name="q7" value="a"> A) Anti-muscle-specific kinase (MuSK) antibodies
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q7" value="b"> B) Anti-LRP4 (agrin-related protein)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q7" value="c"> C) Anti-GABA-A receptor
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q7" value="d"> D) Anti-thyroid peroxidase (anti-TPO)
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q7')">Show Answer</button>
                        <div id="q7-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: A</div>
                            <div class="explanation"><strong>Explanation:</strong> This patient is seronegative for anti-AChR antibodies but has clinical MG (ptosis, diplopia, weakness). ~40-50% of seronegative MG patients have anti-MuSK antibodies. MuSK-antibody-positive MG often presents with predominantly ocular symptoms and may respond poorly to acetylcholinesterase inhibitors alone; immunosuppression (corticosteroids, azathioprine, mycophenolate) is typically required. Anti-LRP4 is rare in MG. Options C and D are not MG-specific antibodies.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> International Consensus for MG Management. Sanders DB et al. <em>Neurology</em>. 2016;87:419-425.</li>
                        <li><span class="ref-guideline">[G2]</span> Evidence-Based Guideline: GBS Diagnosis and Treatment. AAN. 2012.</li>
                        <li><span class="ref-guideline">[G3]</span> EFNS/PNS Guideline: CIDP Management. Van den Bergh PYK et al. <em>J Peripher Nerv Syst</em>. 2021;26:242-268.</li>
                        <li><span class="ref-trial">[T]</span> <strong>MGTX:</strong> Wolfe GI et al. <em>NEJM</em> 2016;375:511-22. Thymectomy + prednisone superior to prednisone alone in AChR+ generalized MG.</li>
                        <li><span class="ref-trial">[T]</span> <strong>REGAIN (Eculizumab MG):</strong> Howard JF Jr et al. <em>Lancet Neurol</em> 2017;16:976-86. Complement inhibitor in refractory MG.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ADAPT (Efgartigimod):</strong> Howard JF Jr et al. <em>Lancet Neurol</em> 2021;20:526-36. FcRn antagonist: 68% vs 30% response.</li>
                        <li><span class="ref-trial">[T]</span> <strong>CHAMPION-MG (Ravulizumab):</strong> Vu T et al. <em>NEJM</em> 2022;386:1132-42. Long-acting C5 inhibitor in MG.</li>
                        <li><span class="ref-trial">[T]</span> <strong>GBS-IVIg Trial:</strong> van der Meche FGA et al. <em>NEJM</em> 1992;326:1123-9. IVIg equivalent to PLEX.</li>
                        <li>[R] Gilhus NE et al. Myasthenia gravis. <em>Nat Rev Dis Primers</em>. 2019;5:30.</li>
                        <li>[R] Shahrizaila N et al. Guillain-Barre syndrome. <em>Lancet</em>. 2021;397:1214-28.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 11: Dementia and Cognitive Disorders -->
            <section id="section-6" class="section">
                <h1 class="section-title">6. Demyelinating Diseases</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Multiple Sclerosis: Subtypes & Diagnostic Criteria</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>MS Subtype</th>
                                <th>Course & Features</th>
                                <th>Frequency at Onset</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Relapsing-Remitting (RRMS)</strong></td>
                                <td>Distinct relapses with periods of remission/recovery. New or enlarging lesions on MRI between clinical events.</td>
                                <td>85% of MS presentations</td>
                                <td>~50% convert to SPMS by 10 years; highly variable</td>
                            </tr>
                            <tr>
                                <td><strong>Secondary Progressive (SPMS)</strong></td>
                                <td>Initial RRMS course followed by progressive worsening with or without superimposed relapses; declining remission quality</td>
                                <td>N/A (develops from RRMS)</td>
                                <td>Progressive disability; early/frequent relapses predict earlier conversion to SP</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive (PPMS)</strong></td>
                                <td>Progressive disability from onset without distinct relapses; slow, relentless accumulation of impairment</td>
                                <td>10-15% at onset</td>
                                <td>Worse prognosis; fewer effective DMT options historically; newer agents showing benefit</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive-Relapsing (PRMS)</strong></td>
                                <td>Progressive from onset with superimposed relapses and inter-relapse progression</td>
                                <td>5% at onset</td>
                                <td>Aggressive course; rare in modern series with early DMT initiation</td>
                            </tr>
                        </table>

                        <p><strong>McDonald 2017 Criteria for MS Diagnosis:</strong> Requires dissemination in space (DIS) and time (DIT).</p>
                        <ul class="list-item">
                            <li><strong>DIS:</strong> ≥1 lesion in ≥2 CNS regions (periventricular, juxtacortical, infratentorial, spinal cord) on MRI</li>
                            <li><strong>DIT:</strong> Simultaneous presence of gadolinium-enhancing and non-enhancing lesions on brain MRI, OR new lesions on follow-up MRI (≥30 days from initial scan), OR CSF-specific oligoclonal bands + abnormal VEP</li>
                            <li><strong>Clinical events required:</strong> Can satisfy DIT with single clinical event if above imaging criteria met; two relapses + objective evidence suffices for diagnosis</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ MS Presentations: Common Clinical Syndromes</div>
                            <ul class="list-item">
                                <li><strong>Optic Neuritis (ON):</strong> Unilateral vision loss, pain with eye movement, relative afferent pupillary defect (RAPD), normal appearing disc acutely or swollen. MRI shows T2 hyperintensity in optic nerve; brain MRI identifies clinically silent lesions (predicts future MS risk).</li>
                                <li><strong>Transverse Myelitis (TM):</strong> Bilateral motor/sensory deficits and sphincter dysfunction with clear spinal cord level. MRI shows T2 hyperintensity in cord; affects multiple segments (>2-3 vertebral levels).</li>
                                <li><strong>Internuclear Ophthalmoplegia (INO):</strong> Impaired adduction ipsilateral to lesion (medial longitudinal fasciculus—MLF), with preserved convergence. Bilateral INO in young patients is highly suggestive of MS.</li>
                                <li><strong>Lhermitte sign:</strong> Electric shock-like sensation down spine with neck flexion; indicates cervical demyelination.</li>
                                <li><strong>Uhthoff phenomenon:</strong> Transient worsening of symptoms with heat/exercise; due to impaired conduction in demyelinated axons.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Disease-Modifying Therapies (DMTs) for MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>DMT Category</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy & Use</th>
                                <th>Key Monitoring/SE</th>
                            </tr>
                            <tr>
                                <td><strong>Injectable (First-Line)</strong></td>
                                <td>Interferon-beta (IFN-β-1a, IFN-β-1b), glatiramer acetate</td>
                                <td>Immune modulation; unclear exact mechanism</td>
                                <td>Moderate efficacy; reduce relapses ~30%. Well-tolerated, established safety. First-line option especially in early/mild RRMS.</td>
                                <td>IFN: flu-like symptoms, depression risk (screen). GA: local injection reactions. Monthly monitoring labs initially.</td>
                            </tr>
                            <tr>
                                <td><strong>Oral Moderate (1st-2nd Line)</strong></td>
                                <td>Fingolimod, teriflunomide, dimethyl fumarate</td>
                                <td>S1P modulators, DHFR inhibitors, NRF2 activators</td>
                                <td>Moderate-high efficacy (20-50% relapse reduction vs placebo). Convenient oral dosing. Used in RRMS, early aggressive disease.</td>
                                <td>Fingolimod: heart rate monitoring (first dose), opportunistic infection risk (VZV, CMV, PML rare). Teriflunomide: hepatotoxicity, teratogen. DMF: flushing, GI upset, PML risk (rare, esp. if immunosuppressed).</td>
                            </tr>
                            <tr>
                                <td><strong>Oral High-Efficacy</strong></td>
                                <td>Cladribine (Mavenclad), siponimod</td>
                                <td>Lymphocyte depletion, S1P modulation</td>
                                <td>High efficacy (~60% relapse reduction). Used in aggressive RRMS, early conversion-risk disease. Siponimod effective in SPMS.</td>
                                <td>Cladribine: teratogenic, myelosuppression, infection risk, requires monitoring. Siponimod: similar to fingolimod (first-dose monitoring, infection risk).</td>
                            </tr>
                            <tr>
                                <td><strong>IV Infusion (High-Efficacy)</strong></td>
                                <td>Natalizumab (Tysabri), ocrelizumab (Ocrevus), alemtuzumab (Lemtrada)</td>
                                <td>VLA-4 antagonist, anti-CD20 B-cell depletion, anti-CD52 T-cell depletion</td>
                                <td><strong>Natalizumab:</strong> ~90% relapse reduction; used for aggressive RRMS or after DMT failure. <strong>Ocrelizumab:</strong> ~50-60% reduction, also effective in PPMS (unique). <strong>Alemtuzumab:</strong> ~70% reduction; intense induction, long remission potential.</td>
                                <td>Natalizumab: PML risk (especially JC virus+, on therapy >2 yrs; ~4 per 1000 JCV+). Ocrelizumab: infection risk, infusion reactions. Alemtuzumab: severe autoimmunity risk (thyroid, ITP, AIHA), requires monitoring Q3mo.</td>
                            </tr>
                            <tr>
                                <td><strong>Immune Reconstitution (Hematopoietic Stem Cell Transplantation—HSCT)</strong></td>
                                <td>Autologous HSCT</td>
                                <td>Myeloablation + stem cell rescue; resets immune system</td>
                                <td>Dramatic effect in highly aggressive RRMS/early SPMS; sustained remission in ~40-60%. High risk/high reward; reserved for aggressive disease.</td>
                                <td>Treatment toxicity (infections, secondary malignancy risk), mortality 1-3%. Requires extensive workup, intense supportive care.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> Modern MS treatment paradigm emphasizes early, aggressive therapy ("hit early, hit hard") in RRMS to prevent disability accumulation. High-efficacy agents increasingly used upfront in aggressive disease, shifting away from step-wise approach. Monitoring for DMT-specific complications (especially PML with natalizumab, autoimmunity with alemtuzumab) is essential.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Neuromyelitis Optica Spectrum Disorder (NMOSD) vs MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>MS</th>
                                <th>NMOSD</th>
                            </tr>
                            <tr>
                                <td><strong>Demographics</strong></td>
                                <td>Caucasian, age 20-40</td>
                                <td>Female-predominant, non-Caucasian (African, Asian), older age at onset</td>
                            </tr>
                            <tr>
                                <td><strong>Clinical Attacks</strong></td>
                                <td>Varied locations (ON, spinal, brainstem, multifocal)</td>
                                <td>Bilateral optic neuritis (ON) and longitudinally extensive transverse myelitis (LETM) are hallmark; area postrema syndrome (hiccups, vomiting) characteristic</td>
                            </tr>
                            <tr>
                                <td><strong>MRI Spine</strong></td>
                                <td>Short lesions (≤2 vertebral segments)</td>
                                <td>Longitudinally extensive lesions (≥3 vertebral segments, often spanning entire cord)</td>
                            </tr>
                            <tr>
                                <td><strong>Brain MRI</strong></td>
                                <td>Multiple white matter lesions, often periventricular</td>
                                <td>Often normal or minimal; brainstem/diencephalic lesions if present</td>
                            </tr>
                            <tr>
                                <td><strong>CSF</strong></td>
                                <td>Oligoclonal bands (OCBs) common</td>
                                <td>OCBs rare; pleocytosis may be higher (>50 WBC common in attacks)</td>
                            </tr>
                            <tr>
                                <td><strong>Aquaporin-4 (AQP4-IgG)</strong></td>
                                <td>Negative</td>
                                <td>Positive in ~80% (AQP4-IgG seropositive NMOSD); seronegative NMOSD exists (~20%, usually MOG-antibody associated)</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>DMTs (IFN, fingolimod, natalizumab, etc.)</td>
                                <td>Avoid IFN (may worsen); immunosuppression key (azathioprine, mycophenolate, rituximab, complement inhibitor eculizumab for AQP4-IgG+). Acute attacks: high-dose IV corticosteroids + PLEX.</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis</strong></td>
                                <td>Variable; slow disability accumulation</td>
                                <td>Generally worse; permanent visual loss, paraparesis common after attacks; however, newer targeted therapies improving outcomes</td>
                            </tr>
                        </table>

                        <p><strong>Area Postrema Syndrome (APS) in NMOSD:</strong> Intractable hiccups, nausea, vomiting from lesions in brainstem area postrema. Highly specific for NMOSD (rarely seen in MS). Often precedes more widespread neurologic symptoms by days/weeks. Warrant urgent neuroimaging and AQP4-IgG testing.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ NMOSD Diagnostic Criteria (2015 Revised)</div>
                            <p>Presence of AQP4-IgG (seropositive form) + at least 1 core clinical characteristic (ON, LETM, area postrema syndrome, acute brainstem syndrome, symptomatic narcolepsy, symptomatic acute diencephalic/optic pathway syndrome). OR seronegative: ≥2 core characteristics in different attacks + brain MRI normal + spinal cord MRI with ≥3 contiguous segments of T2 signal abnormality + CSF pleocytosis (recommended).</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 6 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q6: A 28-year-old woman presents with acute bilateral vision loss and MRI shows bilateral optic nerve T2 hyperintensity. Spine MRI reveals an 8-cm longitudinally extensive T2 signal abnormality spanning C1-T5 with central canal involvement. Serum and CSF AQP4-IgG testing is positive. What is the most important management distinction from MS?</div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="a"> A) Start interferon-beta as first-line DMT, as it is highly effective in NMOSD
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="b"> B) AVOID interferon-beta; use intensive immunosuppression (mycophenolate, azathioprine) or complement inhibitor (eculizumab) for long-term prevention. For acute attack: high-dose IV corticosteroids + plasma exchange.
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="c"> C) Prognosis is identical to MS; start standard MS DMT and monitor closely
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="d"> D) No treatment needed; bilateral ON and LETM are self-limited complications
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q6')">Show Answer</button>
                        <div id="q6-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation (bilateral ON + LETM) combined with positive AQP4-IgG is diagnostic for NMOSD. A critical distinction from MS is that interferon-beta and some other MS DMTs are contraindicated and may worsen NMOSD. Instead, intensive immunosuppression or complement inhibition is the cornerstone of therapy. Acute attacks require aggressive treatment (high-dose IV steroids, plasma exchange) to minimize permanent disability. The longitudinally extensive spinal cord lesion (8 cm, >3 segments) is characteristic of NMOSD, not typical MS. Prognosis requires different management to prevent vision loss and paralysis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> 2017 McDonald Criteria for MS. Thompson AJ et al. <em>Lancet Neurol</em>. 2018;17:162-173.</li>
                        <li><span class="ref-guideline">[G2]</span> International Consensus Criteria for NMOSD. Wingerchuk DM et al. <em>Neurology</em>. 2015;85:177-189.</li>
                        <li><span class="ref-guideline">[G3]</span> AAN DMT Guidelines for MS. Rae-Grant A et al. <em>Neurology</em>. 2018;90:777-788.</li>
                        <li><span class="ref-trial">[T]</span> <strong>OPERA I & II (Ocrelizumab):</strong> Hauser SL et al. <em>NEJM</em> 2017;376:221-34. Anti-CD20 vs IFN-beta-1a in RRMS: 46-47% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ORATORIO (Ocrelizumab PPMS):</strong> Montalban X et al. <em>NEJM</em> 2017;376:209-20. Only approved DMT for PPMS.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ASCLEPIOS (Ofatumumab):</strong> Hauser SL et al. <em>NEJM</em> 2020;383:546-57. SC anti-CD20 vs teriflunomide: 51-59% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREVENT (Eculizumab NMOSD):</strong> Pittock SJ et al. <em>NEJM</em> 2019;381:614-25. 94% relapse reduction in AQP4+ NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>N-MOmentum (Inebilizumab):</strong> Cree BAC et al. <em>Lancet</em> 2019;394:1352-63. 73% ARR reduction in NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SAkuraStar (Satralizumab):</strong> Traboulsee A et al. <em>Lancet Neurol</em> 2020;19:402-12. Anti-IL6R in NMOSD.</li>
                        <li>[R] Filippi M et al. Multiple sclerosis. <em>Nat Rev Dis Primers</em>. 2018;4:43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 10: Neuromuscular Disorders -->
            <section id="section-7" class="section">
                <h1 class="section-title">7. CNS Infections</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Bacterial Meningitis: Etiology by Age & Empiric Treatment</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Age Group</th>
                                <th>Most Common Organisms</th>
                                <th>Empiric Antibiotics</th>
                            </tr>
                            <tr>
                                <td><strong>Neonates (0-30 days)</strong></td>
                                <td>Group B Strep, E. coli K1, Listeria monocytogenes</td>
                                <td>Ampicillin 2g Q4H + ceftazidime 2g Q8H (or gentamicin)</td>
                            </tr>
                            <tr>
                                <td><strong>Infants/Children (1 mo-18 yrs)</strong></td>
                                <td>Streptococcus pneumoniae, Neisseria meningitidis, H. influenzae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Adults (18-50 yrs)</strong></td>
                                <td>N. meningitidis, S. pneumoniae</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin 15-20 mg/kg Q6-8H</td>
                            </tr>
                            <tr>
                                <td><strong>Older Adults (>50 yrs)</strong></td>
                                <td>S. pneumoniae, Listeria, Gram-negative rods</td>
                                <td>Ceftriaxone 2g Q12H + vancomycin + ampicillin 2g Q4H</td>
                            </tr>
                            <tr>
                                <td><strong>Immunocompromised</strong></td>
                                <td>Listeria, Gram-negative rods, Cryptococcus, Mycobacterium</td>
                                <td>Add ampicillin to coverage; consider TMP-SMX for Listeria alternative</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Critical Management: Dexamethasone Timing</div>
                            <p>Dexamethasone 10 mg IV must be given <strong>BEFORE OR WITH first antibiotic dose</strong> to reduce neurologic complications (especially in pneumococcal meningitis). Give Q6H x 4 days. If given after antibiotics, efficacy diminished. Improves outcomes in ~30% of cases.</p>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>CSF Analysis: Bacterial vs Viral vs TB vs Fungal</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Parameter</th>
                                <th>Bacterial</th>
                                <th>Viral</th>
                                <th>TB</th>
                                <th>Fungal</th>
                            </tr>
                            <tr>
                                <td><strong>Appearance</strong></td>
                                <td>Turbid/purulent</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                                <td>Clear/slightly turbid</td>
                            </tr>
                            <tr>
                                <td><strong>Pressure</strong></td>
                                <td>Usually elevated (>400 mm H2O)</td>
                                <td>Normal-mildly elevated</td>
                                <td>Mildly-moderately elevated</td>
                                <td>Often elevated (100-500+)</td>
                            </tr>
                            <tr>
                                <td><strong>WBC (cells/µL)</strong></td>
                                <td>500-20,000+ (PMN predominant)</td>
                                <td>10-500 (lymph predominant early, then lymph)</td>
                                <td>100-500 (lymph predominant)</td>
                                <td>50-500 (lymph predominant)</td>
                            </tr>
                            <tr>
                                <td><strong>Protein</strong></td>
                                <td>>100 mg/dL (often 200-500)</td>
                                <td>Normal-mildly elevated (50-100)</td>
                                <td>100-500+ (often high)</td>
                                <td>100-500+ (often high)</td>
                            </tr>
                            <tr>
                                <td><strong>Glucose (CSF:serum ratio)</strong></td>
                                <td><40 mg/dL or <40% of serum</td>
                                <td>Normal (50-80% of serum)</td>
                                <td><40 mg/dL or <40% (low ratio key)</td>
                                <td>Low-normal (variable)</td>
                            </tr>
                            <tr>
                                <td><strong>Gram Stain</strong></td>
                                <td>Positive 60-90%</td>
                                <td>Negative</td>
                                <td>Negative (AFB for TB)</td>
                                <td>Negative (India ink for Cryptococcus)</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> The combination of <strong>low CSF glucose + high protein + lymphocytic predominance</strong> is classic for TB meningitis. Delayed diagnosis is common; maintain high suspicion in at-risk patients (immunocompromised, endemic areas). Start anti-TB therapy empirically if TB meningitis suspected, even before confirmatory test results.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>HSV Encephalitis & Autoimmune Encephalitis</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>Herpes Simplex Virus (HSV) Encephalitis:</strong> Most common cause of sporadic viral encephalitis. Presents with fever, altered consciousness, behavioral changes, seizures, focal neurologic signs (temporal lobe involvement common). CSF: lymphocytic pleocytosis, elevated protein, normal glucose (variable). <em>MRI:</em> T2/FLAIR hyperintensity in temporal lobes, orbitofrontal, insular regions. <em>EEG:</em> Periodic sharp wave complexes in temporal regions (PLEDS—periodic lateralizing epileptiform discharges). <em>Treatment:</em> <strong>Start acyclovir 10-15 mg/kg IV Q8H immediately upon suspicion (do NOT wait for LP or EEG)</strong>. Continue 10-14 days. PCR of CSF for HSV is gold standard (90%+ sensitivity), but treatment must start empirically. Early treatment crucial for prognosis; delays lead to permanent sequelae (cognitive impairment, seizures, personality change).</p>

                        <p><strong>Autoimmune Encephalitis (NMDAR-IgG, AMPAR-IgG, GABA-B-IgG, etc.):</strong> Increasingly recognized, especially in young patients with behavioral changes, psychosis, seizures, movement disorders. CSF shows lymphocytic pleocytosis, elevated protein. Brain MRI often normal or shows nonspecific changes. <em>Diagnosis:</em> CSF/serum antibody testing (NMDAR most common; can be seronegative 10-20%). <em>Treatment:</em> Immunotherapy is cornerstone: IVIG 2 g/kg over 3-5 days, plasma exchange, or both. Corticosteroids (methylprednisolone 1g daily x 3-5 days, then taper). Second-line: rituximab, cyclophosphamide for severe/refractory cases. Screen for underlying malignancy (ovarian teratomas in NMDAR encephalitis, lung cancer in others).</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>TB Meningitis & Cryptococcal Meningitis in HIV</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>TB Meningitis:</strong> Diagnosis: acid-fast bacilli (AFB) stain of CSF (low sensitivity ~10%), TB culture (gold standard but takes 2-6 weeks), TB PCR/GeneXpert MTB/RIF (higher sensitivity, faster). CSF shows low glucose + high protein. <em>Treatment:</em> 12-month regimen: (1) Intensive phase (2 months): isoniazid, rifampin, pyrazinamide, ethambutol, plus streptomycin. (2) Continuation phase (10 months): isoniazid + rifampin. <strong>Corticosteroids essential:</strong> Dexamethasone 0.3-0.4 mg/kg Q6H x 3 weeks, then taper. Dramatically improves outcomes. Adjunctive vitamin B6 (pyridoxine) for isoniazid neuropathy prevention.</p>

                        <p><strong>Cryptococcal Meningitis (CrAg-positive HIV/AIDS):</strong> <em>Diagnosis:</em> Serum/CSF CrAg antigen testing (>95% sensitive in CSF), India ink stain (40-50% sensitive), fungal culture. <em>Treatment (dual phases):</em></p>
                        <ul class="list-item">
                            <li><strong>Induction phase (2 weeks):</strong> Amphotericin B 0.7-1 mg/kg IV daily + flucytosine 25 mg/kg Q6H (if available/tolerated)</li>
                            <li><strong>Consolidation phase (8 weeks):</strong> Fluconazole 400 mg daily</li>
                            <li><strong>Maintenance phase:</strong> Fluconazole 200 mg daily indefinitely (until CD4 >100-200 for ≥3 months on ART)</li>
                        </ul>
                        <p><em>Adjunctive management:</em> CSF drainage/shunt if severe elevated ICP or symptomatic hydrocephalus. Avoid excessive fluid resuscitation (increases ICP). Corticosteroids controversial; may be considered if severe inflammation.</p>
                    </div>
                </div>

                <!-- Practice Question 5 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q5: A 24-year-old woman with AIDS (CD4 28 cells/µL) presents with subacute headache, fever, and neck stiffness. LP shows CSF: 80 WBC (predominantly lymphocytes), protein 110 mg/dL, glucose 42 mg/dL (serum 92). Serum CrAg is positive. CSF India ink stain is negative. What is the most important initial management step?</div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="a"> A) Start fluconazole 400 mg PO daily pending cultures; recheck LP in 1 week
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="b"> B) Start IV amphotericin B 0.7-1 mg/kg daily + flucytosine 25 mg/kg Q6H for induction therapy; manage ICP with CSF drainage if needed
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="c"> C) Start ceftriaxone + vancomycin empirically; obtain repeat cultures to confirm organism
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q5" value="d"> D) Initiate TB treatment immediately; TB meningitis most likely given low CSF glucose
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q5')">Show Answer</button>
                        <div id="q5-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The positive serum CrAg in an AIDS patient with meningitis is diagnostic for cryptococcal meningitis. Although CSF India ink is negative, the CrAg and clinical presentation confirm the diagnosis. Induction therapy with IV amphotericin B + flucytosine is the standard of care and offers superior outcomes compared to fluconazole monotherapy. ICP management is critical in cryptococcal meningitis due to high opening pressures; CSF drainage via LP or EVD may be necessary. Option A (fluconazole monotherapy) is suboptimal for induction. Options C and D are incorrect diagnoses given the positive CrAg.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> IDSA Practice Guidelines for Bacterial Meningitis. Tunkel AR et al. <em>Clin Infect Dis</em>. 2004;39:1267-84. Updated 2017.</li>
                        <li><span class="ref-guideline">[G2]</span> IDSA Guidelines for Cryptococcal Disease. Perfect JR et al. <em>Clin Infect Dis</em>. 2010;50:291-322.</li>
                        <li><span class="ref-guideline">[G3]</span> WHO Guidelines: Cryptococcal Disease in HIV-infected Adults. 2018.</li>
                        <li><span class="ref-trial">[T]</span> <strong>de Gans Trial:</strong> de Gans J, van de Beek D. <em>NEJM</em> 2002;347:1549-56. Dexamethasone reduced mortality in <em>S. pneumoniae</em> meningitis (7% vs 15%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>Thwaites Trial:</strong> Thwaites GE et al. <em>NEJM</em> 2004;351:1741-51. Dexamethasone in TBM reduced mortality (32% vs 41%).</li>
                        <li><span class="ref-trial">[T]</span> <strong>AMBITION:</strong> Jarvis JN et al. <em>NEJM</em> 2022;386:1109-20. Single high-dose liposomal amphotericin B simplified cryptococcal treatment.</li>
                        <li>[R] van de Beek D et al. Community-acquired bacterial meningitis. <em>Nat Rev Dis Primers</em>. 2016;2:16074.</li>
                        <li>[R] Dalmau J et al. Anti-NMDA-receptor encephalitis. <em>Lancet Neurol</em>. 2008;7:1091-98.</li>
                        <li>[R] Thwaites GE et al. Tuberculous meningitis. <em>Nat Rev Neurol</em>. 2013;9:33-43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 9: Demyelinating Diseases -->
            <section id="section-9" class="section">
                <h1 class="section-title">9. Demyelinating Diseases</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Multiple Sclerosis: Subtypes & Diagnostic Criteria</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>MS Subtype</th>
                                <th>Course & Features</th>
                                <th>Frequency at Onset</th>
                                <th>Prognosis</th>
                            </tr>
                            <tr>
                                <td><strong>Relapsing-Remitting (RRMS)</strong></td>
                                <td>Distinct relapses with periods of remission/recovery. New or enlarging lesions on MRI between clinical events.</td>
                                <td>85% of MS presentations</td>
                                <td>~50% convert to SPMS by 10 years; highly variable</td>
                            </tr>
                            <tr>
                                <td><strong>Secondary Progressive (SPMS)</strong></td>
                                <td>Initial RRMS course followed by progressive worsening with or without superimposed relapses; declining remission quality</td>
                                <td>N/A (develops from RRMS)</td>
                                <td>Progressive disability; early/frequent relapses predict earlier conversion to SP</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive (PPMS)</strong></td>
                                <td>Progressive disability from onset without distinct relapses; slow, relentless accumulation of impairment</td>
                                <td>10-15% at onset</td>
                                <td>Worse prognosis; fewer effective DMT options historically; newer agents showing benefit</td>
                            </tr>
                            <tr>
                                <td><strong>Progressive-Relapsing (PRMS)</strong></td>
                                <td>Progressive from onset with superimposed relapses and inter-relapse progression</td>
                                <td>5% at onset</td>
                                <td>Aggressive course; rare in modern series with early DMT initiation</td>
                            </tr>
                        </table>

                        <p><strong>McDonald 2017 Criteria for MS Diagnosis:</strong> Requires dissemination in space (DIS) and time (DIT).</p>
                        <ul class="list-item">
                            <li><strong>DIS:</strong> ≥1 lesion in ≥2 CNS regions (periventricular, juxtacortical, infratentorial, spinal cord) on MRI</li>
                            <li><strong>DIT:</strong> Simultaneous presence of gadolinium-enhancing and non-enhancing lesions on brain MRI, OR new lesions on follow-up MRI (≥30 days from initial scan), OR CSF-specific oligoclonal bands + abnormal VEP</li>
                            <li><strong>Clinical events required:</strong> Can satisfy DIT with single clinical event if above imaging criteria met; two relapses + objective evidence suffices for diagnosis</li>
                        </ul>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ MS Presentations: Common Clinical Syndromes</div>
                            <ul class="list-item">
                                <li><strong>Optic Neuritis (ON):</strong> Unilateral vision loss, pain with eye movement, relative afferent pupillary defect (RAPD), normal appearing disc acutely or swollen. MRI shows T2 hyperintensity in optic nerve; brain MRI identifies clinically silent lesions (predicts future MS risk).</li>
                                <li><strong>Transverse Myelitis (TM):</strong> Bilateral motor/sensory deficits and sphincter dysfunction with clear spinal cord level. MRI shows T2 hyperintensity in cord; affects multiple segments (>2-3 vertebral levels).</li>
                                <li><strong>Internuclear Ophthalmoplegia (INO):</strong> Impaired adduction ipsilateral to lesion (medial longitudinal fasciculus—MLF), with preserved convergence. Bilateral INO in young patients is highly suggestive of MS.</li>
                                <li><strong>Lhermitte sign:</strong> Electric shock-like sensation down spine with neck flexion; indicates cervical demyelination.</li>
                                <li><strong>Uhthoff phenomenon:</strong> Transient worsening of symptoms with heat/exercise; due to impaired conduction in demyelinated axons.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Disease-Modifying Therapies (DMTs) for MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>DMT Category</th>
                                <th>Agents</th>
                                <th>Mechanism</th>
                                <th>Efficacy & Use</th>
                                <th>Key Monitoring/SE</th>
                            </tr>
                            <tr>
                                <td><strong>Injectable (First-Line)</strong></td>
                                <td>Interferon-beta (IFN-β-1a, IFN-β-1b), glatiramer acetate</td>
                                <td>Immune modulation; unclear exact mechanism</td>
                                <td>Moderate efficacy; reduce relapses ~30%. Well-tolerated, established safety. First-line option especially in early/mild RRMS.</td>
                                <td>IFN: flu-like symptoms, depression risk (screen). GA: local injection reactions. Monthly monitoring labs initially.</td>
                            </tr>
                            <tr>
                                <td><strong>Oral Moderate (1st-2nd Line)</strong></td>
                                <td>Fingolimod, teriflunomide, dimethyl fumarate</td>
                                <td>S1P modulators, DHFR inhibitors, NRF2 activators</td>
                                <td>Moderate-high efficacy (20-50% relapse reduction vs placebo). Convenient oral dosing. Used in RRMS, early aggressive disease.</td>
                                <td>Fingolimod: heart rate monitoring (first dose), opportunistic infection risk (VZV, CMV, PML rare). Teriflunomide: hepatotoxicity, teratogen. DMF: flushing, GI upset, PML risk (rare, esp. if immunosuppressed).</td>
                            </tr>
                            <tr>
                                <td><strong>Oral High-Efficacy</strong></td>
                                <td>Cladribine (Mavenclad), siponimod</td>
                                <td>Lymphocyte depletion, S1P modulation</td>
                                <td>High efficacy (~60% relapse reduction). Used in aggressive RRMS, early conversion-risk disease. Siponimod effective in SPMS.</td>
                                <td>Cladribine: teratogenic, myelosuppression, infection risk, requires monitoring. Siponimod: similar to fingolimod (first-dose monitoring, infection risk).</td>
                            </tr>
                            <tr>
                                <td><strong>IV Infusion (High-Efficacy)</strong></td>
                                <td>Natalizumab (Tysabri), ocrelizumab (Ocrevus), alemtuzumab (Lemtrada)</td>
                                <td>VLA-4 antagonist, anti-CD20 B-cell depletion, anti-CD52 T-cell depletion</td>
                                <td><strong>Natalizumab:</strong> ~90% relapse reduction; used for aggressive RRMS or after DMT failure. <strong>Ocrelizumab:</strong> ~50-60% reduction, also effective in PPMS (unique). <strong>Alemtuzumab:</strong> ~70% reduction; intense induction, long remission potential.</td>
                                <td>Natalizumab: PML risk (especially JC virus+, on therapy >2 yrs; ~4 per 1000 JCV+). Ocrelizumab: infection risk, infusion reactions. Alemtuzumab: severe autoimmunity risk (thyroid, ITP, AIHA), requires monitoring Q3mo.</td>
                            </tr>
                            <tr>
                                <td><strong>Immune Reconstitution (Hematopoietic Stem Cell Transplantation—HSCT)</strong></td>
                                <td>Autologous HSCT</td>
                                <td>Myeloablation + stem cell rescue; resets immune system</td>
                                <td>Dramatic effect in highly aggressive RRMS/early SPMS; sustained remission in ~40-60%. High risk/high reward; reserved for aggressive disease.</td>
                                <td>Treatment toxicity (infections, secondary malignancy risk), mortality 1-3%. Requires extensive workup, intense supportive care.</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl:</strong> Modern MS treatment paradigm emphasizes early, aggressive therapy ("hit early, hit hard") in RRMS to prevent disability accumulation. High-efficacy agents increasingly used upfront in aggressive disease, shifting away from step-wise approach. Monitoring for DMT-specific complications (especially PML with natalizumab, autoimmunity with alemtuzumab) is essential.
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Neuromyelitis Optica Spectrum Disorder (NMOSD) vs MS</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>MS</th>
                                <th>NMOSD</th>
                            </tr>
                            <tr>
                                <td><strong>Demographics</strong></td>
                                <td>Caucasian, age 20-40</td>
                                <td>Female-predominant, non-Caucasian (African, Asian), older age at onset</td>
                            </tr>
                            <tr>
                                <td><strong>Clinical Attacks</strong></td>
                                <td>Varied locations (ON, spinal, brainstem, multifocal)</td>
                                <td>Bilateral optic neuritis (ON) and longitudinally extensive transverse myelitis (LETM) are hallmark; area postrema syndrome (hiccups, vomiting) characteristic</td>
                            </tr>
                            <tr>
                                <td><strong>MRI Spine</strong></td>
                                <td>Short lesions (≤2 vertebral segments)</td>
                                <td>Longitudinally extensive lesions (≥3 vertebral segments, often spanning entire cord)</td>
                            </tr>
                            <tr>
                                <td><strong>Brain MRI</strong></td>
                                <td>Multiple white matter lesions, often periventricular</td>
                                <td>Often normal or minimal; brainstem/diencephalic lesions if present</td>
                            </tr>
                            <tr>
                                <td><strong>CSF</strong></td>
                                <td>Oligoclonal bands (OCBs) common</td>
                                <td>OCBs rare; pleocytosis may be higher (>50 WBC common in attacks)</td>
                            </tr>
                            <tr>
                                <td><strong>Aquaporin-4 (AQP4-IgG)</strong></td>
                                <td>Negative</td>
                                <td>Positive in ~80% (AQP4-IgG seropositive NMOSD); seronegative NMOSD exists (~20%, usually MOG-antibody associated)</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>DMTs (IFN, fingolimod, natalizumab, etc.)</td>
                                <td>Avoid IFN (may worsen); immunosuppression key (azathioprine, mycophenolate, rituximab, complement inhibitor eculizumab for AQP4-IgG+). Acute attacks: high-dose IV corticosteroids + PLEX.</td>
                            </tr>
                            <tr>
                                <td><strong>Prognosis</strong></td>
                                <td>Variable; slow disability accumulation</td>
                                <td>Generally worse; permanent visual loss, paraparesis common after attacks; however, newer targeted therapies improving outcomes</td>
                            </tr>
                        </table>

                        <p><strong>Area Postrema Syndrome (APS) in NMOSD:</strong> Intractable hiccups, nausea, vomiting from lesions in brainstem area postrema. Highly specific for NMOSD (rarely seen in MS). Often precedes more widespread neurologic symptoms by days/weeks. Warrant urgent neuroimaging and AQP4-IgG testing.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ NMOSD Diagnostic Criteria (2015 Revised)</div>
                            <p>Presence of AQP4-IgG (seropositive form) + at least 1 core clinical characteristic (ON, LETM, area postrema syndrome, acute brainstem syndrome, symptomatic narcolepsy, symptomatic acute diencephalic/optic pathway syndrome). OR seronegative: ≥2 core characteristics in different attacks + brain MRI normal + spinal cord MRI with ≥3 contiguous segments of T2 signal abnormality + CSF pleocytosis (recommended).</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 6 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q6: A 28-year-old woman presents with acute bilateral vision loss and MRI shows bilateral optic nerve T2 hyperintensity. Spine MRI reveals an 8-cm longitudinally extensive T2 signal abnormality spanning C1-T5 with central canal involvement. Serum and CSF AQP4-IgG testing is positive. What is the most important management distinction from MS?</div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="a"> A) Start interferon-beta as first-line DMT, as it is highly effective in NMOSD
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="b"> B) AVOID interferon-beta; use intensive immunosuppression (mycophenolate, azathioprine) or complement inhibitor (eculizumab) for long-term prevention. For acute attack: high-dose IV corticosteroids + plasma exchange.
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="c"> C) Prognosis is identical to MS; start standard MS DMT and monitor closely
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q6" value="d"> D) No treatment needed; bilateral ON and LETM are self-limited complications
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q6')">Show Answer</button>
                        <div id="q6-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical presentation (bilateral ON + LETM) combined with positive AQP4-IgG is diagnostic for NMOSD. A critical distinction from MS is that interferon-beta and some other MS DMTs are contraindicated and may worsen NMOSD. Instead, intensive immunosuppression or complement inhibition is the cornerstone of therapy. Acute attacks require aggressive treatment (high-dose IV steroids, plasma exchange) to minimize permanent disability. The longitudinally extensive spinal cord lesion (8 cm, >3 segments) is characteristic of NMOSD, not typical MS. Prognosis requires different management to prevent vision loss and paralysis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> 2017 McDonald Criteria for MS. Thompson AJ et al. <em>Lancet Neurol</em>. 2018;17:162-173.</li>
                        <li><span class="ref-guideline">[G2]</span> International Consensus Criteria for NMOSD. Wingerchuk DM et al. <em>Neurology</em>. 2015;85:177-189.</li>
                        <li><span class="ref-guideline">[G3]</span> AAN DMT Guidelines for MS. Rae-Grant A et al. <em>Neurology</em>. 2018;90:777-788.</li>
                        <li><span class="ref-trial">[T]</span> <strong>OPERA I & II (Ocrelizumab):</strong> Hauser SL et al. <em>NEJM</em> 2017;376:221-34. Anti-CD20 vs IFN-beta-1a in RRMS: 46-47% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ORATORIO (Ocrelizumab PPMS):</strong> Montalban X et al. <em>NEJM</em> 2017;376:209-20. Only approved DMT for PPMS.</li>
                        <li><span class="ref-trial">[T]</span> <strong>ASCLEPIOS (Ofatumumab):</strong> Hauser SL et al. <em>NEJM</em> 2020;383:546-57. SC anti-CD20 vs teriflunomide: 51-59% lower ARR.</li>
                        <li><span class="ref-trial">[T]</span> <strong>PREVENT (Eculizumab NMOSD):</strong> Pittock SJ et al. <em>NEJM</em> 2019;381:614-25. 94% relapse reduction in AQP4+ NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>N-MOmentum (Inebilizumab):</strong> Cree BAC et al. <em>Lancet</em> 2019;394:1352-63. 73% ARR reduction in NMOSD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>SAkuraStar (Satralizumab):</strong> Traboulsee A et al. <em>Lancet Neurol</em> 2020;19:402-12. Anti-IL6R in NMOSD.</li>
                        <li>[R] Filippi M et al. Multiple sclerosis. <em>Nat Rev Dis Primers</em>. 2018;4:43.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 10: Neuromuscular Disorders -->
            <section id="section-8" class="section">
                <h1 class="section-title">8. Dementia and Cognitive Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Reversible Causes of Cognitive Decline</span>
                    </div>
                    <div class="subsection-content">
                        <div class="clinical-pearl">
                            <strong>Reversible Causes (10-15% of dementia cases):</strong> Always screen for: vitamin B12 deficiency, hypothyroidism, depression (pseudodementia), normal-pressure hydrocephalus (NPH), subdural hematoma, medication side effects (benzodiazepines, anticholinergics, opioids, sedating antihistamines). Reversibility varies; some improve partially with treatment (NPH with shunt, B12 repletion in early deficiency).
                        </div>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Major Dementia Syndromes: Pathology & Biomarkers</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Dementia Type</th>
                                <th>Pathology</th>
                                <th>Clinical Features</th>
                                <th>Biomarkers</th>
                                <th>Treatment</th>
                            </tr>
                            <tr>
                                <td><strong>Alzheimer's Disease (AD)</strong></td>
                                <td>Amyloid-β plaques + tau tangles</td>
                                <td>Insidious memory loss (episodic early), progressive cognitive decline, preserved motor function until late stage. Behavioral/personality changes common.</td>
                                <td>CSF: ↓Aβ42, ↑p-tau, ↑t-tau. PET amyloid/tau positive. MRI: hippocampal atrophy early.</td>
                                <td>Cholinesterase inhibitors (donepezil 10 mg daily, rivastigmine, galantamine); NMDA antagonist memantine 20 mg daily. NEW: Aducanumab (anti-Aβ mAb), lecanemab (anti-Aβ protofibrils) shown to slow cognitive decline by ~35% if early amyloid pathology. Cognitive rehabilitation, safety precautions.</td>
                            </tr>
                            <tr>
                                <td><strong>Vascular Dementia (VaD)</strong></td>
                                <td>Cerebral infarcts, white matter disease, subcortical ischemia</td>
                                <td>Stepwise cognitive decline (vs insidious AD), executive dysfunction prominent, gait disturbance, mood/personality changes. History of stroke or TIA.</td>
                                <td>MRI shows multiple lacunar infarcts, white matter hyperintensities. Neuroimaging correlates with dementia severity.</td>
                                <td>Stroke prevention: aggressive HTN control, antiplatelet (aspirin), statin, lifestyle modification. Cholinesterase inhibitors may provide modest benefit. Treat vascular risk factors aggressively.</td>
                            </tr>
                            <tr>
                                <td><strong>Dementia with Lewy Bodies (DLB)</strong></td>
                                <td>Alpha-synuclein deposits (Lewy bodies)</td>
                                <td>Cognitive decline early (often before/concurrent with motor symptoms—distinguishes from PD-dementia). Visual hallucinations (animated, detailed, non-threatening). Parkinsonism. RBD common. Autonomic dysfunction (orthostasis, syncope). Sensitivity to antipsychotics (caution).</td>
                                <td>123I-MIBG cardiac imaging may show reduced uptake. CSF: ↓Aβ42, normal-mildly elevated p-tau. Amyloid/tau PET variable.</td>
                                <td>Avoid antipsychotics (can precipitate severe parkinsonism/NMS). Rivastigmine preferred (may improve visual hallucinations and apathy). Memantine less evidence. Levodopa for motor symptoms. Clozapine if antipsychotic absolutely necessary.</td>
                            </tr>
                            <tr>
                                <td><strong>Behavioral Variant Frontotemporal Dementia (bvFTD)</strong></td>
                                <td>Tau, TDP-43, or FUS inclusions (frontotemporal pathology)</td>
                                <td>Behavioral/personality changes prominent (apathy, disinhibition, compulsions, impulsivity). Memory relatively spared early. Executive dysfunction. Young age of onset (40-60 yrs). Inappropriate social behavior.</td>
                                <td>MRI: frontal/anterior temporal atrophy. Hypometabolism on FDG-PET in frontal/temporal lobes. Genetic testing (C9orf72, GRN, MAPT mutations in 30-40%).</td>
                                <td>No specific disease-modifying treatment. SSRIs for behavioral/apathy symptoms. Supportive care, behavioral management. Genetic counseling if familial. Some targeting tau pathology emerging.</td>
                            </tr>
                            <tr>
                                <td><strong>Primary Progressive Aphasia (PPA)</strong></td>
                                <td>Language dominant FTD variants; TDP-43 or tau pathology</td>
                                <td>Three subtypes: nonfluent/agrammatic (speech apraxia, agrammatism), semantic (anomia, semantic knowledge loss), logopenic (word-finding, repetition problems). Memory/visuospatial relatively preserved early.</td>
                                <td>MRI shows left-dominant temporal/inferior frontal atrophy. PET hypometabolism correlates with clinical variant.</td>
                                <td>Speech therapy mainstay. Limited pharmacologic benefit. Identify underlying pathology (tau vs TDP-43) important for prognosis and emerging targeted therapies.</td>
                            </tr>
                            <tr>
                                <td><strong>Creutzfeldt-Jakob Disease (CJD)</strong></td>
                                <td>Prion protein deposits; spongiform degeneration</td>
                                <td>Rapidly progressive dementia + myoclonus/ataxia/parkinsonism/visual symptoms. Sporadic form: age >60, median survival 6-12 months. Familial form slower (~2 years). Variant CJD (vCJD from BSE): psychiatric/sensory symptoms prominent early, young age.</td>
                                <td>MRI: typical "pulvinar sign" (T2/FLAIR hyperintensity in pulvinar/thalamus), cortical ribboning in sporadic form. CSF 14-3-3 protein or RT-QuIC (real-time quaking-induced conversion assay, very high sensitivity). EEG: periodic sharp wave complexes.</td>
                                <td>No cure. Supportive care. Palliative symptom management. Strict infection control (spongiform encephalopathies transmissible via contaminated instruments). Very poor prognosis; death within 1-2 years typical in sporadic form.</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Lecanemab (Leqembi) - Anti-Aβ Monoclonal Antibody</div>
                            <p>FDA-approved for early AD (MCI/mild dementia stage with amyloid pathology confirmed). IV infusion every 2 weeks; high amyloid-related imaging abnormalities (ARIA) risk requiring baseline and follow-up MRI. ~35% slowing of cognitive decline over 18 months vs placebo (modest but clinically meaningful). Requires amyloid biomarker confirmation (PET, CSF, or blood phospho-tau/Aβ). Not curative; delays progression.</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 8 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q8: A 58-year-old male presents with 1-year progressive cognitive decline dominated by behavioral changes: apathy, impulsive spending, inappropriate social disinhibition. Memory is relatively preserved. MRI shows frontal and anterior temporal lobe atrophy. What is the most likely diagnosis?</div>
                        <div class="question-option">
                            <input type="radio" name="q8" value="a"> A) Alzheimer's disease with atypical presentation
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q8" value="b"> B) Behavioral variant frontotemporal dementia (bvFTD)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q8" value="c"> C) Vascular dementia from small vessel disease
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q8" value="d"> D) Dementia with Lewy bodies with prominent behavioral component
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q8')">Show Answer</button>
                        <div id="q8-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical syndrome is classic for bvFTD: behavioral/personality changes (apathy, impulsivity, disinhibition) dominating early course with relative preservation of memory, young-to-middle age of onset, and frontal/anterior temporal atrophy on MRI. AD typically presents with memory loss first, not behavioral changes. VaD shows stepwise decline with vascular risk factors. DLB would include visual hallucinations and parkinsonism as key features. Understanding the clinical syndrome and imaging distribution is critical for accurate dementia diagnosis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> NIA-AA Research Framework (ATN). Jack CR Jr et al. <em>Alzheimers Dement</em>. 2018;14:535-562.</li>
                        <li><span class="ref-guideline">[G2]</span> AAN Guideline: MCI. Petersen RC et al. <em>Neurology</em>. 2018;90:126-135.</li>
                        <li><span class="ref-guideline">[G3]</span> Diagnostic Criteria for Vascular Cognitive Disorders. Sachdev P et al. 2014.</li>
                        <li><span class="ref-trial">[T]</span> <strong>Clarity AD (Lecanemab):</strong> van Dyck CH et al. <em>NEJM</em> 2023;388:9-21. 27% slower decline in early AD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>TRAILBLAZER-ALZ 2 (Donanemab):</strong> Sims JR et al. <em>JAMA</em> 2023;330:512-27. 35% slower decline in early AD.</li>
                        <li><span class="ref-trial">[T]</span> <strong>EMERGE/ENGAGE (Aducanumab):</strong> Budd Haeberlein S et al. 2022. Controversial results.</li>
                        <li>[R] Rascovsky K et al. Criteria for bvFTD. <em>Brain</em>. 2011;134:2456-2477.</li>
                        <li>[R] Geschwind MD. Rapidly Progressive Dementia. <em>Continuum</em>. 2016;22:510-537.</li>
                        <li>[R] Relkin N et al. Diagnosing NPH. <em>Neurosurgery</em>. 2005;57:S4-16.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 12: Coma and Disorders of Consciousness -->
            <section id="section-9" class="section">
                <h1 class="section-title">9. Sleep Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Narcolepsy: Type 1 vs Type 2</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Feature</th>
                                <th>Narcolepsy Type 1 (NT1)</th>
                                <th>Narcolepsy Type 2 (NT2)</th>
                            </tr>
                            <tr>
                                <td><strong>Cataplexy</strong></td>
                                <td>Present (hallmark feature)</td>
                                <td>Absent</td>
                            </tr>
                            <tr>
                                <td><strong>Hypocretin (Orexin) in CSF</strong></td>
                                <td><110 pg/mL (low; pathognomonic)</td>
                                <td>Normal (>110 pg/mL)</td>
                            </tr>
                            <tr>
                                <td><strong>Sleep Latency Test (MSLT)</strong></td>
                                <td>Mean latency <8 min; ≥2 SOREMs in 4 naps</td>
                                <td>Mean latency <8 min; ≥2 SOREMs</td>
                            </tr>
                            <tr>
                                <td><strong>Prevalence</strong></td>
                                <td>~0.03-0.05% (1 in 2000-3000)</td>
                                <td>Less common; ratio NT1:NT2 ~2-3:1</td>
                            </tr>
                            <tr>
                                <td><strong>Treatment</strong></td>
                                <td>Stimulants (methylphenidate, amphetamine, modafinil); sodium oxybate for cataplexy; antidepressants (SSRIs/SNRIs) for cataplexy + REM phenomena</td>
                                <td>Stimulants primarily (less severe cataplexy to treat)</td>
                            </tr>
                        </table>

                        <p><strong>Clinical Features:</strong> Excessive daytime sleepiness (EDS), sleep attacks (irresistible sleep lasting seconds-minutes), fragmented nighttime sleep, hypnagogic/hypnopompic hallucinations, sleep paralysis. <em>Cataplexy in NT1:</em> Sudden loss of voluntary muscle tone triggered by emotion (laughter, surprise, anger), lasting seconds-minutes; consciousness preserved. Unique to NT1.</p>
                    </div>
                </div>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>REM Sleep Behavior Disorder & Restless Leg Syndrome</span>
                    </div>
                    <div class="subsection-content">
                        <p><strong>REM Sleep Behavior Disorder (RBD):</strong> Absence of normal REM sleep muscle atonia; patient acts out dreams (vocalizes, flails, kicks). Injury risk high (to self, bedpartner). <strong>Strong prodromal marker for alpha-synucleinopathy:</strong> >80% of RBD patients develop Parkinson's, DLB, or MSA within 10-20 years. Diagnosis via polysomnography (PSG): excessive chin EMG tone during REM, increased phasic EMG bursts. Treatment: clonazepam 0.5-2 mg before bed (first-line); melatonin 3-10 mg nightly (alternative). Behavioral measures: safe sleep environment (padded furniture, remove objects).</p>

                        <p><strong>Restless Leg Syndrome (RLS):</strong> Uncomfortable sensations in legs (tingling, creeping, aching) at rest, worse in evening/night; relieved by movement. Disrupts sleep onset/maintenance. Diagnosis clinical (no confirmatory test, though PSG may show periodic leg movements). <strong>Iron deficiency common underlying cause:</strong> check ferritin, iron saturation. <strong>First-line treatment:</strong> Gabapentin 300-3600 mg/day (FDA-approved for RLS) or pregabalin. Dopamine agonists (pramipexole, ropinirole) effective but risk of augmentation (worsening symptoms with continued use) if used long-term. <strong>Avoid SSRIs, stimulants, antihistamines</strong> (worsen RLS). <strong>Augmentation risk:</strong> If on dopamine agonists, dose escalation over time heralds augmentation; switch to non-dopaminergic agent (gabapentin/pregabalin) or add second agent.</p>
                    </div>
                </div>

                <!-- Practice Question 10 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q10: A 68-year-old man with Parkinson's disease presents with a 3-year history of violent nighttime behavior: shouting, flailing, kicking his wife during sleep. Polysomnography shows excessive chin EMG activity during REM sleep and loss of normal REM atonia. What is the clinical significance of this finding?</div>
                        <div class="question-option">
                            <input type="radio" name="q10" value="a"> A) This is a normal aging-related change requiring no intervention
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q10" value="b"> B) REM Sleep Behavior Disorder (RBD); strong indicator of underlying alpha-synucleinopathy (he already has PD, but RBD accelerates neurodegenerative progression)
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q10" value="c"> C) Uncontrolled Parkinson's disease symptoms; increase dopaminergic medication
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q10" value="d"> D) Sleep apnea requiring CPAP therapy
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q10')">Show Answer</button>
                        <div id="q10-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The PSG findings (loss of REM atonia with excessive chin EMG during REM, violent behavior acting out dreams) are diagnostic of RBD. While this patient already has PD (an alpha-synucleinopathy), RBD in patients with neurodegenerative disease indicates more extensive CNS pathology and may predict faster disease progression. RBD is a strong prodromal marker in non-PD patients (~80% develop alpha-synucleinopathy), but in someone with established PD, it signifies multi-system involvement. Management includes safety (clonazepam, melatonin) and recognition of increased risk for cognitive/autonomic decline.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> ICSD-3: International Classification of Sleep Disorders. 3rd ed. AASM. 2014.</li>
                        <li><span class="ref-guideline">[G2]</span> AAN Practice Parameters: Treatment of Narcolepsy. Morgenthaler TI et al. <em>Sleep</em>. 2007;30:1705-11.</li>
                        <li><span class="ref-guideline">[G3]</span> IRLSSG Consensus Guidelines for RLS. Garcia-Borreguero D et al. <em>Sleep Med</em>. 2016;21:1-11.</li>
                        <li><span class="ref-trial">[T]</span> <strong>TONES (Sodium Oxybate):</strong> Bogan RK et al. <em>Sleep</em> 2015;38:1123-31. Lower-sodium oxybate for narcolepsy.</li>
                        <li><span class="ref-trial">[T]</span> <strong>HARMONY (Pitolisant):</strong> Dauvilliers Y et al. <em>Lancet Neurol</em> 2013;12:1068-75. H3 inverse agonist for narcolepsy.</li>
                        <li>[R] Scammell TE. Narcolepsy. <em>NEJM</em> 2015;373:2654-62.</li>
                        <li>[R] Postuma RB et al. RBD predictors. <em>Brain</em>. 2019;142:744-59.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 14: Neuro-oncology -->
            <section id="section-10" class="section">
                <h1 class="section-title">10. Neuro-oncology</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Primary Brain Tumors: Classification & Management</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Tumor Type</th>
                                <th>Grade/Characteristics</th>
                                <th>Prognosis</th>
                                <th>Treatment</th>
                            </tr>
                            <tr>
                                <td><strong>Glioblastoma (GBM)</strong></td>
                                <td>WHO Grade IV; rapid growth, necrosis, vascular proliferation. Most common malignant brain tumor.</td>
                                <td>Median OS ~14-15 months with standard therapy; <2 years without treatment. MGMT methylation status important prognostic factor.</td>
                                <td>Surgery (maximal safe resection), radiation (60 Gy), chemotherapy (temozolomide). Adjuvant bevacizumab (anti-VEGF) in recurrent disease. Electrical tumor-treating fields (Novocure) approved as adjuvant.</td>
                            </tr>
                            <tr>
                                <td><strong>Astrocytoma (Grade II-III)</strong></td>
                                <td>Lower grades show slower growth; Grade III (anaplastic) more aggressive. IDH mutation status affects prognosis and treatment decisions.</td>
                                <td>Grade II: 5-10 year median survival. Grade III: 2-5 years. IDH-mutant tumors generally better prognosis.</td>
                                <td>Surgery + radiation ± chemotherapy. Grade III often treated similarly to GBM. Molecular testing (IDH, 1p/19q codeletion) guides therapy.</td>
                            </tr>
                            <tr>
                                <td><strong>Oligodendroglioma</strong></td>
                                <td>Often Grade II-III. 1p/19q codeletion highly favorable (responsive to chemotherapy). IDH1/2 mutations common.</td>
                                <td>1p/19q codeleted: median OS 10-15 years. Non-codeleted: shorter survival. 1p/19q codeletion most favorable prognostic marker in this tumor.</td>
                                <td>Surgery + radiation + chemotherapy (PCV or temozolomide) if high-grade or 1p/19q codeleted.</td>
                            </tr>
                            <tr>
                                <td><strong>Meningioma</strong></td>
                                <td>Grade I (benign, 80%), II (atypical, 15%), III (malignant, 5%). WHO 2021 classification updates grading.</td>
                                <td>Grade I: excellent prognosis; 5-year recurrence ~5%. Grade II: 5-year recurrence ~30%. Grade III: poor.</td>
                                <td>Surgery (gross total resection goal). Radiation for Grade II/III or recurrent Grade I. Chemotherapy reserved for Grade III or recurrent/unresectable.</td>
                            </tr>
                            <tr>
                                <td><strong>Primary CNS Lymphoma (PCNSL)</strong></td>
                                <td>Most are B-cell non-Hodgkin (usually diffuse large B-cell). Higher incidence in immunocompromised (AIDS, post-transplant).</td>
                                <td>Median OS 4-5 years in immunocompetent; worse in immunocompromised. Age, performance status, CNS involvement prognostic.</td>
                                <td>Chemotherapy (methotrexate-based regimens, intensive CNS-penetrating drugs). Whole-brain radiation added in many regimens but neurotoxicity risk in elderly. Monoclonal antibodies (rituximab) incorporated.</td>
                            </tr>
                            <tr>
                                <td><strong>Pituitary Adenoma</strong></td>
                                <td>Usually benign (WHO Grade I). Functional (prolactin, growth hormone, ACTH, TSH-secreting) or non-functional. Macroadenoma if >10mm.</td>
                                <td>Good with appropriate treatment; hormone-secreting tumors often respond to medical therapy. Visual prognosis depends on optic chiasm compression degree.</td>
                                <td>Functional: dopamine agonist (bromocriptine, cabergoline) or surgery. Macroadenomas with mass effect: consider surgery vs medical therapy. TSH/GH-secreting may require pituitary radiation if resistant to medical/surgical therapy.</td>
                            </tr>
                        </table>

                        <p><strong>Brain Metastases:</strong> Most common intracranial malignancy (more than all primary brain tumors combined). Sources: lung (40%), breast (15%), melanoma (10%), colorectal (5%), others. Present with focal deficits, headache, seizure. MRI with contrast shows enhancing lesions. Management: whole-brain radiation therapy (WBRT), stereotactic radiosurgery (SRS) for 1-3 lesions, chemotherapy based on primary cancer. Surgery if single accessible lesion causing mass effect or biopsy needed.</p>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Ring-Enhancing Lesion Differential</div>
                            <p>Ring-enhancing lesions on post-contrast MRI suggest: brain abscess, CNS lymphoma, glioblastoma, metastases, toxoplasmosis (AIDS), tuberculoma, cysticercosis. Clinical context essential: AIDS patient = toxo likely; fever/headache = abscess; no risk factors = glioma/metastasis. Biopsy often needed for definitive diagnosis.</p>
                        </div>
                    </div>
                </div>

                <!-- Practice Question 11 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q11: A 55-year-old male with history of melanoma (Stage III, treated 5 years ago) presents with headache and focal weakness. MRI shows two 8mm ring-enhancing lesions in the cerebral hemispheres. What is the most likely diagnosis and next management step?</div>
                        <div class="question-option">
                            <input type="radio" name="q11" value="a"> A) Brain abscess; start antibiotics immediately pending culture
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q11" value="b"> B) Brain metastases from melanoma; consider stereotactic radiosurgery (SRS) given number and size of lesions
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q11" value="c"> C) CNS lymphoma; biopsy for definitive diagnosis and treatment planning
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q11" value="d"> D) Glioblastoma; arrange urgent surgical resection
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q11')">Show Answer</button>
                        <div id="q11-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> The clinical context (history of melanoma) strongly favors brain metastases. Melanoma has high propensity for CNS involvement. The presence of two lesions (<3 total) makes SRS a reasonable option; if more lesions or diffuse disease, WBRT would be considered. While ring-enhancing lesions have a differential, the history of cancer makes metastasis most likely. Abscess would be suggested by fever/infection signs. Lymphoma and glioma are less likely given the clear metastatic history. Staging CT chest/abdomen also needed to assess systemic disease burden.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> WHO Classification of CNS Tumors. 5th ed. Louis DN et al. 2021.</li>
                        <li><span class="ref-guideline">[G2]</span> EANO Guidelines for Diffuse Gliomas. Weller M et al. <em>Lancet Oncol</em>. 2017;18:e315-e329.</li>
                        <li><span class="ref-trial">[T]</span> <strong>Stupp Protocol (GBM):</strong> Stupp R et al. <em>NEJM</em> 2005;352:987-96. TMZ + radiation vs radiation: OS 14.6 vs 12.1 months.</li>
                        <li><span class="ref-trial">[T]</span> <strong>RTOG 9402/EORTC 26951:</strong> Cairncross G et al. <em>JCO</em> 2013;31:337-43. PCV in 1p/19q codeleted oligodendroglioma: 14.7 years median OS.</li>
                        <li>[R] Ostrom QT et al. CBTRUS Statistical Report. <em>Neuro Oncol</em>. 2022;24:v1-v95.</li>
                        <li>[R] Grommes C, DeAngelis LM. Primary CNS lymphoma. <em>JCO</em>. 2017;35:2410-2418.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 15: Spinal Cord Disorders -->
            <section id="section-11" class="section">
                <h1 class="section-title">11. Spinal Cord Disorders</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Myelopathy Syndromes: Anatomic Correlation</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Syndrome</th>
                                <th>Lesion Location</th>
                                <th>Clinical Features</th>
                                <th>Common Etiologies</th>
                            </tr>
                            <tr>
                                <td><strong>Complete Transverse Myelopathy</strong></td>
                                <td>Entire cross-section</td>
                                <td>Bilateral motor/sensory loss below lesion level; sphincter dysfunction; spasticity/hyperreflexia; loss of all modalities</td>
                                <td>Acute: trauma, spinal cord infarction, severe demyelination. Chronic: tumor, spondylosis</td>
                            </tr>
                            <tr>
                                <td><strong>Brown-Séquard Syndrome</strong></td>
                                <td>Hemisection (lateral half)</td>
                                <td>Ipsilateral motor loss + proprioception loss (dorsal column); contralateral pain/temperature loss (spinothalamic tract 2-3 levels below). Crossed syndrome.</td>
                                <td>Hemisection lesion: trauma, spinal cord infarction, tumor (rare), demyelination</td>
                            </tr>
                            <tr>
                                <td><strong>Central Cord Syndrome</strong></td>
                                <td>Central gray matter + surrounding white matter</td>
                                <td>Suspended loss of pain/temperature (cape distribution, arms > legs); motor loss variable; proprioception relatively spared early. Hyperreflexia, spasticity.</td>
                                <td>Acute trauma/contusion (most common), syrinx, demyelination, tumor</td>
                            </tr>
                            <tr>
                                <td><strong>Anterior Cord Syndrome</strong></td>
                                <td>Anterior 2/3 of cord (anterior/anterolateral tracts)</td>
                                <td>Motor loss (corticospinal) + pain/temp loss (spinothalamic); proprioception/vibration preserved (dorsal columns). Poor prognosis for recovery.</td>
                                <td>Spinal cord infarction (most common—often from aortic disease/hypotension), anterior compression from tumor/disc</td>
                            </tr>
                            <tr>
                                <td><strong>Posterior Cord Syndrome</strong></td>
                                <td>Posterior columns (dorsal funiculi)</td>
                                <td>Loss of proprioception/vibration; motor and pain/temp relatively preserved. Sensory ataxia, positive Romberg.</td>
                                <td>B12 deficiency (combined central + peripheral neuropathy), tabes dorsalis, dorsal column demyelination (MS, rare)</td>
                            </tr>
                            <tr>
                                <td><strong>Conus Medullaris Syndrome</strong></td>
                                <td>Conus (distal spinal cord, T12-L1 level)</td>
                                <td>Bilateral lower extremity weakness/sensory loss (saddle distribution), sphincter dysfunction (urinary retention/incontinence, fecal dysfunction), back pain at L1. May have early bilateral Babinski signs.</td>
                                <td>Central disc herniation, tumor, tethering, demyelination, spinal cord infarction</td>
                            </tr>
                            <tr>
                                <td><strong>Cauda Equina Syndrome (CES)</strong></td>
                                <td>Multiple nerve roots below conus (L1-S5)</td>
                                <td>Asymmetric lower extremity weakness/pain, asymmetric sensory loss, sphincter dysfunction (variable), areflexia, saddle anesthesia possible but not always. "Radicular" quality pain. Bilateral leg pain.</td>
                                <td><strong>NEUROSURGICAL EMERGENCY:</strong> Large central disc herniation (L4-L5, L5-S1), spinal canal stenosis, tumor, abscess, metastases</td>
                            </tr>
                        </table>

                        <div class="high-yield">
                            <div class="high-yield-title">⚡ Epidural Spinal Cord Compression Emergency</div>
                            <p><strong>Etiologies:</strong> Metastatic cancer (most common), epidural abscess, hematoma, disc herniation. <strong>Presentation:</strong> Progressive myelopathy with back pain (often severe/night pain), lower extremity weakness, sensory level, sphincter dysfunction. <strong>Red flag:</strong> Rapid worsening (hours-days). <strong>Diagnosis:</strong> Stat MRI spine with contrast. <strong>Management:</strong> Corticosteroids (dexamethasone 10 mg IV loading, then 4 mg Q6H), oncology/neurosurgery consult urgently, radiation oncology if malignancy. Surgery if cord compression, neurologic deterioration despite steroids, or radiation contraindicated. Time-critical: earlier treatment → better prognosis for ambulation.</p>
                        </div>

                        <p><strong>Spinal Cord Infarction (Spinal Stroke):</strong> Can present as anterior cord syndrome (loss of motor + pain/temp with preserved proprioception). Vascular supply: artery of Adamkiewicz (L1-L3 region, supplies lower thoracic/lumbar cord). Causes: aortic disease (aortic dissection, atherosclerosis), hypotension, surgery, artery occlusion, vasculitis. Acute onset, often severe pain. MRI shows T2 hyperintensity in cord. Treatment: supportive, address underlying vascular cause. Poor prognosis; motor recovery limited.</p>
                    </div>
                </div>

                <!-- Practice Question 12 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q12: A 60-year-old woman with history of breast cancer (treated 3 years ago) presents with acute-onset severe low back pain and bilateral leg pain/weakness, with urinary retention. MRI shows a large central disc herniation at L4-L5 compressing multiple nerve roots. What is the most appropriate immediate management?</div>
                        <div class="question-option">
                            <input type="radio" name="q12" value="a"> A) Physical therapy and NSAIDs; reassess in 1 week if no improvement
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q12" value="b"> B) EMERGENCY neurosurgical evaluation for urgent decompression; treat cauda equina syndrome
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q12" value="c"> C) Epidural corticosteroid injection to reduce inflammation
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q12" value="d"> D) Chemotherapy to address possible metastatic recurrence
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q12')">Show Answer</button>
                        <div id="q12-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> This is cauda equina syndrome (CES)—a neurosurgical emergency requiring decompression within 48 hours ideally, before severe irreversible nerve damage occurs. Bilateral leg symptoms, urinary retention, and imaging showing significant compression at L4-L5 confirm CES. Delayed surgery worsens prognosis for motor recovery and sphincter function. Corticosteroid injection (option C) is contraindicated in active CES. Physical therapy (option A) is inappropriate for acute compression requiring surgical decompression. While cancer history raises concern for metastasis, the primary imaging finding (disc herniation) and clinical syndrome call for urgent disc herniation decompression.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li><span class="ref-guideline">[G1]</span> AANS/CNS Guidelines for Acute Cervical Spine and Spinal Cord Injuries. Walters BC et al. <em>Neurosurgery</em>. 2013.</li>
                        <li>[R] Darouiche RO. Spinal Epidural Abscess. <em>NEJM</em> 2006;355:2012-20.</li>
                        <li>[R] Patchell RA et al. Surgical resection in spinal cord compression. <em>Lancet</em>. 2005;366:643-48.</li>
                        <li>[R] Transverse Myelitis Consortium. Diagnostic criteria. <em>Neurology</em>. 2002;59:499-505.</li>
                        <li>[R] Barreras P et al. Spinal cord infarction. <em>Continuum</em>. 2018;24:407-26.</li>
                    </ul>
                </div>
            </section>
            <!-- Section 16: Neurological Emergencies Summary -->
            <section id="section-12" class="section">
                <h1 class="section-title">12. Neurological Emergencies Summary</h1>

                <div class="subsection">
                    <div class="subsection-title">
                        <span class="toggle-icon">▼</span>
                        <span>Time-Critical Neuro Emergencies: Recognition & Action</span>
                    </div>
                    <div class="subsection-content">
                        <table>
                            <tr>
                                <th>Emergency</th>
                                <th>Key Recognition Features</th>
                                <th>Immediate Actions</th>
                                <th>Critical Timeline</th>
                            </tr>
                            <tr>
                                <td><strong>Acute Ischemic Stroke (LVO)</strong></td>
                                <td>Sudden focal deficit (NIHSS ≥11 suggests LVO), facial droop, arm drift, speech difficulty, time known</td>
                                <td>Stat CT/CTA, stroke team activation, IV tPA if eligible (0-4.5h), thrombectomy if LVO (0-6h standard, 6-24h selected)</td>
                                <td>Door-to-CT <25 min, door-to-needle <60 min, door-to-thrombectomy <120 min</td>
                            </tr>
                            <tr>
                                <td><strong>Hemorrhagic Stroke (ICH)</strong></td>
                                <td>Sudden onset severe headache + neuro deficit, CT shows hyperdense lesion, elevated BP</td>
                                <td>Stat CT, neurosurgery consult if large hematoma/posterior fossa, reverse anticoagulation urgently (FFP/PCC/idarucizumab), target SBP 130-140, osmotic therapy (mannitol/hypertonic saline)</td>
                                <td>Hematoma expansion most in first 24h; early BP control critical</td>
                            </tr>
                            <tr>
                                <td><strong>Subarachnoid Hemorrhage</strong></td>
                                <td>Thunderclap headache (worst of life), neck stiffness, vision changes, syncope, CT with blood in subarachnoid space</td>
                                <td>Stat CT, neurosurgery consult, aneurysm securing (endovascular coiling or surgery) ASAP, nimodipine 60 mg Q4H x21 days, manage vasospasm (hemodynamic augmentation, Ca channel blockers, angioplasty if needed)</td>
                                <td>Risk of rebleeding highest first 24h; vasospasm peaks day 4-14</td>
                            </tr>
                            <tr>
                                <td><strong>Status Epilepticus (SE)</strong></td>
                                <td>Seizure lasting >5 min or ≥2 seizures without recovery; may be non-convulsive (confusion, altered behavior)</td>
                                <td>Lorazepam 4 mg IV or midazolam 10 mg IM (Stage 1), second-line antiepileptic at 5-20 min if seizure continues (Stage 2), anesthesia/intubation if refractory (Stage 3), identify/treat trigger (hypoglycemia, infection, withdrawal)</td>
                                <td>Treatment delays every minute increase morbidity; mortality if RSE untreated</td>
                            </tr>
                            <tr>
                                <td><strong>Bacterial Meningitis</strong></td>
                                <td>Fever, headache, neck stiffness, altered mental status, petechial rash (meningococcemia), high CSF protein/low glucose/elevated WBC</td>
                                <td>Blood cultures, empiric antibiotics BEFORE LP (don't delay for imaging if high suspicion), dexamethasone 10 mg IV WITH first antibiotic dose, CSF analysis (LP if safe), identify organism, source control</td>
                                <td>Antibiotics within 1 hour of presentation; dexamethasone timing critical for outcomes</td>
                            </tr>
                            <tr>
                                <td><strong>Encephalitis (HSV)</strong></td>
                                <td>Fever, altered consciousness, behavioral changes, seizures, temporal lobe predilection on MRI, temporal periodicity on EEG</td>
                                <td>Start acyclovir 10-15 mg/kg IV Q8H IMMEDIATELY (don't wait for LP/EEG), CSF HSV PCR, supportive care, seizure management</td>
                                <td>Early treatment (first 48h) vastly improves outcomes; delays cause permanent sequelae</td>
                            </tr>
                            <tr>
                                <td><strong>Spinal Cord Compression/CES</strong></td>
                                <td>Progressive myelopathy, back pain, bilateral leg symptoms, urinary retention, saddle anesthesia, sphincter dysfunction, rapid worsening</td>
                                <td>Stat MRI spine with contrast, neurosurgery urgent consult, decompress within 48h (sooner if acute deterioration), corticosteroids if metastatic (not standard for disc CES, but consider if malignancy)</td>
                                <td>Outcome (ambulation, continence) depends on duration of compression; <48h optimal</td>
                            </tr>
                            <tr>
                                <td><strong>Acute Epidural Abscess</strong></td>
                                <td>Fever, back pain, progressive neurologic deficit, elevated inflammatory markers, MRI shows enhancing epidural collection, cord compression possible</td>
                                <td>Stat MRI, blood cultures, broad-spectrum antibiotics (cover Staph, Strep, GNR), source control (surgical drainage if cord compression or neurologic deterioration), neurosurgery consult</td>
                                <td>Urgent intervention needed; delayed treatment risks permanent paralysis</td>
                            </tr>
                            <tr>
                                <td><strong>Increased Intracranial Pressure/Herniation</strong></td>
                                <td>Altered consciousness, blown pupil, focal deficits, abnormal posturing, imaging shows mass effect/midline shift</td>
                                <td>Head of bed 30°, hyperventilate to pCO2 30-35 (temporary), osmotic therapy (mannitol 1 g/kg or hypertonic saline 3% bolus), lorazepam if seizures, STAT neurosurgery if mass lesion (hematoma, tumor, abscess), avoid hypotension/fever</td>
                                <td>Herniation progression rapid; minutes count for intervention</td>
                            </tr>
                            <tr>
                                <td><strong>Myasthenic Crisis</strong></td>
                                <td>Respiratory muscle weakness (declining VC, weak cough), bulbar dysfunction (aspiration risk), progressive weakness unresponsive to pyridostigmine</td>
                                <td>Intubate prophylactically if VC declining/aspiration risk, IVIG 2g/kg or PLEX to rapidly improve strength, ICU monitoring, identify trigger (infection, medication change), continue other MG therapies</td>
                                <td>Respiratory failure can develop rapidly; anticipate intubation before complete decompensation</td>
                            </tr>
                            <tr>
                                <td><strong>Guillain-Barré Syndrome</strong></td>
                                <td>Ascending paralysis, areflexia, respiratory involvement possible, CSF albuminocytologic dissociation, abnormal NCS</td>
                                <td>Admit ICU if respiratory compromise anticipated, FVC/MIF monitoring, IVIG 2g/kg or PLEX (both effective), supportive ventilation if needed, prophylaxis for autonomic instability, identify/treat trigger</td>
                                <td>Peak disability usually 2-3 weeks; recovery slow (weeks-months); early treatment improves outcomes</td>
                            </tr>
                        </table>

                        <div class="clinical-pearl">
                            <strong>Clinical Pearl - Universal Principles in Neuro Emergencies:</strong> (1) <strong>Time is brain:</strong> Delays in diagnosis/treatment lead to irreversible damage. (2) <strong>Don't let perfect be enemy of good:</strong> Start treatment based on clinical suspicion; confirmatory tests done in parallel. (3) <strong>Anticipate worst:</strong> Admit to ICU early if any chance of deterioration. (4) <strong>Airway first:</strong> In altered consciousness, secure airway proactively; aspiration/hypoventilation worse than intubation burden.
                        </div>
                    </div>
                </div>

                <!-- Practice Question 13 -->
                <div class="practice-questions">
                    <div class="question">
                        <div class="question-text">Q13: A 28-year-old man presents with acute fever (39.5°C), severe headache, neck stiffness, and altered mental status. He vomited once. Which is the appropriate initial sequence of actions?</div>
                        <div class="question-option">
                            <input type="radio" name="q13" value="a"> A) Stat head CT to rule out mass effect, then lumbar puncture to obtain CSF for culture and analysis
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q13" value="b"> B) Blood cultures, empiric antibiotics (ceftriaxone + vancomycin) + dexamethasone IV immediately; head CT only if LP deferred or CSF abnormal suggests mass lesion
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q13" value="c"> C) Supportive care with antipyretics; await CSF analysis from LP before starting antibiotics
                        </div>
                        <div class="question-option">
                            <input type="radio" name="q13" value="d"> D) Start acyclovir empirically while awaiting viral studies
                        </div>
                        <button class="show-answer-btn" onclick="toggleAnswer('q13')">Show Answer</button>
                        <div id="q13-answer" class="answer-content">
                            <div class="correct-answer">✓ Correct Answer: B</div>
                            <div class="explanation"><strong>Explanation:</strong> Bacterial meningitis is a medical emergency with high mortality if treatment delayed. Current guidelines emphasize: start antibiotics (+ dexamethasone) BEFORE lumbar puncture, based on clinical suspicion. Blood cultures drawn first, then immediate empiric therapy (ceftriaxone covers meningococcal/pneumococcal; vancomycin for resistant pneumococcus; dexamethasone WITH first antibiotic dose to reduce complications). Defer CT unless: altered consciousness/focality raising concern for mass effect, or if LP cannot be performed safely. Option A inappropriately delays treatment; option C is dangerous (no treatment delay). Option D misses bacterial meningitis diagnosis; acyclovir should be added if encephalitis suspected, but not before antibiotics for meningitis.</div>
                        </div>
                    </div>
                </div>
                <div class="reference-box">
                    <h4>REFERENCES & EVIDENCE</h4>
                    <ul>
                        <li>[R] Comprehensive references are in each respective section (1-12) above.</li>
                        <li>[R] Wijdicks EFM et al. Prediction of outcome in comatose survivors after CPR. <em>Neurology</em>. 2006;67:203-210.</li>
                        <li>[R] Frontera JA et al. Reversal of Antithrombotics in ICH. <em>Neurocrit Care</em>. 2016;24:6-46.</li>
                        <li>[R] Rabinstein AA. Treatment of Acute Ischemic Stroke. <em>Continuum</em>. 2020;26:268-286.</li>
                    </ul>
                </div>
            </section>
        </main>
    </div>

    <script>
        // Navigation and sections data
                const sections = [
            { id: 'section-1', title: '1. Cerebrovascular Disease' },
            { id: 'section-2', title: '2. Epilepsy and Seizure Disorders' },
            { id: 'section-3', title: '3. Movement Disorders' },
            { id: 'section-4', title: '4. Headache Disorders' },
            { id: 'section-5', title: '5. Neuromuscular Disorders' },
            { id: 'section-6', title: '6. Demyelinating Diseases' },
            { id: 'section-7', title: '7. CNS Infections' },
            { id: 'section-8', title: '8. Dementia and Cognitive Disorders' },
            { id: 'section-9', title: '9. Sleep Disorders' },
            { id: 'section-10', title: '10. Neuro-Oncology' },
            { id: 'section-11', title: '11. Spinal Cord Disorders' },
            { id: 'section-12', title: '12. Neurological Emergencies' }
        ];

        const readSections = new Set();

        // Initialize navigation
        function initNav() {
            const navLinks = document.getElementById('navLinks');
            sections.forEach(section => {
                const link = document.createElement('div');
                link.className = 'nav-link';
                link.textContent = section.title;
                link.onclick = () => showSection(section.id);
                link.id = 'nav-' + section.id;
                navLinks.appendChild(link);
            });
        }

        // Show section and update nav
        function showSection(sectionId) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.getElementById(sectionId).classList.add('active');

            document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
            document.getElementById('nav-' + sectionId).classList.add('active');

            if (!readSections.has(sectionId)) {
                readSections.add(sectionId);
                updateProgress();
            }

            window.scrollTo(0, 0);
        }

        // Update progress bar
        function updateProgress() {
            const progress = (readSections.size / sections.length) * 100;
            document.getElementById('progressFill').style.width = progress + '%';
            document.getElementById('progressText').textContent = `${readSections.size} of ${sections.length} sections read`;
        }

        // Toggle subsections
        document.addEventListener('click', (e) => {
            if (e.target.closest('.subsection-title')) {
                const subsection = e.target.closest('.subsection-title');
                const content = subsection.nextElementSibling;
                content.classList.toggle('collapsed');
                subsection.querySelector('.toggle-icon').textContent = content.classList.contains('collapsed') ? '▶' : '▼';
            }
        });

        // Search functionality
        function performSearch() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            if (!searchTerm) {
                document.querySelectorAll('.highlight').forEach(el => {
                    el.outerHTML = el.innerHTML;
                });
                return;
            }

            const mainContent = document.querySelector('.main-content');
            const walker = document.createTreeWalker(
                mainContent,
                NodeFilter.SHOW_TEXT,
                null,
                false
            );

            let node;
            const highlightedNodes = [];
            while (node = walker.nextNode()) {
                if (node.textContent.toLowerCase().includes(searchTerm)) {
                    highlightedNodes.push(node);
                }
            }

            highlightedNodes.forEach(node => {
                const regex = new RegExp(`(${searchTerm})`, 'gi');
                const span = document.createElement('span');
                span.innerHTML = node.textContent.replace(regex, '<span class="highlight">$1</span>');
                node.parentNode.replaceChild(span, node);
            });
        }

        document.getElementById('searchInput').addEventListener('keyup', performSearch);

        // Dark mode toggle
        document.getElementById('darkModeToggle').addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            document.querySelector('.search-bar').classList.toggle('dark-mode');
        });

        // Answer reveal
        function toggleAnswer(questionId) {
            const answerContent = document.getElementById(questionId + '-answer');
            answerContent.classList.toggle('show');
            const button = event.target;
            button.textContent = answerContent.classList.contains('show') ? 'Hide Answer' : 'Show Answer';
        }

        // Initialize on load
        window.addEventListener('DOMContentLoaded', () => {
            initNav();
            showSection('section-1');
        });
    </script>
</body>
</html>
    </div>

